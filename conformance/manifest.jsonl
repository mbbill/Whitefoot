# xlang conformance manifest — one JSON object per case (blank / #-lines ignored).
# id -> cases/<id>.xl ; rules[] -> spec rule ids exercised ; expect -> required verdict.
# status: runnable (must match) | pending (toolchain can't run yet) | xfail (tracked gap).
{"id": "run-ex1-value-match", "rules": ["GRAM-10", "GRAM-11", "GIVE-1", "ERR-1", "OP-1"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "EX-1-class program: let-init give value-match, named binders, named user-fn call, checked arithmetic; runs to exit 0."}
{"id": "run-ex2-loop-trap-folds", "rules": ["GRAM-4", "OP-1", "OP-2"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "loop + trapping arithmetic; every trap proven away at -O2, folds to a constant return."}
{"id": "reject-err2-nonexhaustive", "rules": ["ERR-2"], "expect": {"kind": "reject", "rule": "ERR-2"}, "status": "runnable", "doc": "A match missing a variant arm is rejected; exhaustiveness cannot be silenced (W3)."}
{"id": "reject-own10-dangle", "rules": ["OWN-10"], "expect": {"kind": "reject", "rule": "OWN-10"}, "status": "runnable", "doc": "Returning a borrow of an own parameter into a caller region is a dangling reference; rejected before codegen."}
{"id": "trap-op5-check-fails", "rules": ["OP-5", "SCOPE-4"], "expect": {"kind": "trap"}, "status": "runnable", "doc": "A failed check traps at runtime and aborts (no unwinding)."}
{"id": "reject-gram11-unnamed-call", "rules": ["GRAM-11"], "expect": {"kind": "reject", "rule": "GRAM-11"}, "status": "pending", "reason": "democ rejects positional user-calls at parse time via a bare assertion, without citing GRAM-11 (a DIAG-1 gap in the demo parser); runnable once parse errors cite rule ids", "doc": "A user-fn call with positional (unnamed) args must be rejected citing GRAM-11; named-in-declared-order is required."}
{"id": "xfail-own1-bare-affine-use", "rules": ["OWN-1"], "expect": {"kind": "reject", "rule": "OWN-1"}, "status": "runnable", "doc": "A bare use of an affine value must be rejected (write move); now rejected."}
{"id": "pending-op9-buffer-new", "rules": ["TYPE-2", "OP-9"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no buffer codegen yet", "doc": "buffer_new allocates a runtime-length flat buffer; size-overflow traps [OP-9]."}
{"id": "pending-const2-item", "rules": ["CONST-2"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no const-item support yet", "doc": "A named immutable const item."}
{"id": "scope1-pos-kernel-no-gated", "rules": ["SCOPE-1"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "A conformant kernel program contains no gated constructs and is accepted [SCOPE-1]."}
{"id": "scope2-pos-accepted", "rules": ["SCOPE-2"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "A program that parses, satisfies every rule, and carries its checks is accepted [SCOPE-2]; the reject direction of the iff is exercised by every reject case in the suite."}
{"id": "scope3-pos-defined-run", "rules": ["SCOPE-3"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "An accepted program has no undefined behavior and runs to a normal exit [SCOPE-3]."}
{"id": "scope4-pos-check-traps", "rules": ["SCOPE-4"], "expect": {"kind": "trap"}, "status": "runnable", "doc": "A runtime contract violation (failed check) traps and aborts with no unwinding [SCOPE-4]."}
{"id": "form1-pos-canonical", "rules": ["FORM-1"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "A canonical-form program (one spelling per construct, one legal byte formatting) is accepted [FORM-1]."}
{"id": "form1-neg-unknown-construct", "rules": ["FORM-1"], "expect": {"kind": "reject", "rule": "FORM-1"}, "status": "pending", "reason": "democ rejects the unknown construct via a bare parse assertion without citing a rule id (a DIAG-1 gap in the demo parser); runnable once parse errors cite rule ids.", "doc": "An unknown construct is a hard error (conservative extension) [FORM-1]."}
{"id": "form2-pos-canonical-bytes", "rules": ["FORM-2"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "A byte-canonical program (two-space indent, one space after ':', one statement per line) is accepted and runs [FORM-2]."}
{"id": "form2-neg-noncanonical-ws", "rules": ["FORM-2"], "expect": {"kind": "reject", "rule": "FORM-2"}, "status": "xfail", "reason": "democ's regex tokenizer is whitespace-insensitive and does not enforce FORM-2 byte formatting; the mis-indented, mis-spaced source is silently accepted. Found 2026-07-08; fix with a canonical-form gate.", "doc": "Non-canonical whitespace (four-space indent, no space after ':') must be a hard error [FORM-2]; democ is whitespace-insensitive and accepts it."}
{"id": "form3-pos-lexical-classes", "rules": ["FORM-3"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "IDENT, TYPEID, REGIONID ('r), LABEL (@l), and OPNAME (iadd.checked) lexical classes used canonically; runs [FORM-3]."}
{"id": "form3-neg-opname-bad-suffix", "rules": ["FORM-3"], "expect": {"kind": "reject", "rule": "FORM-3"}, "status": "pending", "reason": "democ's tokenizer accepts an out-of-set mode suffix and fails later at codegen with a bare SystemExit (no FORM-3 rule id); runnable once OPNAME suffixes are lexically constrained to {wrap,trap,checked,strict} and the rejection cites FORM-3.", "doc": "An OPNAME's mode suffix is a closed word set; 'iadd.bogus' is not a legal OPNAME [FORM-3]."}
{"id": "form3-neg-typeid-fn-name", "rules": ["FORM-3"], "expect": {"kind": "reject", "rule": "FORM-3"}, "status": "xfail", "reason": "democ does not enforce the IDENT lexical class on fn names and accepts a TYPEID-spelled name ('Main'). Found 2026-07-08; fix with lexical-class validation of declaration names.", "doc": "A fn name must be an IDENT ([a-z][a-z0-9_]*); a TYPEID-spelled name must be rejected [FORM-3]."}
{"id": "form4-pos-doc-not-comment", "rules": ["FORM-4"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "There are no comments; documentation rides the doc field of a declaration [FORM-4]."}
{"id": "form4-neg-comment", "rules": ["FORM-4"], "expect": {"kind": "reject", "rule": "FORM-4"}, "status": "pending", "reason": "democ has no comment lexeme; comment text tokenizes as spurious idents and fails at parse via a bare assertion (no FORM-4 rule id); runnable once a comment lexeme is recognized and rejected with a cited rule id.", "doc": "A source comment must be a hard error; documentation belongs in the doc field [FORM-4]."}
{"id": "form5-pos-suffixed-literal", "rules": ["FORM-5"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "An integer literal carries its mandatory type suffix ('42_i32') [FORM-5]."}
{"id": "form5-neg-missing-suffix", "rules": ["FORM-5"], "expect": {"kind": "reject", "rule": "FORM-5"}, "status": "xfail", "reason": "democ has no literal-suffix lexing beyond the _i32 form; a suffixless integer is parsed as an identifier place and rejected as an unbound name citing TYPE-5, not FORM-5. Found 2026-07-08.", "doc": "An integer literal without its mandatory type suffix ('42') is illegal [FORM-5]."}
{"id": "form6-pos-unit-type-and-value", "rules": ["FORM-6"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "'unit' names the unit type in type position ('own unit') and the unit value in expression position ('= unit'), resolved by disjoint productions [FORM-6]."}
{"id": "form7-pos-in-range", "rules": ["FORM-7"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "An in-range integer literal (i32 max, 2147483647_i32) is well-formed [FORM-7]."}
{"id": "form7-neg-out-of-range", "rules": ["FORM-7"], "expect": {"kind": "reject", "rule": "FORM-7"}, "status": "xfail", "reason": "democ does not range-check integer literals; an out-of-range value (9999999999 > i32 max) is silently accepted rather than rejected at check time. Found 2026-07-08; fix with FORM-7 literal well-formedness checking.", "doc": "An out-of-range integer literal is a hard error at check time; a literal never denotes a wrapped or truncated value [FORM-7]."}
{"id": "form7-neg-leading-zero", "rules": ["FORM-7"], "expect": {"kind": "reject", "rule": "FORM-7"}, "status": "xfail", "reason": "democ does not check leading-zero literal form; '007_i32' is silently accepted. Found 2026-07-08; fix with FORM-7 literal well-formedness checking.", "doc": "A leading-zero integer literal is illegal; the single digit 0 is its own form [FORM-7]."}
{"id": "gram1-pos-lookahead", "rules": ["GRAM-1"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "No checkable negative: grammar determinism is a meta-property; a violation would be a spec defect, not a writer-emittable program that democ could reject with a rule id.", "doc": "GRAM-1: the FIRST-set overlaps between construct K(), table-op op<t>(), and user call f(param:atom), and between a statement match and a let-initializer match, each parse to exactly one core-tree node under two-token lookahead; runs to exit 0."}
{"id": "gram2-pos-items", "rules": ["GRAM-2"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "No checkable negative: a malformed item is a parse-level error democ reports as a bare assertion without a rule id (DIAG-1 gap), and the spec attaches no citation to item-grammar violations.", "doc": "GRAM-2: a program is item* \u2014 here two fn_decl items and one enum_decl item; compiles and runs to exit 0."}
{"id": "gram3-pos-modes", "rules": ["GRAM-3"], "expect": {"kind": "accept"}, "status": "runnable", "reason": "No checkable negative: a bad type/mode token is a bare parse assertion without a rule id, not a rule-cited rejection.", "doc": "GRAM-3: the three modes own / &'r / &uniq 'r written explicitly on i32 params, with a region_param declaring 'r; accepted."}
{"id": "gram4-pos-stmts", "rules": ["GRAM-4"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "No checkable negative: an ill-formed statement is a bare parse assertion without a rule id (DIAG-1 gap).", "doc": "GRAM-4: exercises let, region, loop, statement-match, break, set, give (let-initializer match), check, and return statements; runs to exit 0."}
{"id": "gram5-pos-exprs-places", "rules": ["GRAM-5"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "The `move place` atom is a GRAM-5 form democ's parser does not yet handle (outside the profile), so it is omitted; no rule-cited negative exists (bad expressions are bare parse assertions).", "doc": "GRAM-5: literal atom, place atom, borrow_expr atom (&'r p), deref place, a table-op call, and a construct \u2014 the expression/place forms; runs to exit 0."}
{"id": "gram6-pos-no-operators", "rules": ["GRAM-6"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "No checkable negative: an infix operator, `if`, `while`, or `for` fails to tokenize/parse and surfaces as a bare assertion without a rule id, not a rule-cited rejection.", "doc": "GRAM-6: no operators/if/while/for \u2014 arithmetic is named ops (iadd/isub), the conditional is a match on prelude Bool, and iteration is loop+break; sums 4..1 == 10 and runs to exit 0."}
{"id": "gram7-pos-two-productions", "rules": ["GRAM-7"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "No checkable negative for GRAM-7 itself: give-freedom / double-give in a let-match arm is GIVE-1, and a give in a statement match is GIVE-1's checker-scoped restriction, not a GRAM-7 citation.", "doc": "GRAM-7: one match arm shape used in both disjoint productions \u2014 a let-initializer (value-producing, terminates in give) and a statement match (acts by effect, no value) \u2014 sharing one core-tree node kind; runs to exit 0."}
{"id": "gram8-pos-construct", "rules": ["GRAM-8"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "GRAM-8 positive: named construction writes W's declared field once as inner:atom, and the nullary variant is written N(); accepted and runs to exit 0."}
{"id": "gram8-neg-wrong-field", "rules": ["GRAM-8"], "expect": {"kind": "reject", "rule": "GRAM-8"}, "status": "runnable", "doc": "GRAM-8 negative: a construct of W with a misspelled field name (inr for inner) is a hard error citing GRAM-8 and K's declared field list."}
{"id": "gram8-neg-out-of-order", "rules": ["GRAM-8"], "expect": {"kind": "reject", "rule": "GRAM-8"}, "status": "runnable", "doc": "GRAM-8 negative: constructing P with fields in reversed order (b, a) is rejected citing GRAM-8 \u2014 declared order is the one legal byte sequence, never a reordering option."}
{"id": "gram9-pos-three-address", "rules": ["GRAM-9"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "GRAM-9 positive: flat three-address computation \u2014 each intermediate (s, then p) is bound by a let stating its explicit mode/type and forwarded by name; no expression nesting. Runs to exit 0."}
{"id": "gram9-neg-nested-call", "rules": ["GRAM-9"], "expect": {"kind": "reject", "rule": "GRAM-9"}, "status": "xfail", "reason": "democ's recursive-descent parser recurses into full expr for operands and does not enforce the GRAM-9 atom restriction, so it accepts the nested call; reject[GRAM-9] is the correct spec behavior \u2014 a tracked gap (found 2026-07-08).", "doc": "GRAM-9 negative: a call (iadd.wrap) in an atom position \u2014 nested inside imul.wrap's operand \u2014 does not derive under the grammar and must be a hard error citing GRAM-9; the fix is to bind it with a preceding let."}
{"id": "gram10-pos-named-binders", "rules": ["GRAM-10"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "GRAM-10 positive: each variant field is bound as field:binder with a fresh writer-chosen IDENT in declared order \u2014 Ok(value: w), Err(error: e); runs to exit 0."}
{"id": "gram10-neg-wrong-field", "rules": ["GRAM-10"], "expect": {"kind": "reject", "rule": "GRAM-10"}, "status": "runnable", "doc": "GRAM-10 negative: a match arm that names the Ok field val instead of its declared name value is a hard error citing GRAM-10 and K's declared field list."}
{"id": "gram11-pos-named-args", "rules": ["GRAM-11"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "GRAM-11 positive: a call to user fn add2 names its arguments as x:atom, y:atom in declared parameter order \u2014 the GRAM-8 discipline applied to calls; runs to exit 0."}
{"id": "gram11-neg-misspelled", "rules": ["GRAM-11"], "expect": {"kind": "reject", "rule": "GRAM-11"}, "status": "runnable", "doc": "GRAM-11 negative: a call to add2 naming a parameter z that is not in the callee's parameter list (x, y) is a hard error citing GRAM-11."}
{"id": "gram11-neg-out-of-order", "rules": ["GRAM-11"], "expect": {"kind": "reject", "rule": "GRAM-11"}, "status": "runnable", "doc": "GRAM-11 negative: a call to sub2 writing its named arguments out of declared order (y, x) is rejected citing GRAM-11 \u2014 parameter names are checked facts, never a reordering license."}
{"id": "type1-pos-i32-unit", "rules": ["TYPE-1"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "i32 and unit primitives [TYPE-1]: a checked add and an equality check run to exit 0."}
{"id": "type1-pos-wide-prims", "rules": ["TYPE-1"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "The full primitive set beyond i32 (i8/i64/u32/f64 params) is nameable and type-checks [TYPE-1]."}
{"id": "type2-pos-enum", "rules": ["TYPE-2"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "enum is a composite type [TYPE-2]: a value is constructed and matched; runs to exit 0."}
{"id": "type3-pos-nameable", "rules": ["TYPE-3"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "Every mode (own, &'r, &uniq 'r) and every type has a written canonical name requiring no compiler execution [TYPE-3]."}
{"id": "type4-pos-cvt", "rules": ["TYPE-4"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no cvt codegen (op cvt is outside its op subset); the single representation-change op cannot be lowered yet", "doc": "cvt<i32,i64> is the single explicit representation-change op [TYPE-4]; i32->i64 is a total pair."}
{"id": "type5-pos-explicit", "rules": ["TYPE-5"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "Every let states its full mode+type and the call states its type arg; all argument types match declared types exactly [TYPE-5]."}
{"id": "type5-neg-arg-mismatch", "rules": ["TYPE-5"], "expect": {"kind": "reject", "rule": "TYPE-5"}, "status": "runnable", "doc": "A unit argument passed where an i32 parameter is declared violates exact argument typing [TYPE-5]."}
{"id": "type6-pos-distinct-names", "rules": ["TYPE-6"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "Distinct value names plus a break to a lexically enclosing loop label [TYPE-6]; runs to exit 0."}
{"id": "type6-neg-dup-variant", "rules": ["TYPE-6"], "expect": {"kind": "reject", "rule": "TYPE-6"}, "status": "runnable", "doc": "Two enums declaring the same variant name Dup() violate global variant-name uniqueness [TYPE-6]."}
{"id": "type6-neg-shadow", "rules": ["TYPE-6"], "expect": {"kind": "reject", "rule": "TYPE-6"}, "status": "runnable", "doc": "Redeclaring a live name (`let a` twice) must be rejected as shadowing [TYPE-6]; democ currently accepts it (tracked gap)."}
{"id": "type7-pos-deref", "rules": ["TYPE-7"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "Reading through a borrow is explicit via deref(place) [TYPE-7]; reads 42 back through &'r and runs to exit 0."}
{"id": "type7-neg-deref-nonref", "rules": ["TYPE-7"], "expect": {"kind": "reject", "rule": "TYPE-7"}, "status": "runnable", "doc": "deref applied to a non-reference i32 value is malformed [TYPE-7]: deref is defined only for &'r / &uniq 'r / box / arena places."}
{"id": "type7-neg-implicit-read", "rules": ["TYPE-7", "TYPE-5"], "expect": {"kind": "reject", "rule": "TYPE-7"}, "status": "runnable", "doc": "Using a borrow where a value of its referent type is expected, without deref, is the read TYPE-7 forbids; the spec assigns the diagnostic id [TYPE-5], but democ cites TYPE-7 (tracked citation gap)."}
{"id": "const1-pos-array-size", "rules": ["CONST-1"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no array_new codegen (op array_new outside its subset); the literal const-expr size parses but no array runtime is emitted", "doc": "A decimal integer literal is a constant-expression usable as an array<T, N> size [CONST-1]."}
{"id": "const1-neg-noninteger", "rules": ["CONST-1"], "expect": {"kind": "reject", "rule": "CONST-1"}, "status": "pending", "reason": "democ does not parse top-level const items (parser asserts 'fn'), so const-expr resolution \u2014 rejecting a non-integer (unit-typed) const in a size position \u2014 is unimplemented", "doc": "An IDENT resolving to a non-integer (unit-typed) const used in a const-expr (array size) position is a compile-time rejection [CONST-1]."}
{"id": "const2-pos-item", "rules": ["CONST-2"], "expect": {"kind": "accept"}, "status": "pending", "reason": "democ has no const-item support: top-level `const` does not parse (parser asserts 'fn')", "doc": "A named, immutable, program-lifetime const item of primitive type [CONST-2]."}
{"id": "const2-neg-noneligible", "rules": ["CONST-2"], "expect": {"kind": "reject", "rule": "CONST-2"}, "status": "pending", "reason": "democ has no const-item support (top-level `const` does not parse), so const-eligibility of the declared type is unchecked", "doc": "box<T> is not const-eligible \u2014 a const is pure static rodata with no allocation/region/drop \u2014 so a box-typed const is rejected [CONST-2]."}
{"id": "own1-pos-consume-once", "rules": ["OWN-1"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "OWN-1 positive: an affine own-enum value is consumed by exactly one match-move; no reuse, runs to exit 0."}
{"id": "own1-neg-use-after-move", "rules": ["OWN-1", "OWN-13"], "expect": {"kind": "reject", "rule": "OWN-1"}, "status": "runnable", "reason": "Also the OWN-13 negative: matching an own place moves it (OWN-13), so the second match is a use of a dead binding (OWN-1). The checker cites OWN-1 for use-after-move, so this case carries the OWN-13 violation but asserts OWN-1.", "doc": "OWN-1 negative: matching an own value moves it; a second match of the same binding is a use of a moved (dead) binding \u2014 rejected citing OWN-1."}
{"id": "own2-pos-three-modes", "rules": ["OWN-2"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "No rule-id-citing negative exists: an omitted mode is a bare parse-level rejection (no rule id), outside DIAG-1, so only a positive is authored.", "doc": "OWN-2 positive: all three modes are written explicitly \u2014 own (a), shared &'r (s), and &uniq 'q (u) \u2014 read, borrow, and mutate-through-uniq; runs to exit 0."}
{"id": "own3-pos-outlives-store", "rules": ["OWN-3"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "OWN-3 positive: regions are lexical and an enclosing region outlives an inner one; a borrow made in outer 'r is legally stored into an inner &'s destination (outlives-or-equals). Runs to exit 0."}
{"id": "own3-neg-unknown-region", "rules": ["OWN-3"], "expect": {"kind": "reject", "rule": "OWN-3"}, "status": "runnable", "doc": "OWN-3 negative: a borrow names region 'z that was never introduced (no region_params, no enclosing region 'z block) \u2014 rejected citing OWN-3."}
{"id": "own4-pos-return-caller-borrow", "rules": ["OWN-4"], "expect": {"kind": "accept"}, "status": "runnable", "doc": "OWN-4 positive: a borrow made in caller-supplied region 'r0 is returned as rtype region 'r0 \u2014 the returned region equals the borrow's region, so the escape is legal; accepted."}
{"id": "own4-neg-return-local-borrow", "rules": ["OWN-4"], "expect": {"kind": "reject", "rule": "OWN-4"}, "status": "runnable", "doc": "OWN-4 negative: a borrow made in local region 's is returned; a local-region borrow does not outlive the caller and escapes via return \u2014 rejected citing OWN-4."}
{"id": "own5-pos-read-through-holder", "rules": ["OWN-5"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "OWN-5 positive: while a &uniq borrow is live, reads and writes through that borrow's holder are the permitted access path; write-then-read through u, then read the place after the region closes. Runs to exit 0."}
{"id": "own5-neg-read-while-uniq", "rules": ["OWN-5"], "expect": {"kind": "reject", "rule": "OWN-5"}, "status": "runnable", "doc": "OWN-5 negative: while a &uniq borrow of a is live, reading a directly (not through the holder) is an overlapping access \u2014 rejected citing OWN-5."}
{"id": "own6-pos-callscoped-temp", "rules": ["OWN-6"], "expect": {"kind": "accept"}, "status": "runnable", "reason": "OWN-6 (holder/resolution/temporary lifetime) is the mechanism OWN-5/OWN-7 judge over; it is never separately cited, so only a positive that exercises the call-scoped-temporary clause is authored.", "doc": "OWN-6 positive: a borrow passed as a call argument is an unbound call-scoped temporary that dies at the end of its statement; two successive &uniq-argument calls over the same place therefore do not conflict \u2014 accepted."}
{"id": "own7-pos-distinct-noverlap", "rules": ["OWN-7"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "reason": "OWN-7 (overlap definition) is never cited on its own \u2014 an overlap violation cites OWN-5/OWN-12. This positive exercises the distinct-root non-overlap case; richer field/index/slice overlap is pending (democ has only i32 scalars, no fields or arrays).", "doc": "OWN-7 positive: resolved places rooted at distinct bindings a and b do not overlap, so two live &uniq borrows coexist and each mutates its own root; runs to exit 0."}
{"id": "own10-pos-local-region", "rules": ["OWN-10"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "OWN-10 positive: an own binding a is borrowed into a local region 'r introduced within a's scope; storage outlives the borrow, so it is legal. Runs to exit 0."}
{"id": "own10-neg-dangle-caller", "rules": ["OWN-10"], "expect": {"kind": "reject", "rule": "OWN-10"}, "status": "runnable", "doc": "OWN-10 negative: borrowing an own parameter x into caller-supplied region 'r0 (which outlives the frame) would dangle after return \u2014 rejected citing OWN-10 before codegen."}
{"id": "own11-pos-loop-inner-region", "rules": ["OWN-11"], "expect": {"kind": "run", "exit": 0}, "status": "runnable", "doc": "OWN-11 positive: inside loop @l a borrow names region 's introduced within @l's body (reading an outer binding by copy is exempt); one iteration then break. Runs to exit 0."}
{"id": "own11-neg-borrow-outer-region", "rules": ["OWN-11"], "expect": {"kind": "reject", "rule": "OWN-11"}, "status": "runnable", "doc": "OWN-11 negative (first clause): inside loop @l a borrow names region 'r introduced outside the loop \u2014 rejected citing OWN-11 (a cross-iteration borrow would alias itself)."}
{"id": "own11-neg-move-outer-in-loop", "rules": ["OWN-11"], "expect": {"kind": "reject", "rule": "OWN-11"}, "status": "runnable", "doc": "OWN-11 negative (second clause): a binding s declared outside loop @l is moved inside it (via an own-scrutinee match); a second iteration would use a dead binding \u2014 rejected citing OWN-11."}
