enum Sign {
  Neg();
  Zero();
  Pos();
}

fn main() -> own unit traps {
  doc "give is legal only inside a let-initializer match arm; a give in a statement match, which acts by effect and yields no value, is rejected citing GIVE-1 (the break-precedent checker-scoped restriction) [GIVE-1, OWN-13, OP-1].";
  let s: own Sign = Zero();
  match s {
    Neg() => {
      give 0_i32;
    }
    Zero() => {
      give 1_i32;
    }
    Pos() => {
      give 2_i32;
    }
  }
  return unit;
}
