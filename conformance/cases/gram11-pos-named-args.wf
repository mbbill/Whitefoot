fn add2(x: own i32, y: own i32) -> own i32 pure {
  return iadd.wrap<i32>(x, y);
}

fn main() -> own unit traps {
  doc "GRAM-11: a user-fn call names its arguments in declared parameter order.";
  let r: own i32 = add2(x: 40_i32, y: 2_i32);
  check ieq<i32>(r, 42_i32) else trap "drift";
  return unit;
}
