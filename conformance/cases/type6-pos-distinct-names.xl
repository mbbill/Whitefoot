fn main () -> own unit traps {
  doc "Distinct value names and a break to a lexically enclosing loop [TYPE-6].";
  let i: own i32 = 0_i32;
  let total: own i32 = 0_i32;
  loop @l {
    match ige<i32>(i, 3_i32) {
      True() => {
        break @l;
      }
      False() => {
      }
    }
    set total = iadd.trap<i32>(total, i);
    set i = iadd.trap<i32>(i, 1_i32);
  }
  check ieq<i32>(total, 3_i32) else trap "sum drift";
  return unit;
}
