fn positive(x: own i32) -> own i32 traps requires {
  let permitted: own Bool = igt<i32>(x, 0_i32);
  check permitted else trap "x must be positive";
} {
  doc "A false requirement traps at the call boundary before this body executes [FN-8/SCOPE-4].";
  return x;
}

fn main() -> own unit traps {
  let value: own i32 = positive(x: 0_i32);
  check ieq<i32>(value, 0_i32) else trap "unreachable body result";
  return unit;
}
