fn main() -> own unit traps {
  doc "iadd.checked returns Result<T, Overflow> [OP-1]; i32::MAX + 1 yields Err, so the Err arm runs and the Ok arm's guard would trap if overflow went undetected [OP-5].";
  let hi: own i32 = 2147483647_i32;
  match iadd.checked<i32>(hi, 1_i32) {
    Ok(value: v) => {
      check ilt<i32>(v, 0_i32) else trap "overflow was not detected";
      return unit;
    }
    Err(error: e) => {
      return unit;
    }
  }
}
