struct Rec {
  f: u64;
  g: u64;
}

fn main () -> own unit allocates(heap), traps {
  let b: own buffer<u64> = buffer_new<u64>(8_u64, 0_u64);
  let r: own Rec = Rec(f: 1_u64, g: 2_u64);
  let s: own Rec = move r;
  let x: own u64 = index<u64>(b, r.f);
  check ieq<u64>(x, 0_u64) else trap "x";
  return unit;
}
