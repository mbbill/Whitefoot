fn bump(x: own i32) -> own i32 pure {
  doc "A pure helper with no trapping construct.";
  return iadd.wrap<i32>(x, 1_i32);
}

fn f(x: own i32) -> own i32 traps {
  doc "Declares traps but its body only calls a pure fn [EFF-2] declared-but-unexhibited.";
  let a: own i32 = bump(x: x);
  return a;
}

fn main() -> own unit traps {
  doc "Driver.";
  let a: own i32 = f(x: 7_i32);
  check ieq<i32>(a, 8_i32) else trap "x";
  return unit;
}
