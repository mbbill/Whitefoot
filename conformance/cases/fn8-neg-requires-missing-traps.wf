fn missing_effect(x: own i32) -> own i32 pure requires {
  let permitted: own Bool = ige<i32>(x, 0_i32);
  check permitted else trap "x must be nonnegative";
} {
  doc "A requirement check exhibits traps, so omitting traps from the function row violates EFF-2.";
  return x;
}

fn main() -> own unit pure {
  return unit;
}
