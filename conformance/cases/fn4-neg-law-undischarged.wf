contract OpaqueMonoid {
  doc "FN-4: a stated law on a fn whose body is not a single table op has no static proof; stated-but-unchecked is a hard reject, never a trusted fact.";
  fn combine(x: own u64, y: own u64) -> own u64 pure;
  law associative(combine);
}

fn twostep(x: own u64, y: own u64) -> own u64 pure {
  let t: own u64 = iadd.wrap<u64>(x, y);
  return iadd.wrap<u64>(t, 1_u64);
}

conform u64: OpaqueMonoid {
  combine = twostep;
}

fn main() -> own unit pure {
  return unit;
}
