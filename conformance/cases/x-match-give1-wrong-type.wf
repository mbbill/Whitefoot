fn main() -> own unit traps {
  doc "GIVE-1 type requirement: `give` must deliver the let's declared mode type; giving an i32 where the binder declares Bool is rejected citing TYPE-5 (the binder's type rule GIVE-1 defers to).";
  let v: own Bool = match ilt<i32>(3_i32, 4_i32) {
    True() => {
      give 1_i32;
    }
    False() => {
      give 0_i32;
    }
  }
  return unit;
}
