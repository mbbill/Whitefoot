enum Light {
  Off();
  On();
}

fn main() -> own unit traps {
  doc "enum is a composite type [TYPE-2]: construct and match a value.";
  let s: own Light = On();
  match s {
    Off() => {
      return unit;
    }
    On() => {
      check ieq<i32>(1_i32, 1_i32) else trap "unreachable";
    }
  }
  return unit;
}
