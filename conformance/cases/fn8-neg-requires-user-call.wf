fn identity(x: own i32) -> own i32 pure {
  return x;
}

fn user_call(x: own i32) -> own i32 traps requires {
  let copied: own i32 = identity(x: x);
  let permitted: own Bool = ieq<i32>(copied, x);
  check permitted else trap "identity mismatch";
} {
  doc "User-function calls are forbidden in a requirement clause even when the callee is pure [FN-8].";
  return x;
}

fn main() -> own unit pure {
  return unit;
}
