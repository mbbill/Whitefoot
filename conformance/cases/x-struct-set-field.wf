struct Counter {
  n: i32;
}

fn main() -> own unit traps {
  doc "TYPE-5: mutate a struct field with `set place.f = atom`, read it back, check the result.";
  let c: own Counter = Counter(n: 1_i32);
  set c.n = 41_i32;
  let v: own i32 = iadd.trap<i32>(c.n, 1_i32);
  check ieq<i32>(v, 42_i32) else trap "set field drift";
  return unit;
}
