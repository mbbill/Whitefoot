fn increment(x: own i32) -> own i32 traps requires {
  let value: own Bool = ige<i32>(x, 0_i32);
  check value else trap "x must be nonnegative";
} {
  doc "A requirement local's scope ends with the clause, so its name is fresh again in the body [FN-8/TYPE-6].";
  let value: own i32 = iadd.wrap<i32>(x, 1_i32);
  return value;
}

fn main() -> own unit traps {
  let value: own i32 = increment(x: 7_i32);
  check ieq<i32>(value, 8_i32) else trap "requires scope drift";
  return unit;
}
