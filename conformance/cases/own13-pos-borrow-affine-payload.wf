struct Pair {
  left: i32;
  right: i32;
}

enum Packet {
  Data(item: Pair);
  Empty();
}

fn inspect ['r](packet: &'r Packet) -> own i32 pure {
  doc "OWN-13: matching deref(packet) derives a shared Pair binder; deref(item).left reads through that provenance.";
  match deref(packet) {
    Data(item: item) => {
      return deref(item).left;
    }
    Empty() => {
      return 0_i32;
    }
  }
}
