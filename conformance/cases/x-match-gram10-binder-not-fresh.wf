fn main() -> own unit traps {
  doc "GRAM-10 freshness: a match binder that reuses a live outer name (w) is not fresh and is a hard error citing GRAM-10 [TYPE-6].";
  let w: own i32 = 7_i32;
  let v: own i32 = match iadd.checked<i32>(40_i32, 2_i32) {
    Ok(value: w) => {
      give w;
    }
    Err(error: e) => {
      give 0_i32;
    }
  }
  check ieq<i32>(v, 42_i32) else trap "x";
  return unit;
}
