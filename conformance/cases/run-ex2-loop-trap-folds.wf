fn main() -> own unit traps {
  doc "Loop, break, mutable locals, and a give value-match: sum 0..4 == 10.";
  let i: own i32 = 0_i32;
  let sum: own i32 = 0_i32;
  loop @l {
    match ige<i32>(i, 5_i32) {
      True() => {
        break @l;
      }
      False() => {
      }
    }
    set sum = iadd.trap<i32>(sum, i);
    set i = iadd.trap<i32>(i, 1_i32);
  }
  check ieq<i32>(sum, 10_i32) else trap "sum drift";
  let doubled: own i32 = match imul.checked<i32>(sum, 2_i32) {
    Ok(value: d) => {
      give d;
    }
    Err(error: e) => {
      return unit;
    }
  }
  check ieq<i32>(doubled, 20_i32) else trap "double drift";
  return unit;
}
