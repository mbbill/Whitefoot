fn takesown(n: own i32) -> own i32 pure {
  doc "Parameter n is an own i32 [FN-1].";
  return n;
}

fn main() -> own unit pure {
  doc "Caller passes a shared borrow where the signature declares an own value [FN-1].";
  let a: own i32 = 5_i32;
  region 'r {
    let b: &'r i32 = &'r a;
    let r: own i32 = takesown(n: b);
  }
  return unit;
}
