fn main() -> own unit traps {
  doc "OWN-5: reads and writes through the &uniq holder are permitted while it is live.";
  let a: own i32 = 3_i32;
  region 'r {
    let u: &uniq 'r i32 = &uniq 'r a;
    set deref(u) = 10_i32;
    check ieq<i32>(deref(u), 10_i32) else trap "rw";
  }
  check ieq<i32>(a, 10_i32) else trap "after";
  return unit;
}
