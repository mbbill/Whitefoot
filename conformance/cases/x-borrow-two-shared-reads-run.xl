fn main () -> own unit traps {
  doc "OWN-5: two shared borrows of one place coexist and are both read - shared reads never conflict.";
  let a: own i32 = 7_i32;
  region 'r {
    let s1: &'r i32 = &'r a;
    let s2: &'r i32 = &'r a;
    check ieq<i32>(deref(s1), deref(s2)) else trap "eq";
  }
  return unit;
}
