struct Point {
  x: i32;
  y: i32;
}

fn main() -> own unit traps {
  doc "TYPE-2/GRAM-8: construct a struct, read its fields, use them in arithmetic, check the sum.";
  let p: own Point = Point(x: 3_i32, y: 4_i32);
  let s: own i32 = iadd.trap<i32>(p.x, p.y);
  check ieq<i32>(s, 7_i32) else trap "field arithmetic drift";
  return unit;
}
