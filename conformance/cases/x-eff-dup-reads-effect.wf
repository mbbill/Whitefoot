fn f(x: own i32) -> own i32 reads('r), reads('s) {
  doc "Two separate reads effects duplicate the reads kind [EFF-1]; canonical is reads('r 's).";
  return x;
}

fn main() -> own unit traps {
  doc "Driver.";
  let a: own i32 = f(x: 7_i32);
  check ieq<i32>(a, 7_i32) else trap "x";
  return unit;
}
