enum Packet {
  Data(value: i32);
}

fn inspect ['r](holder: &'r Packet) -> own unit pure {
  doc "OWN-1: move deref(holder) cannot steal a borrowed enum; bare match deref(holder) derives borrowed payload binders.";
  match move deref(holder) {
    Data(value: value) => {
      let saved: own i32 = deref(value);
    }
  }
  return unit;
}
