fn main() -> own unit traps {
  doc "Writing through a &uniq borrow via set deref(p) and reading the value back [TYPE-7].";
  let a: own i32 = 40_i32;
  region 'r {
    let p: &uniq 'r i32 = &uniq 'r a;
    set deref(p) = 42_i32;
  }
  check ieq<i32>(a, 42_i32) else trap "uniq write lost";
  return unit;
}
