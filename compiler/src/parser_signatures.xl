      }
      False() => {
        region 'effect_region_error {
          let parse_expected_region_atom_0122: own ParseStatus = ParseExpectedRegion();
          parser_fail(tokens: tokens, out: &uniq 'effect_region_error deref(out), status: parse_expected_region_atom_0122, token: region_cursor);
        }
        return ParserNodeResult(node: ast_none, next: region_cursor);
      }
    }
    let region_node: own u64 = ast_none;
    region 'effect_region_alloc {
      let ast_region_atom_0123: own AstKind = AstRegion();
      set region_node = parser_push_token(tokens: tokens, out: &uniq 'effect_region_alloc deref(out), kind: ast_region_atom_0123, token: region_cursor);
    }
    match ieq<u64>(region_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: region_cursor);
      }
      False() => {
      }
    }
    region 'effect_region_attach {
      parser_append_child(out: &uniq 'effect_region_attach deref(out), parent: effect_node, child: region_node);
    }
    set have_region = True();
    set region_cursor = iadd.trap<u64>(region_cursor, 1_u64);
  }
}

fn parser_parse_allocates_effect ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let effect_node: own u64 = ast_none;
  region 'allocates_effect_alloc {
    let ast_allocates_effect_atom_0124: own AstKind = AstAllocatesEffect();
    set effect_node = parser_push_token(tokens: tokens, out: &uniq 'allocates_effect_alloc deref(out), kind: ast_allocates_effect_atom_0124, token: cursor);
  }
  match ieq<u64>(effect_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: cursor);
    }
    False() => {
    }
  }

  let left_paren_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  let left_paren: own Bool = parser_symbol_is(source: source, tokens: tokens, token: left_paren_cursor, want: 40_u8);
  match left_paren {
    True() => {
    }
    False() => {
      region 'allocates_left_paren_error {
        let parse_expected_left_paren_atom_0125: own ParseStatus = ParseExpectedLeftParen();
        parser_fail(tokens: tokens, out: &uniq 'allocates_left_paren_error deref(out), status: parse_expected_left_paren_atom_0125, token: left_paren_cursor);
      }
      return ParserNodeResult(node: ast_none, next: left_paren_cursor);
    }
  }

  let storage_cursor: own u64 = iadd.trap<u64>(left_paren_cursor, 1_u64);
  let have_storage: own Bool = False();
  loop @allocation_storages {
    let right_paren: own Bool = parser_symbol_is(source: source, tokens: tokens, token: storage_cursor, want: 41_u8);
    match right_paren {
      True() => {
        match have_storage {
          True() => {
            let effect_end: own u64 = index<u64>(deref(tokens).ends, storage_cursor);
            set index<u64>(deref(out).ends, effect_node) = effect_end;
            let after_effect: own u64 = iadd.trap<u64>(storage_cursor, 1_u64);
            return ParserNodeResult(node: effect_node, next: after_effect);
          }
          False() => {
            region 'allocates_empty_error {
              let parse_expected_storage_atom_0126: own ParseStatus = ParseExpectedStorage();
              parser_fail(tokens: tokens, out: &uniq 'allocates_empty_error deref(out), status: parse_expected_storage_atom_0126, token: storage_cursor);
            }
            return ParserNodeResult(node: ast_none, next: storage_cursor);
          }
        }
      }
      False() => {
      }
    }

    let heap_word: own Bool = parser_word4(source: source, tokens: tokens, token: storage_cursor, a: 104_u8, b: 101_u8, c: 97_u8, d: 112_u8);
    match heap_word {
      True() => {
        let heap_node: own u64 = ast_none;
        region 'allocation_heap_alloc {
          let ast_heap_storage_atom_0127: own AstKind = AstHeapStorage();
          set heap_node = parser_push_token(tokens: tokens, out: &uniq 'allocation_heap_alloc deref(out), kind: ast_heap_storage_atom_0127, token: storage_cursor);
        }
        match ieq<u64>(heap_node, ast_none) {
          True() => {
            return ParserNodeResult(node: ast_none, next: storage_cursor);
          }
          False() => {
          }
        }
        region 'allocation_heap_attach {
          parser_append_child(out: &uniq 'allocation_heap_attach deref(out), parent: effect_node, child: heap_node);
        }
        set have_storage = True();
        set storage_cursor = iadd.trap<u64>(storage_cursor, 1_u64);
      }
      False() => {
        let arena_word: own Bool = parser_word5(source: source, tokens: tokens, token: storage_cursor, a: 97_u8, b: 114_u8, c: 101_u8, d: 110_u8, e: 97_u8);
        match arena_word {
          True() => {
            let arena_node: own u64 = ast_none;
            region 'allocation_arena_alloc {
              let ast_arena_storage_atom_0128: own AstKind = AstArenaStorage();
              set arena_node = parser_push_token(tokens: tokens, out: &uniq 'allocation_arena_alloc deref(out), kind: ast_arena_storage_atom_0128, token: storage_cursor);
            }
            match ieq<u64>(arena_node, ast_none) {
              True() => {
                return ParserNodeResult(node: ast_none, next: storage_cursor);
              }
              False() => {
              }
            }
            let arena_region_cursor: own u64 = iadd.trap<u64>(storage_cursor, 1_u64);
            let arena_region_ok: own Bool = parser_kind_at_is(tokens: tokens, token: arena_region_cursor, want: 4_u64);
            match arena_region_ok {
              True() => {
              }
              False() => {
                region 'allocation_arena_region_error {
                  let parse_expected_region_atom_0129: own ParseStatus = ParseExpectedRegion();
                  parser_fail(tokens: tokens, out: &uniq 'allocation_arena_region_error deref(out), status: parse_expected_region_atom_0129, token: arena_region_cursor);
                }
                return ParserNodeResult(node: ast_none, next: arena_region_cursor);
              }
            }
            let arena_region_node: own u64 = ast_none;
            region 'allocation_arena_region_alloc {
              let ast_region_atom_0130: own AstKind = AstRegion();
              set arena_region_node = parser_push_token(tokens: tokens, out: &uniq 'allocation_arena_region_alloc deref(out), kind: ast_region_atom_0130, token: arena_region_cursor);
            }
            match ieq<u64>(arena_region_node, ast_none) {
              True() => {
                return ParserNodeResult(node: ast_none, next: arena_region_cursor);
              }
              False() => {
              }
            }
            region 'allocation_arena_region_attach {
              parser_append_child(out: &uniq 'allocation_arena_region_attach deref(out), parent: arena_node, child: arena_region_node);
            }
            let arena_end: own u64 = index<u64>(deref(tokens).ends, arena_region_cursor);
            set index<u64>(deref(out).ends, arena_node) = arena_end;
            region 'allocation_arena_attach {
              parser_append_child(out: &uniq 'allocation_arena_attach deref(out), parent: effect_node, child: arena_node);
            }
            set have_storage = True();
            set storage_cursor = iadd.trap<u64>(arena_region_cursor, 1_u64);
          }
          False() => {
            region 'allocation_storage_error {
              let parse_expected_storage_atom_0131: own ParseStatus = ParseExpectedStorage();
              parser_fail(tokens: tokens, out: &uniq 'allocation_storage_error deref(out), status: parse_expected_storage_atom_0131, token: storage_cursor);
            }
            return ParserNodeResult(node: ast_none, next: storage_cursor);
          }
        }
      }
    }
  }
}

fn parser_parse_effect_row ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, parent: own u64, cursor: own u64) -> own u64 reads('s 't 'a), writes('a), traps {
  let pure_effect: own Bool = parser_word4(source: source, tokens: tokens, token: cursor, a: 112_u8, b: 117_u8, c: 114_u8, d: 101_u8);
  match pure_effect {
    True() => {
      let pure_node: own u64 = ast_none;
      region 'signature_pure_alloc {
        let ast_pure_effect_atom_0132: own AstKind = AstPureEffect();
        set pure_node = parser_push_token(tokens: tokens, out: &uniq 'signature_pure_alloc deref(out), kind: ast_pure_effect_atom_0132, token: cursor);
      }
      match ieq<u64>(pure_node, ast_none) {
        True() => {
          return ast_none;
        }
        False() => {
        }
      }
      region 'signature_pure_attach {
        parser_append_child(out: &uniq 'signature_pure_attach deref(out), parent: parent, child: pure_node);
      }
      let after_pure: own u64 = iadd.trap<u64>(cursor, 1_u64);
      let pure_comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_pure, want: 44_u8);
      match pure_comma {
        True() => {
          let after_pure_comma: own u64 = iadd.trap<u64>(after_pure, 1_u64);
          region 'pure_comma_error {
            let parse_expected_effect_atom_0133: own ParseStatus = ParseExpectedEffect();
            parser_fail(tokens: tokens, out: &uniq 'pure_comma_error deref(out), status: parse_expected_effect_atom_0133, token: after_pure_comma);
          }
          return ast_none;
        }
        False() => {
          return after_pure;
        }
      }
    }
    False() => {
    }
  }
  let effect_cursor: own u64 = cursor;
  let effect_stage: own u64 = 0_u64;
  loop @effects {
    let reads_word: own Bool = parser_word5(source: source, tokens: tokens, token: effect_cursor, a: 114_u8, b: 101_u8, c: 97_u8, d: 100_u8, e: 115_u8);
    let writes_word: own Bool = parser_word6(source: source, tokens: tokens, token: effect_cursor, a: 119_u8, b: 114_u8, c: 105_u8, d: 116_u8, e: 101_u8, f: 115_u8);
    let allocates_word: own Bool = parser_signature_allocates_word(source: source, tokens: tokens, token: effect_cursor);
    let traps_word: own Bool = parser_word5(source: source, tokens: tokens, token: effect_cursor, a: 116_u8, b: 114_u8, c: 97_u8, d: 112_u8, e: 115_u8);
    let reads_stage: own Bool = ieq<u64>(effect_stage, 0_u64);
    let writes_stage: own Bool = ile<u64>(effect_stage, 1_u64);
    let allocates_stage: own Bool = ile<u64>(effect_stage, 2_u64);
    let traps_stage: own Bool = ile<u64>(effect_stage, 3_u64);
    let reads_allowed: own Bool = band<Bool>(reads_word, reads_stage);
    let writes_allowed: own Bool = band<Bool>(writes_word, writes_stage);
    let allocates_allowed: own Bool = band<Bool>(allocates_word, allocates_stage);
    let traps_allowed: own Bool = band<Bool>(traps_word, traps_stage);
    let parsed_effect_node: own u64 = ast_none;
    let parsed_effect_next: own u64 = effect_cursor;
    match reads_allowed {
      True() => {
        region 'reads_effect_parse {
          let ast_reads_effect_atom_0134: own AstKind = AstReadsEffect();
          let reads_result: own ParserNodeResult = parser_parse_region_effect(source: source, tokens: tokens, out: &uniq 'reads_effect_parse deref(out), cursor: effect_cursor, kind: ast_reads_effect_atom_0134);
          set parsed_effect_node = reads_result.node;
          set parsed_effect_next = reads_result.next;
        }
        set effect_stage = 1_u64;
      }
      False() => {
        match writes_allowed {
          True() => {
            region 'writes_effect_parse {
              let ast_writes_effect_atom_0135: own AstKind = AstWritesEffect();
              let writes_result: own ParserNodeResult = parser_parse_region_effect(source: source, tokens: tokens, out: &uniq 'writes_effect_parse deref(out), cursor: effect_cursor, kind: ast_writes_effect_atom_0135);
              set parsed_effect_node = writes_result.node;
              set parsed_effect_next = writes_result.next;
            }
            set effect_stage = 2_u64;
          }
          False() => {
            match allocates_allowed {
              True() => {
                region 'allocates_effect_parse {
                  let allocates_result: own ParserNodeResult = parser_parse_allocates_effect(source: source, tokens: tokens, out: &uniq 'allocates_effect_parse deref(out), cursor: effect_cursor);
                  set parsed_effect_node = allocates_result.node;
                  set parsed_effect_next = allocates_result.next;
                }
                set effect_stage = 3_u64;
              }
              False() => {
                match traps_allowed {
                  True() => {
                    region 'traps_effect_alloc {
                      let ast_traps_effect_atom_0136: own AstKind = AstTrapsEffect();
                      set parsed_effect_node = parser_push_token(tokens: tokens, out: &uniq 'traps_effect_alloc deref(out), kind: ast_traps_effect_atom_0136, token: effect_cursor);
                    }
                    set parsed_effect_next = iadd.trap<u64>(effect_cursor, 1_u64);
                    set effect_stage = 4_u64;
                  }
                  False() => {
                    region 'effect_row_error {
                      let parse_expected_effect_atom_0137: own ParseStatus = ParseExpectedEffect();
                      parser_fail(tokens: tokens, out: &uniq 'effect_row_error deref(out), status: parse_expected_effect_atom_0137, token: effect_cursor);
                    }
                    return ast_none;
                  }
                }
              }
            }
          }
        }
      }
    }
    match ieq<u64>(parsed_effect_node, ast_none) {
      True() => {
        return ast_none;
      }
      False() => {
      }
    }
    region 'effect_attach {
      parser_append_child(out: &uniq 'effect_attach deref(out), parent: parent, child: parsed_effect_node);
    }
    set effect_cursor = parsed_effect_next;
    let comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: effect_cursor, want: 44_u8);
    match comma {
      True() => {
        set effect_cursor = iadd.trap<u64>(effect_cursor, 1_u64);
      }
      False() => {
        return effect_cursor;
      }
    }
  }
}
