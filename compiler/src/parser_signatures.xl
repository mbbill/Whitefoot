  let end: own u64 = index<u64>(deref(tokens).ends, token);
  let cursor: own u64 = start;
  loop @const_digits {
    let done: own Bool = ige<u64>(cursor, end);
    match done {
      True() => {
        return igt<u64>(end, start);
      }
      False() => {
      }
    }
    let byte: own u8 = index<u8>(deref(source), cursor);
    let digit: own Bool = lexer_is_digit(c: byte);
    match digit {
      True() => {
        set cursor = iadd.trap<u64>(cursor, 1_u64);
      }
      False() => {
        return False();
      }
    }
  }
}

