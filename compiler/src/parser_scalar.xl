    let ast_type_argument_atom_0063: own AstKind = AstTypeArgument();
    let parsed_type: own ParserNodeResult = parser_parse_signature_type(source: source, tokens: tokens, out: &uniq 'table_type_parse deref(out), cursor: type_cursor, kind: ast_type_argument_atom_0063);
    set parsed_type_node = parsed_type.node;
    set parsed_type_next = parsed_type.next;
  }
  match ieq<u64>(parsed_type_node, ast_none) {
