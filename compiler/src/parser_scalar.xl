  match table_callee {
    True() => {
      region 'table_parse {
        return parser_parse_table_call(source: source, tokens: tokens, out: &uniq 'table_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  let word_callee: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 1_u64);
  match word_callee {
    True() => {
      let after_word: own u64 = iadd.trap<u64>(cursor, 1_u64);
      let call_shape: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_word, want: 40_u8);
      match call_shape {
        True() => {
          region 'user_parse {
            return parser_parse_user_call(source: source, tokens: tokens, out: &uniq 'user_parse deref(out), cursor: cursor);
          }
        }
        False() => {
        }
      }
    }
    False() => {
    }
  }
  let number_start: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 6_u64);
  let atom_start: own Bool = bor<Bool>(word_callee, number_start);
  match atom_start {
    True() => {
      region 'expression_atom_parse {
        return parser_parse_atom(source: source, tokens: tokens, out: &uniq 'expression_atom_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  region 'expression_error {
    let parse_expected_expression_atom_0075: own ParseStatus = ParseExpectedExpression();
    parser_fail(tokens: tokens, out: &uniq 'expression_error deref(out), status: parse_expected_expression_atom_0075, token: cursor);
  }
  return ParserNodeResult(node: ast_none, next: cursor);
}

