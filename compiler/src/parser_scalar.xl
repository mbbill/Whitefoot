    }
    let parsed_argument_node: own u64 = ast_none;
    let parsed_argument_next: own u64 = argument_cursor;
    region 'table_argument_parse {
      let parsed_argument: own ParserNodeResult = parser_parse_atom(source: source, tokens: tokens, out: &uniq 'table_argument_parse deref(out), cursor: argument_cursor);
