  let type_cursor: own u64 = iadd.trap<u64>(colon_cursor, 1_u64);
  let type_node: own u64 = ast_none;
  let after_type: own u64 = type_cursor;
  region 'const_type_parse {
    let ast_const_type_atom_0170: own AstKind = AstConstType();
    let parsed_type: own ParserNodeResult = parser_parse_signature_type(source: source, tokens: tokens, out: &uniq 'const_type_parse deref(out), cursor: type_cursor, kind: ast_const_type_atom_0170);
    set type_node = parsed_type.node;
    set after_type = parsed_type.next;
  }
  match ieq<u64>(type_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: after_type);
    }
    False() => {
    }
  }
  region 'const_type_attach {
    parser_append_child(out: &uniq 'const_type_attach deref(out), parent: item_node, child: type_node);
  }
  let equals: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_type, want: 61_u8);
  match equals {
    True() => {
    }
    False() => {
      region 'const_equals_error {
        let parse_expected_equals_atom_0171: own ParseStatus = ParseExpectedEquals();
        parser_fail(tokens: tokens, out: &uniq 'const_equals_error deref(out), status: parse_expected_equals_atom_0171, token: after_type);
      }
      return ParserNodeResult(node: ast_none, next: after_type);
    }
  }
  let value_cursor: own u64 = iadd.trap<u64>(after_type, 1_u64);
  let value_node: own u64 = ast_none;
  let after_value: own u64 = value_cursor;
  region 'const_value_parse {
    let parsed_value: own ParserNodeResult = parser_parse_const_value(source: source, tokens: tokens, out: &uniq 'const_value_parse deref(out), cursor: value_cursor);
    set value_node = parsed_value.node;
    set after_value = parsed_value.next;
  }
  match ieq<u64>(value_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: after_value);
    }
    False() => {
    }
  }
  region 'const_value_attach {
    parser_append_child(out: &uniq 'const_value_attach deref(out), parent: item_node, child: value_node);
  }
  let semicolon: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_value, want: 59_u8);
  match semicolon {
    True() => {
    }
    False() => {
      region 'const_semicolon_error {
        let parse_expected_semicolon_atom_0172: own ParseStatus = ParseExpectedSemicolon();
        parser_fail(tokens: tokens, out: &uniq 'const_semicolon_error deref(out), status: parse_expected_semicolon_atom_0172, token: after_value);
      }
      return ParserNodeResult(node: ast_none, next: after_value);
    }
  }
  let item_end: own u64 = index<u64>(deref(tokens).ends, after_value);
  set index<u64>(deref(out).ends, item_node) = item_end;
  let after_item: own u64 = iadd.trap<u64>(after_value, 1_u64);
  return ParserNodeResult(node: item_node, next: after_item);
}

fn parser_parse_top_level_item ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let function_item: own Bool = parser_word2(source: source, tokens: tokens, token: cursor, a: 102_u8, b: 110_u8);
  match function_item {
    True() => {
      region 'top_function_parse {
        return parser_parse_function(source: source, tokens: tokens, out: &uniq 'top_function_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  let enum_item: own Bool = parser_word4(source: source, tokens: tokens, token: cursor, a: 101_u8, b: 110_u8, c: 117_u8, d: 109_u8);
  match enum_item {
    True() => {
      region 'top_enum_parse {
        return parser_parse_enum_item(source: source, tokens: tokens, out: &uniq 'top_enum_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  let struct_item: own Bool = parser_word6(source: source, tokens: tokens, token: cursor, a: 115_u8, b: 116_u8, c: 114_u8, d: 117_u8, e: 99_u8, f: 116_u8);
  match struct_item {
    True() => {
      region 'top_struct_parse {
        return parser_parse_struct_item(source: source, tokens: tokens, out: &uniq 'top_struct_parse deref(out), cursor: cursor);
      }
    }
    False() => {
    }
  }
  region 'top_const_parse {
    return parser_parse_const_item(source: source, tokens: tokens, out: &uniq 'top_const_parse deref(out), cursor: cursor);
  }
}
