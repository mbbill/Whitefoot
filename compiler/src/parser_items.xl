fn parser_parse_const_value ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let number: own Bool = parser_kind_at_is(tokens: tokens, token: cursor, want: 6_u64);
  match number {
    True() => {
      let number_node: own u64 = ast_none;
      region 'const_number_alloc {
        let ast_numeric_literal_atom_0158: own AstKind = AstNumericLiteral();
        set number_node = parser_push_token(tokens: tokens, out: &uniq 'const_number_alloc deref(out), kind: ast_numeric_literal_atom_0158, token: cursor);
      }
      let after_number: own u64 = iadd.trap<u64>(cursor, 1_u64);
      return ParserNodeResult(node: number_node, next: after_number);
    }
    False() => {
    }
  }

  let left_square: own Bool = parser_symbol_is(source: source, tokens: tokens, token: cursor, want: 91_u8);
  match left_square {
    True() => {
    }
    False() => {
      region 'const_value_error {
        let parse_expected_const_value_atom_0159: own ParseStatus = ParseExpectedConstValue();
        parser_fail(tokens: tokens, out: &uniq 'const_value_error deref(out), status: parse_expected_const_value_atom_0159, token: cursor);
      }
      return ParserNodeResult(node: ast_none, next: cursor);
    }
  }
  let array_node: own u64 = ast_none;
  region 'const_array_alloc {
    let ast_const_array_value_atom_0160: own AstKind = AstConstArrayValue();
    set array_node = parser_push_token(tokens: tokens, out: &uniq 'const_array_alloc deref(out), kind: ast_const_array_value_atom_0160, token: cursor);
  }
  match ieq<u64>(array_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: cursor);
    }
    False() => {
    }
  }
  let value_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  let immediate_close: own Bool = parser_symbol_is(source: source, tokens: tokens, token: value_cursor, want: 93_u8);
  match immediate_close {
    True() => {
      region 'const_empty_array_error {
        let parse_expected_const_value_atom_0161: own ParseStatus = ParseExpectedConstValue();
        parser_fail(tokens: tokens, out: &uniq 'const_empty_array_error deref(out), status: parse_expected_const_value_atom_0161, token: value_cursor);
      }
      return ParserNodeResult(node: ast_none, next: value_cursor);
    }
    False() => {
    }
  }
  loop @const_array_values {
    let element_ok: own Bool = parser_kind_at_is(tokens: tokens, token: value_cursor, want: 6_u64);
    match element_ok {
      True() => {
      }
      False() => {
        region 'const_element_error {
          let parse_expected_const_value_atom_0162: own ParseStatus = ParseExpectedConstValue();
          parser_fail(tokens: tokens, out: &uniq 'const_element_error deref(out), status: parse_expected_const_value_atom_0162, token: value_cursor);
        }
        return ParserNodeResult(node: ast_none, next: value_cursor);
      }
    }
    let element_node: own u64 = ast_none;
    region 'const_element_alloc {
      let ast_numeric_literal_atom_0163: own AstKind = AstNumericLiteral();
      set element_node = parser_push_token(tokens: tokens, out: &uniq 'const_element_alloc deref(out), kind: ast_numeric_literal_atom_0163, token: value_cursor);
    }
    match ieq<u64>(element_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: value_cursor);
      }
      False() => {
      }
    }
    region 'const_element_attach {
      parser_append_child(out: &uniq 'const_element_attach deref(out), parent: array_node, child: element_node);
    }
    set value_cursor = iadd.trap<u64>(value_cursor, 1_u64);
    let comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: value_cursor, want: 44_u8);
    match comma {
      True() => {
        let after_comma: own u64 = iadd.trap<u64>(value_cursor, 1_u64);
        let trailing_comma: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_comma, want: 93_u8);
        match trailing_comma {
          True() => {
            region 'const_trailing_comma_error {
              let parse_expected_const_value_atom_0164: own ParseStatus = ParseExpectedConstValue();
              parser_fail(tokens: tokens, out: &uniq 'const_trailing_comma_error deref(out), status: parse_expected_const_value_atom_0164, token: after_comma);
            }
            return ParserNodeResult(node: ast_none, next: after_comma);
          }
          False() => {
          }
        }
        set value_cursor = after_comma;
      }
      False() => {
        let right_square: own Bool = parser_symbol_is(source: source, tokens: tokens, token: value_cursor, want: 93_u8);
        match right_square {
          True() => {
            let array_end: own u64 = index<u64>(deref(tokens).ends, value_cursor);
            set index<u64>(deref(out).ends, array_node) = array_end;
            let after_array: own u64 = iadd.trap<u64>(value_cursor, 1_u64);
            return ParserNodeResult(node: array_node, next: after_array);
          }
          False() => {
            region 'const_array_separator_error {
              let parse_expected_comma_or_right_square_atom_0165: own ParseStatus = ParseExpectedCommaOrRightSquare();
              parser_fail(tokens: tokens, out: &uniq 'const_array_separator_error deref(out), status: parse_expected_comma_or_right_square_atom_0165, token: value_cursor);
            }
            return ParserNodeResult(node: ast_none, next: value_cursor);
          }
        }
      }
    }
  }
}

