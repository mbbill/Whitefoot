    }
    region 'field_type_attach {
      parser_append_child(out: &uniq 'field_type_attach deref(out), parent: field_node, child: type_node);
    }
    let semicolon: own Bool = parser_symbol_is(source: source, tokens: tokens, token: after_type, want: 59_u8);
    match semicolon {
      True() => {
