  let field_cursor: own u64 = iadd.trap<u64>(left_brace_cursor, 1_u64);
  loop @struct_fields {
    let right_brace: own Bool = parser_symbol_is(source: source, tokens: tokens, token: field_cursor, want: 125_u8);
    match right_brace {
      True() => {
        let item_end: own u64 = index<u64>(deref(tokens).ends, field_cursor);
        set index<u64>(deref(out).ends, item_node) = item_end;
        let after_item: own u64 = iadd.trap<u64>(field_cursor, 1_u64);
        return ParserNodeResult(node: item_node, next: after_item);
      }
      False() => {
      }
    }
    let hit_eof: own Bool = parser_kind_at_is(tokens: tokens, token: field_cursor, want: 0_u64);
    match hit_eof {
      True() => {
        region 'struct_right_brace_error {
          let parse_expected_right_brace_atom_0152: own ParseStatus = ParseExpectedRightBrace();
          parser_fail(tokens: tokens, out: &uniq 'struct_right_brace_error deref(out), status: parse_expected_right_brace_atom_0152, token: field_cursor);
        }
        return ParserNodeResult(node: ast_none, next: field_cursor);
