      False() => {
        region 'struct_field_error {
          let parse_expected_name_atom_0153: own ParseStatus = ParseExpectedName();
          parser_fail(tokens: tokens, out: &uniq 'struct_field_error deref(out), status: parse_expected_name_atom_0153, token: field_cursor);
        }
        return ParserNodeResult(node: ast_none, next: field_cursor);
      }
    }
    let field_node: own u64 = ast_none;
    region 'struct_field_alloc {
      let ast_field_atom_0154: own AstKind = AstField();
      set field_node = parser_push_token(tokens: tokens, out: &uniq 'struct_field_alloc deref(out), kind: ast_field_atom_0154, token: field_cursor);
