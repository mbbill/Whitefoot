        }
        return ParserNodeResult(node: ast_none, next: after_type);
      }
    }
    let field_end: own u64 = index<u64>(deref(tokens).ends, after_type);
    set index<u64>(deref(out).ends, field_node) = field_end;
    region 'struct_field_attach {
      parser_append_child(out: &uniq 'struct_field_attach deref(out), parent: item_node, child: field_node);
    }
    set field_cursor = iadd.trap<u64>(after_type, 1_u64);
