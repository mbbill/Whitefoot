fn parser_is_top_level_item ['s, 't] (source: &'s buffer<u8>, tokens: &'t TokenTape, cursor: own u64) -> own Bool reads('s 't), traps {
  let function_item: own Bool = parser_word2(source: source, tokens: tokens, token: cursor, a: 102_u8, b: 110_u8);
  match function_item {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let enum_item: own Bool = parser_word4(source: source, tokens: tokens, token: cursor, a: 101_u8, b: 110_u8, c: 117_u8, d: 109_u8);
  match enum_item {
    True() => {
      return True();
    }
    False() => {
    }
  }
  let struct_item: own Bool = parser_word6(source: source, tokens: tokens, token: cursor, a: 115_u8, b: 116_u8, c: 114_u8, d: 117_u8, e: 99_u8, f: 116_u8);
  match struct_item {
    True() => {
      return True();
    }
    False() => {
    }
  }
  return parser_word5(source: source, tokens: tokens, token: cursor, a: 99_u8, b: 111_u8, c: 110_u8, d: 115_u8, e: 116_u8);
}

fn parser_parse_enum_item ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
  let item_node: own u64 = ast_none;
  region 'enum_item_alloc {
    let ast_enum_decl_atom_0138: own AstKind = AstEnumDecl();
    set item_node = parser_push_token(tokens: tokens, out: &uniq 'enum_item_alloc deref(out), kind: ast_enum_decl_atom_0138, token: cursor);
  }
  match ieq<u64>(item_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: cursor);
    }
    False() => {
    }
  }

  let name_cursor: own u64 = iadd.trap<u64>(cursor, 1_u64);
  let name_ok: own Bool = parser_kind_at_is(tokens: tokens, token: name_cursor, want: 3_u64);
  match name_ok {
    True() => {
    }
    False() => {
      region 'enum_name_error {
        let parse_expected_type_name_atom_0139: own ParseStatus = ParseExpectedTypeName();
        parser_fail(tokens: tokens, out: &uniq 'enum_name_error deref(out), status: parse_expected_type_name_atom_0139, token: name_cursor);
      }
      return ParserNodeResult(node: ast_none, next: name_cursor);
    }
  }
  let name_node: own u64 = ast_none;
  region 'enum_name_alloc {
    let ast_enum_name_atom_0140: own AstKind = AstEnumName();
    set name_node = parser_push_token(tokens: tokens, out: &uniq 'enum_name_alloc deref(out), kind: ast_enum_name_atom_0140, token: name_cursor);
  }
  match ieq<u64>(name_node, ast_none) {
    True() => {
      return ParserNodeResult(node: ast_none, next: name_cursor);
    }
    False() => {
    }
  }
  region 'enum_name_attach {
    parser_append_child(out: &uniq 'enum_name_attach deref(out), parent: item_node, child: name_node);
  }

  let left_brace_cursor: own u64 = iadd.trap<u64>(name_cursor, 1_u64);
  let left_brace: own Bool = parser_symbol_is(source: source, tokens: tokens, token: left_brace_cursor, want: 123_u8);
  match left_brace {
    True() => {
    }
    False() => {
      region 'enum_left_brace_error {
        let parse_expected_left_brace_atom_0141: own ParseStatus = ParseExpectedLeftBrace();
        parser_fail(tokens: tokens, out: &uniq 'enum_left_brace_error deref(out), status: parse_expected_left_brace_atom_0141, token: left_brace_cursor);
      }
      return ParserNodeResult(node: ast_none, next: left_brace_cursor);
    }
  }

  let variant_cursor: own u64 = iadd.trap<u64>(left_brace_cursor, 1_u64);
  loop @enum_variants {
    let right_brace: own Bool = parser_symbol_is(source: source, tokens: tokens, token: variant_cursor, want: 125_u8);
    match right_brace {
      True() => {
        let item_end: own u64 = index<u64>(deref(tokens).ends, variant_cursor);
        set index<u64>(deref(out).ends, item_node) = item_end;
        let after_item: own u64 = iadd.trap<u64>(variant_cursor, 1_u64);
        return ParserNodeResult(node: item_node, next: after_item);
      }
      False() => {
      }
    }
    let hit_eof: own Bool = parser_kind_at_is(tokens: tokens, token: variant_cursor, want: 0_u64);
    match hit_eof {
      True() => {
        region 'enum_right_brace_error {
          let parse_expected_right_brace_atom_0142: own ParseStatus = ParseExpectedRightBrace();
          parser_fail(tokens: tokens, out: &uniq 'enum_right_brace_error deref(out), status: parse_expected_right_brace_atom_0142, token: variant_cursor);
        }
        return ParserNodeResult(node: ast_none, next: variant_cursor);
      }
      False() => {
      }
    }
    let variant_ok: own Bool = parser_kind_at_is(tokens: tokens, token: variant_cursor, want: 3_u64);
    match variant_ok {
      True() => {
      }
      False() => {
        region 'enum_variant_error {
          let parse_expected_type_name_atom_0143: own ParseStatus = ParseExpectedTypeName();
          parser_fail(tokens: tokens, out: &uniq 'enum_variant_error deref(out), status: parse_expected_type_name_atom_0143, token: variant_cursor);
        }
        return ParserNodeResult(node: ast_none, next: variant_cursor);
      }
    }
    let variant_node: own u64 = ast_none;
    region 'enum_variant_alloc {
      let ast_variant_atom_0144: own AstKind = AstVariant();
      set variant_node = parser_push_token(tokens: tokens, out: &uniq 'enum_variant_alloc deref(out), kind: ast_variant_atom_0144, token: variant_cursor);
    }
    match ieq<u64>(variant_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: variant_cursor);
      }
      False() => {
      }
    }
    let left_paren_cursor: own u64 = iadd.trap<u64>(variant_cursor, 1_u64);
    let left_paren: own Bool = parser_symbol_is(source: source, tokens: tokens, token: left_paren_cursor, want: 40_u8);
    match left_paren {
      True() => {
      }
      False() => {
        region 'variant_left_paren_error {
          let parse_expected_left_paren_atom_0145: own ParseStatus = ParseExpectedLeftParen();
          parser_fail(tokens: tokens, out: &uniq 'variant_left_paren_error deref(out), status: parse_expected_left_paren_atom_0145, token: left_paren_cursor);
        }
        return ParserNodeResult(node: ast_none, next: left_paren_cursor);
      }
    }
    let right_paren_cursor: own u64 = iadd.trap<u64>(left_paren_cursor, 1_u64);
    let right_paren: own Bool = parser_symbol_is(source: source, tokens: tokens, token: right_paren_cursor, want: 41_u8);
    match right_paren {
      True() => {
      }
      False() => {
        region 'variant_right_paren_error {
          let parse_expected_right_paren_atom_0146: own ParseStatus = ParseExpectedRightParen();
          parser_fail(tokens: tokens, out: &uniq 'variant_right_paren_error deref(out), status: parse_expected_right_paren_atom_0146, token: right_paren_cursor);
        }
        return ParserNodeResult(node: ast_none, next: right_paren_cursor);
      }
    }
    let semicolon_cursor: own u64 = iadd.trap<u64>(right_paren_cursor, 1_u64);
    let semicolon: own Bool = parser_symbol_is(source: source, tokens: tokens, token: semicolon_cursor, want: 59_u8);
    match semicolon {
      True() => {
      }
      False() => {
        region 'variant_semicolon_error {
          let parse_expected_semicolon_atom_0147: own ParseStatus = ParseExpectedSemicolon();
          parser_fail(tokens: tokens, out: &uniq 'variant_semicolon_error deref(out), status: parse_expected_semicolon_atom_0147, token: semicolon_cursor);
        }
        return ParserNodeResult(node: ast_none, next: semicolon_cursor);
      }
    }
    let variant_end: own u64 = index<u64>(deref(tokens).ends, semicolon_cursor);
    set index<u64>(deref(out).ends, variant_node) = variant_end;
    region 'enum_variant_attach {
      parser_append_child(out: &uniq 'enum_variant_attach deref(out), parent: item_node, child: variant_node);
    }
    set variant_cursor = iadd.trap<u64>(semicolon_cursor, 1_u64);
  }
}

fn parser_parse_struct_item ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, out: &uniq 'a AstTape, cursor: own u64) -> own ParserNodeResult reads('s 't 'a), writes('a), traps {
