        return ParserNodeResult(node: ast_none, next: colon_cursor);
      }
    }
    let type_cursor: own u64 = iadd.trap<u64>(colon_cursor, 1_u64);
    let type_node: own u64 = ast_none;
    let after_type: own u64 = type_cursor;
    region 'field_type_parse {
      let ast_field_type_atom_0156: own AstKind = AstFieldType();
      let parsed_type: own ParserNodeResult = parser_parse_signature_type(source: source, tokens: tokens, out: &uniq 'field_type_parse deref(out), cursor: type_cursor, kind: ast_field_type_atom_0156);
      set type_node = parsed_type.node;
      set after_type = parsed_type.next;
    }
    match ieq<u64>(type_node, ast_none) {
      True() => {
        return ParserNodeResult(node: ast_none, next: after_type);
      }
      False() => {
