    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
    }
  }
  let body_breaks: own Bool = semantic_reader_flow_has_break(flow: body_flow);
  match body_breaks {
    True() => {
      let body_returns: own Bool = semantic_reader_flow_has_return(flow: body_flow);
      match body_returns {
        True() => {
          return SemanticReaderFlowFallsOrReturns();
        }
        False() => {
          return SemanticReaderFlowFalls();
        }
      }
    }
    False() => {
      let body_returns: own Bool = semantic_reader_flow_has_return(flow: body_flow);
      match body_returns {
        True() => {
          return SemanticReaderFlowReturns();
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = statement;
          set deref(report).related = block;
          return SemanticReaderFlowError();
        }
      }
    }
  }
}

fn semantic_reader_tag_only_enum_variant_count ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, enum_decl: own u64) -> own u64 reads('c), traps {
