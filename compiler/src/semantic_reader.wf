      let ctor_code: own PreludeConstructorCode = semantic_prelude_constructor_code(source: source, tokens: tokens, token: ctor_head);
      let ctor_true_tag: own PreludeConstructorCode = PreludeConstructorTrue();
      let ctor_false_tag: own PreludeConstructorCode = PreludeConstructorFalse();
      let ctor_is_true: own Bool = eeq<PreludeConstructorCode>(ctor_code, ctor_true_tag);
      let ctor_is_false: own Bool = eeq<PreludeConstructorCode>(ctor_code, ctor_false_tag);
      match bor<Bool>(ctor_is_true, ctor_is_false) {
        True() => {
          return semantic_buffer_type_bool;
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = ctor_head;
          return semantic_facts_none;
        }
      }
    }
    False() => {
    }
  }
  let ast_user_call_atom: own AstKind = AstUserCall();
  let is_call: own Bool = eeq<AstKind>(node_kind, ast_user_call_atom);
  match is_call {
    True() => {
      let call_type: own u64 = semantic_facts_none;
      region 'semantic_reader_expr_call {
        set call_type = semantic_reader_analyze_call(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, node: node, scratch: scratch, report: &uniq 'semantic_reader_expr_call deref(report));
      }
