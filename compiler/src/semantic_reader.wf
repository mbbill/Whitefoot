      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = head;
      return SemanticReaderFlowError();
    }
  }
  let scrutinee: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 0_u64);
  match ieq<u64>(scrutinee, ast_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = statement;
      return SemanticReaderFlowError();
    }
    False() => {
    }
  }

  let scrutinee_type: own u64 = semantic_facts_none;
  region 'semantic_reader_match_scrutinee {
    set scrutinee_type = semantic_reader_analyze_expr(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, node: scrutinee, scratch: &'semantic_reader_match_scrutinee deref(scratch), report: &uniq 'semantic_reader_match_scrutinee deref(report));
  }
  match ieq<u64>(scrutinee_type, semantic_facts_none) {
    True() => {
      return SemanticReaderFlowError();
    }
    False() => {
    }
  }

  let scrutinee_is_bool: own Bool = ieq<u64>(scrutinee_type, semantic_buffer_type_bool);
  match scrutinee_is_bool {
    True() => {
    }
    False() => {
      let enum_in_range_low: own Bool = ige<u64>(scrutinee_type, semantic_reader_enum_type_base);
      let enum_in_range_high: own Bool = ilt<u64>(scrutinee_type, semantic_reader_struct_type_base);
      let enum_in_range: own Bool = band<Bool>(enum_in_range_low, enum_in_range_high);
      match enum_in_range {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = scrutinee;
          set deref(report).related = statement;
          return SemanticReaderFlowError();
        }
      }
      let enum_decl: own u64 = isub.wrap<u64>(scrutinee_type, semantic_reader_enum_type_base);
      let enum_ok: own Bool = semantic_reader_enum_decl_valid(ast: ast, enum_decl: enum_decl);
      match enum_ok {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = scrutinee;
          set deref(report).related = statement;
          return SemanticReaderFlowError();
        }
      }
      let exact: own Bool = semantic_reader_enum_match_exact(source: source, tokens: tokens, ast: ast, enum_decl: enum_decl, statement: statement);
      match exact {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = statement;
          set deref(report).related = enum_decl;
          return SemanticReaderFlowError();
        }
      }
      let enum_flow: own SemanticReaderFlow = SemanticReaderFlowError();
      region 'semantic_reader_match_enum_arms {
        set enum_flow = semantic_reader_analyze_enum_arms(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, statement: statement, loop_label: loop_label, scratch: &uniq 'semantic_reader_match_enum_arms deref(scratch), report: &uniq 'semantic_reader_match_enum_arms deref(report));
      }
      return enum_flow;
    }
  }

  let match_shape: own Bool = semantic_body_exact_children(ast: ast, node: statement, want: 3_u64);
  match match_shape {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = statement;
      return SemanticReaderFlowError();
    }
  }
  let true_arm: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 1_u64);
  let false_arm: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 2_u64);

  let true_true: own Bool = True();
  let true_arm_ok: own Bool = semantic_reader_arm_valid(source: source, tokens: tokens, ast: ast, arm: true_arm, truth: true_true);
  let false_false: own Bool = False();
  let false_arm_ok: own Bool = semantic_reader_arm_valid(source: source, tokens: tokens, ast: ast, arm: false_arm, truth: false_false);
  match band<Bool>(true_arm_ok, false_arm_ok) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = true_arm;
      return SemanticReaderFlowError();
    }
  }

  let true_block: own u64 = semantic_body_child_at(ast: ast, node: true_arm, ordinal: 0_u64);
  let false_block: own u64 = semantic_body_child_at(ast: ast, node: false_arm, ordinal: 0_u64);

  let true_saved: own u64 = deref(scratch).count;
  let true_flow: own SemanticReaderFlow = SemanticReaderFlowError();
  region 'semantic_reader_match_true {
    set true_flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, block: true_block, loop_label: loop_label, scratch: &uniq 'semantic_reader_match_true deref(scratch), report: &uniq 'semantic_reader_match_true deref(report));
  }
  set deref(scratch).count = true_saved;

  let false_saved: own u64 = deref(scratch).count;
  let false_flow: own SemanticReaderFlow = SemanticReaderFlowError();
  region 'semantic_reader_match_false {
    set false_flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, block: false_block, loop_label: loop_label, scratch: &uniq 'semantic_reader_match_false deref(scratch), report: &uniq 'semantic_reader_match_false deref(report));
  }
  set deref(scratch).count = false_saved;
  return semantic_reader_flow_join(left: true_flow, right: false_flow);
}

