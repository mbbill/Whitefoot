    True() => {
    }
    False() => {
      return False();
    }
  }
  let ast_struct_decl_atom: own AstKind = AstStructDecl();
  return semantic_body_kind_is(ast: ast, node: struct_decl, want: ast_struct_decl_atom);
}

fn semantic_reader_type_node_struct_id ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, type_node: own u64) -> own u64 reads('c), traps {
  let ast_parameter_type_atom: own AstKind = AstParameterType();
  let kind_ok: own Bool = semantic_body_kind_is(ast: ast, node: type_node, want: ast_parameter_type_atom);
  let leaf_ok: own Bool = semantic_body_exact_children(ast: ast, node: type_node, want: 0_u64);
  let token_ok: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: type_node);
  let first: own Bool = band<Bool>(kind_ok, leaf_ok);
  let all: own Bool = band<Bool>(first, token_ok);
  match all {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, type_node);
  let symbol_type_atom: own SymbolNamespace = SymbolType();
  let lookup: own SymbolLookupResult = symbol_lookup_in_scope(source: source, tokens: tokens, symbols: symbols, space: symbol_type_atom, scope: symbol_none, name_token: head);
  match lookup.status {
    SymbolLookupFound() => {
    }
    SymbolLookupNotFound() => {
      return semantic_facts_none;
    }
    SymbolLookupInvalidTape() => {
      return semantic_facts_none;
    }
    SymbolLookupInvalidToken() => {
      return semantic_facts_none;
    }
  }
  let struct_decl: own u64 = lookup.declaration;
  let decl_valid: own Bool = semantic_reader_struct_decl_valid(ast: ast, struct_decl: struct_decl);
  match decl_valid {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let struct_name: own u64 = semantic_body_child_at(ast: ast, node: struct_decl, ordinal: 0_u64);
  let ast_struct_name_atom: own AstKind = AstStructName();
  let struct_name_kind: own Bool = semantic_body_kind_is(ast: ast, node: struct_name, want: ast_struct_name_atom);
  let struct_name_leaf: own Bool = semantic_body_exact_children(ast: ast, node: struct_name, want: 0_u64);
  let struct_name_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: struct_name);
  let struct_name_shape: own Bool = band<Bool>(struct_name_kind, struct_name_leaf);
  match band<Bool>(struct_name_shape, struct_name_token) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let struct_name_head: own u64 = index<u64>(deref(ast).heads, struct_name);
  let name_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: head, right: struct_name_head);
  match name_matches {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  return iadd.trap<u64>(struct_decl, semantic_reader_struct_type_base);
}

fn semantic_reader_struct_field_type ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, struct_decl: own u64, field_name_head: own u64) -> own u64 reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  let ast_field_atom: own AstKind = AstField();
  let ast_field_type_atom: own AstKind = AstFieldType();
  let first: own u64 = index<u64>(deref(ast).first_children, struct_decl);
  let last: own u64 = index<u64>(deref(ast).last_children, struct_decl);
  let child: own u64 = first;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_struct_field_scan {
    match ilt<u64>(child, ast_count) {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
    let child_kind: own AstKind = index<AstKind>(deref(ast).kinds, child);
    let is_field: own Bool = eeq<AstKind>(child_kind, ast_field_atom);
    match is_field {
      True() => {
        let field_head: own u64 = index<u64>(deref(ast).heads, child);
        let same: own Bool = token_text_equal(source: source, tokens: tokens, left: field_head, right: field_name_head);
        match same {
          True() => {
            let field_type_node: own u64 = index<u64>(deref(ast).first_children, child);
            let ft_leaf: own Bool = semantic_body_exact_children(ast: ast, node: field_type_node, want: 0_u64);
            let ft_kind: own Bool = semantic_body_kind_is(ast: ast, node: field_type_node, want: ast_field_type_atom);
            match band<Bool>(ft_leaf, ft_kind) {
              True() => {
              }
              False() => {
                return semantic_facts_none;
              }
            }
            let is_u8: own Bool = semantic_buffer_type_node_valid(source: source, tokens: tokens, ast: ast, node: field_type_node, kind: ast_field_type_atom, type_id: semantic_buffer_type_u8);
            match is_u8 {
              True() => {
                return semantic_buffer_type_u8;
              }
              False() => {
              }
            }
            let is_u64: own Bool = semantic_buffer_type_node_valid(source: source, tokens: tokens, ast: ast, node: field_type_node, kind: ast_field_type_atom, type_id: semantic_buffer_type_u64);
            match is_u64 {
              True() => {
                return semantic_buffer_type_u64;
              }
              False() => {
              }
            }
            let is_bool: own Bool = semantic_buffer_type_node_valid(source: source, tokens: tokens, ast: ast, node: field_type_node, kind: ast_field_type_atom, type_id: semantic_buffer_type_bool);
            match is_bool {
              True() => {
                return semantic_buffer_type_bool;
              }
              False() => {
              }
            }
            return semantic_reader_leaf_enum_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: field_type_node);
          }
          False() => {
          }
        }
      }
      False() => {
      }
    }
    match ieq<u64>(child, last) {
      True() => {
        return semantic_facts_none;
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match ilt<u64>(next, ast_count) {
      True() => {
        set child = next;
      }
      False() => {
        return semantic_facts_none;
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
  }
}

fn semantic_reader_analyze_field_place ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, scratch: &'w SemanticBodyScratch, node: own u64, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
