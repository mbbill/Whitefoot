  match ieq<u64>(type_id, semantic_facts_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = type_node;
      return False();
    }
    False() => {
    }
  }
  let header_ok: own Bool = semantic_buffer_let_header_any(source: source, tokens: tokens, ast: ast, node: statement, type_id: type_id);
  match header_ok {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = type_node;
      return False();
    }
  }
  let value_node: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 3_u64);
  let value_type: own u64 = semantic_facts_none;
  region 'semantic_reader_let_value {
    set value_type = semantic_reader_analyze_expr(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, node: value_node, scratch: &'semantic_reader_let_value deref(scratch), report: &uniq 'semantic_reader_let_value deref(report));
  }
  match ieq<u64>(value_type, semantic_facts_none) {
    True() => {
      return False();
    }
    False() => {
    }
  }
  match ieq<u64>(value_type, type_id) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = value_node;
      set deref(report).related = type_node;
      return False();
    }
  }
  let name_node: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 0_u64);
  let name_head: own u64 = index<u64>(deref(ast).heads, name_node);
  let pushed: own Bool = False();
  region 'semantic_reader_let_push {
    let semantic_mode_own_atom: own SemanticValueMode = SemanticModeOwn();
    set pushed = semantic_body_scope_push(source: source, tokens: tokens, scratch: &uniq 'semantic_reader_let_push deref(scratch), name_token: name_head, declaration: statement, type_id: type_id, mode: semantic_mode_own_atom);
  }
  match pushed {
    True() => {
      return True();
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = name_head;
      return False();
    }
  }
