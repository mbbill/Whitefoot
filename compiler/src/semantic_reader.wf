      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = statement;
      return SemanticReaderFlowError();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, statement);
  let match_word: own Bool = parser_word5(source: source, tokens: tokens, token: head, a: 109_u8, b: 97_u8, c: 116_u8, d: 99_u8, e: 104_u8);
