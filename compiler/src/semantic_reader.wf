            let name_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: child);
            match band<Bool>(name_leaf, name_token) {
              True() => {
                set name_count = iadd.trap<u64>(name_count, 1_u64);
              }
              False() => {
                return semantic_facts_none;
              }
            }
          }
          False() => {
            return semantic_facts_none;
          }
        }
