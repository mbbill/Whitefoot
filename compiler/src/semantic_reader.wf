      let ast_field_place_atom_ieff: own AstKind = AstFieldPlace();
      let base_is_field_ie: own Bool = semantic_body_kind_is(ast: ast, node: base, want: ast_field_place_atom_ieff);
      match base_is_field_ie {
        True() => {
          let ifbase: own u64 = semantic_body_child_at(ast: ast, node: base, ordinal: 0_u64);
          let ast_deref_place_atom_ie: own AstKind = AstDerefPlace();
          let ifbase_is_deref: own Bool = semantic_body_kind_is(ast: ast, node: ifbase, want: ast_deref_place_atom_ie);
          match ifbase_is_deref {
            True() => {
              let ifplace: own u64 = semantic_body_child_at(ast: ast, node: ifbase, ordinal: 0_u64);
              let ifplace_head: own u64 = index<u64>(deref(ast).heads, ifplace);
              set region = semantic_reader_function_param_region(source: source, tokens: tokens, ast: ast, function: function, name_head: ifplace_head);
