fn semantic_reader_arm_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, arm: own u64, truth: own Bool) -> own Bool reads('c), traps {
  let ast_match_arm_atom: own AstKind = AstMatchArm();
  let arm_kind: own Bool = semantic_body_kind_is(ast: ast, node: arm, want: ast_match_arm_atom);
  let arm_shape: own Bool = semantic_body_exact_children(ast: ast, node: arm, want: 1_u64);
  let arm_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: arm);
  let arm_first: own Bool = band<Bool>(arm_kind, arm_shape);
  let arm_root: own Bool = band<Bool>(arm_first, arm_token);
  match arm_root {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let arm_head: own u64 = index<u64>(deref(ast).heads, arm);
  let arm_code: own PreludeConstructorCode = semantic_prelude_constructor_code(source: source, tokens: tokens, token: arm_head);
  let arm_expected: own PreludeConstructorCode = PreludeConstructorFalse();
  match truth {
    True() => {
      set arm_expected = PreludeConstructorTrue();
    }
    False() => {
    }
  }
  return ieq<PreludeConstructorCode>(arm_code, arm_expected);
}

fn semantic_reader_analyze_let ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, region_token: own u64, statement: own u64, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own Bool reads('c 'w), writes('w), traps {
