fn semantic_reader_analyze_enum_arms ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, regions_node: own u64, return_type: own u64, statement: own u64, loop_label: own u64, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own SemanticReaderFlow reads('c 'w), writes('w), traps {
  let ast_count: own u64 = deref(ast).count;
  let first: own u64 = index<u64>(deref(ast).first_children, statement);
  let last: own u64 = index<u64>(deref(ast).last_children, statement);
  let arm: own u64 = index<u64>(deref(ast).next_siblings, first);
  let saw_return: own Bool = False();
  let saw_fall: own Bool = False();
  let saw_break: own Bool = False();
  let steps: own u64 = 0_u64;
  loop @semantic_reader_enum_arm_flow {
    match ilt<u64>(arm, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = statement;
        set deref(report).related = arm;
        return SemanticReaderFlowError();
      }
    }
    let arm_block: own u64 = semantic_body_child_at(ast: ast, node: arm, ordinal: 0_u64);
    let arm_saved: own u64 = deref(scratch).count;
    let arm_flow: own SemanticReaderFlow = SemanticReaderFlowError();
    region 'semantic_reader_enum_arm_block {
      set arm_flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, block: arm_block, loop_label: loop_label, scratch: &uniq 'semantic_reader_enum_arm_block deref(scratch), report: &uniq 'semantic_reader_enum_arm_block deref(report));
    }
    set deref(scratch).count = arm_saved;
    match arm_flow {
      SemanticReaderFlowReturns() => {
        set saw_return = True();
      }
      SemanticReaderFlowFalls() => {
        set saw_fall = True();
      }
      SemanticReaderFlowBreaks() => {
        set saw_break = True();
      }
      SemanticReaderFlowFallsOrReturns() => {
        set saw_fall = True();
        set saw_return = True();
      }
      SemanticReaderFlowFallsOrBreaks() => {
        set saw_fall = True();
        set saw_break = True();
      }
      SemanticReaderFlowReturnsOrBreaks() => {
        set saw_return = True();
        set saw_break = True();
      }
      SemanticReaderFlowFallsOrReturnsOrBreaks() => {
        set saw_fall = True();
        set saw_return = True();
        set saw_break = True();
      }
      SemanticReaderFlowError() => {
        return SemanticReaderFlowError();
      }
    }
    match ieq<u64>(arm, last) {
      True() => {
        return semantic_reader_flow_from_flags(falls: saw_fall, returns: saw_return, breaks: saw_break);
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, arm);
    match ilt<u64>(next, ast_count) {
      True() => {
        set arm = next;
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = statement;
        set deref(report).related = next;
        return SemanticReaderFlowError();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = statement;
        set deref(report).related = steps;
        return SemanticReaderFlowError();
      }
    }
  }
}

fn semantic_reader_analyze_match ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, regions_node: own u64, return_type: own u64, statement: own u64, loop_label: own u64, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own SemanticReaderFlow reads('c 'w), writes('w), traps {
  let match_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: statement);
  match match_token {
    True() => {
    }
