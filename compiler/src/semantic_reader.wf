fn semantic_reader_loop_label_push ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, label: own u64, scratch: &uniq 'w SemanticBodyScratch) -> own Bool reads('c 'w), writes('w), traps {
  let count: own u64 = deref(scratch).loop_count;
  let capacity: own u64 = len<u64>(deref(scratch).loop_labels);
  match ilt<u64>(count, capacity) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let cursor: own u64 = 0_u64;
  loop @semantic_reader_loop_label_unique {
    match ige<u64>(cursor, count) {
      True() => {
        set index<u64>(deref(scratch).loop_labels, count) = label;
        set deref(scratch).loop_count = iadd.trap<u64>(count, 1_u64);
        return True();
      }
      False() => {
      }
    }
    let prior: own u64 = index<u64>(deref(scratch).loop_labels, cursor);
    let duplicate: own Bool = semantic_scanner_nodes_equal<'c>(source: source, tokens: tokens, ast: ast, left: prior, right: label);
    match duplicate {
      True() => {
        return False();
      }
      False() => {
        set cursor = iadd.trap<u64>(cursor, 1_u64);
      }
    }
  }
}

