    }
    False() => {
      return False();
    }
  }
  let name: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
  let mode: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 2_u64);
  let ast_binding_name_atom: own AstKind = AstBindingName();
  let name_kind: own Bool = semantic_body_kind_is(ast: ast, node: name, want: ast_binding_name_atom);
  let name_leaf: own Bool = semantic_body_exact_children(ast: ast, node: name, want: 0_u64);
  let name_word: own Bool = semantic_buffer_declaration_word_valid(source: source, tokens: tokens, ast: ast, node: name);
  let name_first: own Bool = band<Bool>(name_kind, name_leaf);
  let name_valid: own Bool = band<Bool>(name_first, name_word);
  let ast_own_mode_atom: own AstKind = AstOwnMode();
  let mode_kind: own Bool = semantic_body_kind_is(ast: ast, node: mode, want: ast_own_mode_atom);
  let mode_valid: own Bool = semantic_function_mode_valid(source: source, tokens: tokens, ast: ast, node: mode);
  let mode_ok: own Bool = band<Bool>(mode_kind, mode_valid);
  let ast_binding_type_atom: own AstKind = AstBindingType();
  let type_kind: own Bool = semantic_body_kind_is(ast: ast, node: type_node, want: ast_binding_type_atom);
  let type_leaf: own Bool = semantic_body_exact_children(ast: ast, node: type_node, want: 0_u64);
  let type_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: type_node);
  let type_first: own Bool = band<Bool>(type_kind, type_leaf);
  let type_valid: own Bool = band<Bool>(type_first, type_token);
  let prefix: own Bool = band<Bool>(name_valid, mode_ok);
  return band<Bool>(prefix, type_valid);
}

