      set deref(report).related = place_node;
      return semantic_facts_none;
    }
  }
  let struct_decl: own u64 = isub.wrap<u64>(struct_type, semantic_reader_struct_type_base);
  let decl_ok: own Bool = semantic_reader_struct_decl_valid(ast: ast, struct_decl: struct_decl);
  match decl_ok {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = place_node;
      return semantic_facts_none;
    }
  }
  let field_name_head: own u64 = index<u64>(deref(ast).heads, node);
  let field_type: own u64 = semantic_reader_struct_field_type(source: source, tokens: tokens, ast: ast, symbols: symbols, struct_decl: struct_decl, field_name_head: field_name_head);
  match ieq<u64>(field_type, semantic_facts_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = node;
      return semantic_facts_none;
    }
    False() => {
