    False() => {
    }
  }

  let flow: own SemanticReaderFlow = SemanticReaderFlowFalls();
  let block_steps: own u64 = 0_u64;
  loop @semantic_reader_block_statements {
    match ilt<u64>(statement, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = block;
        set deref(report).related = statement;
        return SemanticReaderFlowError();
      }
    }
    let statement_kind: own AstKind = index<AstKind>(deref(ast).kinds, statement);
    let at_last: own Bool = ieq<u64>(statement, last_statement);
    let next_statement: own u64 = index<u64>(deref(ast).next_siblings, statement);

    let ast_let_atom: own AstKind = AstLet();
    let is_let: own Bool = eeq<AstKind>(statement_kind, ast_let_atom);
    let ast_match_atom: own AstKind = AstMatch();
    let is_match: own Bool = eeq<AstKind>(statement_kind, ast_match_atom);
    let ast_return_atom: own AstKind = AstReturn();
    let is_return: own Bool = eeq<AstKind>(statement_kind, ast_return_atom);
    let ast_set_atom: own AstKind = AstSet();
    let is_set: own Bool = eeq<AstKind>(statement_kind, ast_set_atom);
    let ast_loop_atom: own AstKind = AstLoop();
    let is_loop: own Bool = eeq<AstKind>(statement_kind, ast_loop_atom);
    let ast_break_atom: own AstKind = AstBreak();
    let is_break: own Bool = eeq<AstKind>(statement_kind, ast_break_atom);

    let statement_flow: own SemanticReaderFlow = SemanticReaderFlowFalls();
    let statement_error: own Bool = False();
    let statement_handled: own Bool = False();

    match is_let {
      True() => {
        set statement_handled = True();
        let let_clean: own Bool = False();
        region 'semantic_reader_stmt_let {
          set let_clean = semantic_reader_analyze_let(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, statement: statement, scratch: &uniq 'semantic_reader_stmt_let deref(scratch), report: &uniq 'semantic_reader_stmt_let deref(report));
        }
        match let_clean {
          True() => {
            set statement_flow = SemanticReaderFlowFalls();
          }
          False() => {
            set statement_error = True();
          }
        }
      }
      False() => {
      }
    }
    match is_match {
      True() => {
        set statement_handled = True();
        region 'semantic_reader_stmt_match {
          set statement_flow = semantic_reader_analyze_match(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, statement: statement, loop_label: loop_label, scratch: &uniq 'semantic_reader_stmt_match deref(scratch), report: &uniq 'semantic_reader_stmt_match deref(report));
        }
      }
      False() => {
      }
    }
    match is_return {
      True() => {
        set statement_handled = True();
        let return_clean: own Bool = False();
        region 'semantic_reader_stmt_return {
          set return_clean = semantic_reader_analyze_return(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, statement: statement, scratch: &uniq 'semantic_reader_stmt_return deref(scratch), report: &uniq 'semantic_reader_stmt_return deref(report));
        }
        match return_clean {
          True() => {
            set statement_flow = SemanticReaderFlowReturns();
          }
          False() => {
            set statement_error = True();
          }
        }
      }
      False() => {
      }
    }
    match is_set {
      True() => {
        set statement_handled = True();
        let set_clean: own Bool = False();
        region 'semantic_reader_stmt_set {
          set set_clean = semantic_reader_analyze_set<'c, 'semantic_reader_stmt_set>(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, statement: statement, scratch: &uniq 'semantic_reader_stmt_set deref(scratch), report: &uniq 'semantic_reader_stmt_set deref(report));
        }
        match set_clean {
          True() => {
            set statement_flow = SemanticReaderFlowFalls();
          }
          False() => {
            set statement_error = True();
          }
        }
      }
      False() => {
      }
    }
    match is_loop {
      True() => {
        set statement_handled = True();
        region 'semantic_reader_stmt_loop {
          set statement_flow = semantic_reader_analyze_loop<'c, 'semantic_reader_stmt_loop>(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: return_type, statement: statement, scratch: &uniq 'semantic_reader_stmt_loop deref(scratch), report: &uniq 'semantic_reader_stmt_loop deref(report));
        }
      }
      False() => {
      }
    }
    match is_break {
      True() => {
        set statement_handled = True();
        let break_clean: own Bool = False();
        region 'semantic_reader_stmt_break {
          set break_clean = semantic_reader_analyze_break<'c, 'semantic_reader_stmt_break>(source: source, tokens: tokens, ast: ast, statement: statement, loop_label: loop_label, report: &uniq 'semantic_reader_stmt_break deref(report));
        }
        match break_clean {
          True() => {
            set statement_flow = SemanticReaderFlowBreaks();
          }
          False() => {
            set statement_error = True();
          }
        }
      }
      False() => {
      }
    }
    match statement_handled {
      True() => {
      }
      False() => {
        set statement_error = True();
        let unknown_head: own u64 = index<u64>(deref(ast).heads, statement);
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = statement;
        set deref(report).related = unknown_head;
      }
    }

    match statement_error {
      True() => {
        return SemanticReaderFlowError();
      }
      False() => {
      }
    }

    let composed_flow: own SemanticReaderFlow = semantic_reader_flow_then(before: flow, statement: statement_flow);
    match composed_flow {
      SemanticReaderFlowError() => {
        return SemanticReaderFlowError();
      }
      SemanticReaderFlowReturns() => {
      }
      SemanticReaderFlowFalls() => {
      }
      SemanticReaderFlowBreaks() => {
      }
      SemanticReaderFlowFallsOrReturns() => {
      }
      SemanticReaderFlowFallsOrBreaks() => {
      }
      SemanticReaderFlowReturnsOrBreaks() => {
      }
      SemanticReaderFlowFallsOrReturnsOrBreaks() => {
      }
    }
    set flow = composed_flow;
    let flow_falls: own Bool = semantic_reader_flow_has_fall(flow: flow);

    match at_last {
      True() => {
        match ieq<u64>(next_statement, ast_none) {
          True() => {
            break @semantic_reader_block_statements;
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = block;
            set deref(report).related = next_statement;
            return SemanticReaderFlowError();
          }
        }
      }
      False() => {
        match flow_falls {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = statement;
            set deref(report).related = next_statement;
            return SemanticReaderFlowError();
          }
        }
        match ilt<u64>(next_statement, ast_count) {
          True() => {
            set statement = next_statement;
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = block;
            set deref(report).related = next_statement;
            return SemanticReaderFlowError();
          }
        }
      }
    }
    set block_steps = iadd.trap<u64>(block_steps, 1_u64);
    match ilt<u64>(block_steps, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = block;
        set deref(report).related = block_steps;
        return SemanticReaderFlowError();
      }
    }
  }
  return flow;
}

