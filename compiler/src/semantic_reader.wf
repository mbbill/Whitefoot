  let linear_shape: own Bool = semantic_body_exact_children(ast: ast, node: function, want: 6_u64);
  match linear_shape {
    True() => {
      let linear_param: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 1_u64);
      let linear_return_type: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 3_u64);
      let linear_effect: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 4_u64);
      let linear_param_type: own u64 = semantic_reader_param_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, parameter: linear_param);
      let linear_param_mode: own SemanticValueMode = semantic_reader_param_mode(source: source, tokens: tokens, ast: ast, parameter: linear_param);
      let linear_mode_own_atom: own SemanticValueMode = SemanticModeOwn();
      let linear_param_u8: own Bool = ieq<u64>(linear_param_type, semantic_buffer_type_u8);
      let linear_param_own: own Bool = eeq<SemanticValueMode>(linear_param_mode, linear_mode_own_atom);
      let ast_return_type_atom_linear: own AstKind = AstReturnType();
      let linear_return_bool: own Bool = semantic_buffer_type_node_valid(source: source, tokens: tokens, ast: ast, node: linear_return_type, kind: ast_return_type_atom_linear, type_id: semantic_buffer_type_bool);
      let ast_pure_effect_atom_linear: own AstKind = AstPureEffect();
      let linear_effect_pure: own Bool = semantic_body_kind_is(ast: ast, node: linear_effect, want: ast_pure_effect_atom_linear);
      let linear_param_ok: own Bool = band<Bool>(linear_param_u8, linear_param_own);
      let linear_tail_ok: own Bool = band<Bool>(linear_return_bool, linear_effect_pure);
      match band<Bool>(linear_param_ok, linear_tail_ok) {
        True() => {
          return False();
