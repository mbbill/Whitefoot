        set regions_node = push_child;
      }
      False() => {
      }
    }
    let push_is_param: own Bool = eeq<AstKind>(push_kind, ast_parameter_atom);
    match push_is_param {
      True() => {
        let push_type: own u64 = semantic_reader_param_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, parameter: push_child);
        let push_mode: own SemanticValueMode = semantic_reader_param_mode(source: source, tokens: tokens, ast: ast, parameter: push_child);
        let push_name_head: own u64 = index<u64>(deref(ast).heads, push_child);
        let pushed: own Bool = False();
        region 'semantic_reader_run_push_param {
          set pushed = semantic_body_scope_push(source: source, tokens: tokens, scratch: &uniq 'semantic_reader_run_push_param deref(scratch), name_token: push_name_head, declaration: push_child, type_id: push_type, mode: push_mode);
        }
        match pushed {
          True() => {
          }
          False() => {
            set pushed_ok = False();
          }
        }
      }
      False() => {
      }
    }
    let push_is_return_type: own Bool = eeq<AstKind>(push_kind, ast_return_type_atom);
    match push_is_return_type {
      True() => {
        set return_type_node = push_child;
      }
      False() => {
      }
    }
    let push_is_reads: own Bool = eeq<AstKind>(push_kind, ast_reads_effect_atom);
    match push_is_reads {
      True() => {
        set reads_node = push_child;
      }
      False() => {
      }
    }
    let push_is_traps: own Bool = eeq<AstKind>(push_kind, ast_traps_effect_atom);
    match push_is_traps {
      True() => {
        set traps_seen = True();
      }
      False() => {
      }
    }
    let push_is_block: own Bool = eeq<AstKind>(push_kind, ast_block_atom);
    match push_is_block {
      True() => {
        set reader_block = push_child;
      }
      False() => {
      }
    }
    match ieq<u64>(push_child, function_last) {
      True() => {
        break @semantic_reader_run_push;
      }
      False() => {
      }
    }
    let push_next: own u64 = index<u64>(deref(ast).next_siblings, push_child);
    match ilt<u64>(push_next, ast_count) {
      True() => {
        set push_child = push_next;
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = function;
        set deref(report).related = push_next;
        return unit;
      }
    }
    set push_steps = iadd.trap<u64>(push_steps, 1_u64);
    match ilt<u64>(push_steps, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = function;
        set deref(report).related = push_steps;
        return unit;
      }
    }
  }

  match pushed_ok {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = function;
      return unit;
    }
  }

  let region_token: own u64 = ast_none;
  let multiple_regions: own Bool = False();
  match ine<u64>(regions_node, ast_none) {
    True() => {
      let region_leaf: own u64 = semantic_body_child_at(ast: ast, node: regions_node, ordinal: 0_u64);
      let region_last: own u64 = index<u64>(deref(ast).last_children, regions_node);
      set region_token = index<u64>(deref(ast).heads, region_leaf);
      set multiple_regions = ine<u64>(region_leaf, region_last);
    }
    False() => {
    }
  }

  let reader_return_type_id: own u64 = semantic_reader_return_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: return_type_node);
  match ine<u64>(reader_return_type_id, semantic_facts_none) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = return_type_node;
      return unit;
    }
  }

  let flow: own SemanticReaderFlow = SemanticReaderFlowError();
  region 'semantic_reader_run_block {
    set flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, regions_node: regions_node, return_type: reader_return_type_id, block: reader_block, loop_label: ast_none, scratch: &uniq 'semantic_reader_run_block deref(scratch), report: &uniq 'semantic_reader_run_block deref(report));
  }
  match flow {
    SemanticReaderFlowReturns() => {
      let effects_ok: own Bool = semantic_reader_effects_reconcile(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, multiple_regions: multiple_regions, region_token: region_token, reads_node: reads_node, traps_declared: traps_seen, block: reader_block);
      match effects_ok {
        True() => {
          set deref(report).status = SemanticBodyClean();
          set deref(report).node = semantic_facts_none;
          set deref(report).related = semantic_facts_none;
          set deref(report).rule = SemanticRuleNone();
          set deref(report).fix = SemanticFixNone();
          set deref(report).related_node = ast_none;
          return unit;
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = function;
          set deref(report).related = reader_block;
          set deref(report).rule = SemanticRuleNone();
          set deref(report).fix = SemanticFixNone();
          set deref(report).related_node = ast_none;
          return unit;
        }
      }
    }
    SemanticReaderFlowFalls() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowBreaks() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowFallsOrReturns() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowFallsOrBreaks() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowReturnsOrBreaks() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowError() => {
      set deref(report).status = SemanticBodyUnsupported();
      return unit;
    }
  }
}
