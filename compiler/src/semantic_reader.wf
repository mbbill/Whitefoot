        }
      }
      let actual_region: own u64 = index<u64>(deref(ast).heads, region_node);
      return token_text_equal<'c, 'c>(source: source, tokens: tokens, left: actual_region, right: expected_region);
    }
    False() => {
      return False();
    }
  }
}

