fn semantic_reader_operand ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, scratch: &'w SemanticBodyScratch, node: own u64, expected_type: own u64) -> own Bool reads('c 'w), traps {
  let ast_count: own u64 = deref(ast).count;
  match ilt<u64>(node, ast_count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let node_kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let is_literal: own Bool = eeq<AstKind>(node_kind, ast_numeric_literal_atom);
  match is_literal {
    True() => {
      match ieq<u64>(expected_type, semantic_buffer_type_u8) {
        True() => {
          let head: own u64 = index<u64>(deref(ast).heads, node);
          let leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
          match leaf {
            True() => {
            }
            False() => {
              return False();
            }
          }
          let parsed: own SemanticU8LiteralResult = semantic_body_parse_u8_literal(source: source, tokens: tokens, token: head);
          match parsed.status {
            SemanticU8LiteralReady() => {
              return True();
            }
            SemanticU8LiteralWrongType() => {
              return False();
            }
            SemanticU8LiteralMissingSuffix() => {
              return False();
            }
            SemanticU8LiteralNoncanonical() => {
              return False();
            }
            SemanticU8LiteralInvalidValue() => {
              return False();
            }
            SemanticU8LiteralMalformed() => {
              return False();
            }
          }
        }
        False() => {
        }
      }
      match ieq<u64>(expected_type, semantic_buffer_type_u64) {
        True() => {
          return semantic_reader_u64_literal_canonical<'c>(source: source, tokens: tokens, ast: ast, node: node);
        }
        False() => {
          return False();
        }
      }
    }
    False() => {
    }
  }
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let is_place: own Bool = eeq<AstKind>(node_kind, ast_place_use_atom);
  match is_place {
    True() => {
      let place_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: node);
      match ieq<u64>(place_type, semantic_facts_none) {
        True() => {
          return False();
        }
        False() => {
        }
      }
      return ieq<u64>(place_type, expected_type);
    }
    False() => {
      return False();
    }
  }
}

fn semantic_reader_analyze_table_call ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, scratch: &'w SemanticBodyScratch, node: own u64, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  let ast_table_call_atom: own AstKind = AstTableCall();
  let kind_ok: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_table_call_atom);
  let token_ok: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  match band<Bool>(kind_ok, token_ok) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = node;
      return semantic_facts_none;
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let is_len: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 108_u8, b: 101_u8, c: 110_u8);
  match is_len {
    True() => {
      let len_shape: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 2_u64);
      match len_shape {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = node;
          return semantic_facts_none;
        }
      }
      let len_type_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
      let len_operand: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
      let len_element: own u64 = semantic_reader_type_arg_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: len_type_node);
      let len_want_u8: own Bool = ieq<u64>(len_element, semantic_buffer_type_u8);
      let len_want_u64: own Bool = ieq<u64>(len_element, semantic_buffer_type_u64);
      let len_want_enum_low: own Bool = ige<u64>(len_element, semantic_reader_enum_type_base);
      let len_want_enum_high: own Bool = ilt<u64>(len_element, semantic_reader_struct_type_base);
      let len_want_enum: own Bool = band<Bool>(len_want_enum_low, len_want_enum_high);
      let len_want_int: own Bool = bor<Bool>(len_want_u8, len_want_u64);
      match bor<Bool>(len_want_int, len_want_enum) {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = len_type_node;
          return semantic_facts_none;
        }
      }
      let ast_deref_place_atom_len: own AstKind = AstDerefPlace();
      let ast_field_place_atom_len: own AstKind = AstFieldPlace();
      let len_op_is_deref: own Bool = semantic_body_kind_is(ast: ast, node: len_operand, want: ast_deref_place_atom_len);
      let len_op_is_field: own Bool = semantic_body_kind_is(ast: ast, node: len_operand, want: ast_field_place_atom_len);
      let len_base_element: own u64 = semantic_facts_none;
      match len_op_is_deref {
        True() => {
          let len_op_shape: own Bool = semantic_body_exact_children(ast: ast, node: len_operand, want: 1_u64);
          match len_op_shape {
            True() => {
            }
            False() => {
              set deref(report).status = SemanticBodyUnsupported();
              set deref(report).node = node;
              set deref(report).related = len_operand;
              return semantic_facts_none;
            }
          }
          let len_place: own u64 = semantic_body_child_at(ast: ast, node: len_operand, ordinal: 0_u64);
          let len_place_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: len_place);
          match ieq<u64>(len_place_type, semantic_buffer_type_u8_buffer) {
            True() => {
              set len_base_element = semantic_buffer_type_u8;
            }
            False() => {
              set deref(report).status = SemanticBodyUnsupported();
              set deref(report).node = node;
              set deref(report).related = len_place;
              return semantic_facts_none;
            }
          }
        }
        False() => {
        }
      }
      match len_op_is_field {
        True() => {
          set len_base_element = semantic_reader_index_field_element(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: scratch, field_node: len_operand);
        }
        False() => {
        }
      }
      let len_op_recognized: own Bool = bor<Bool>(len_op_is_deref, len_op_is_field);
      match len_op_recognized {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = len_operand;
          return semantic_facts_none;
        }
      }
      match ieq<u64>(len_base_element, semantic_facts_none) {
        True() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = len_operand;
          return semantic_facts_none;
        }
        False() => {
        }
      }
      match ieq<u64>(len_element, len_base_element) {
        True() => {
          return semantic_buffer_type_u64;
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = len_type_node;
          return semantic_facts_none;
        }
      }
    }
    False() => {
    }
  }
  let is_bnot: own Bool = parser_word4(source: source, tokens: tokens, token: head, a: 98_u8, b: 110_u8, c: 111_u8, d: 116_u8);
  match is_bnot {
    True() => {
      let unary_shape: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 2_u64);
      match unary_shape {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = node;
          return semantic_facts_none;
        }
      }
      let unary_type_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
      let unary_operand_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
      let unary_operand_type: own u64 = semantic_reader_type_arg_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: unary_type_node);
      let unary_bool: own Bool = ieq<u64>(unary_operand_type, semantic_buffer_type_bool);
      match unary_bool {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = unary_type_node;
          return semantic_facts_none;
        }
      }
      let unary_ok: own Bool = semantic_reader_operand(source: source, tokens: tokens, ast: ast, scratch: scratch, node: unary_operand_node, expected_type: semantic_buffer_type_bool);
      match unary_ok {
        True() => {
          return semantic_buffer_type_bool;
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = head;
          return semantic_facts_none;
        }
      }
    }
    False() => {
    }
  }
  let shape_ok: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 3_u64);
  let first: own Bool = band<Bool>(kind_ok, shape_ok);
  let root_ok: own Bool = band<Bool>(first, token_ok);
  match root_ok {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = node;
      return semantic_facts_none;
    }
  }
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
  let left_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
  let right_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 2_u64);
  let operand_type: own u64 = semantic_reader_type_arg_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: type_node);
  match ieq<u64>(operand_type, semantic_facts_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = type_node;
      return semantic_facts_none;
    }
    False() => {
    }
  }
  let operand_u8: own Bool = ieq<u64>(operand_type, semantic_buffer_type_u8);
  let operand_u64: own Bool = ieq<u64>(operand_type, semantic_buffer_type_u64);
  let operand_bool: own Bool = ieq<u64>(operand_type, semantic_buffer_type_bool);
  let operand_scalar: own Bool = bor<Bool>(operand_u8, operand_u64);
  let operand_enum_low: own Bool = ige<u64>(operand_type, semantic_reader_enum_type_base);
  let operand_enum_high: own Bool = ilt<u64>(operand_type, semantic_reader_struct_type_base);
  let operand_enum: own Bool = band<Bool>(operand_enum_low, operand_enum_high);
  let operand_tag_only: own Bool = bor<Bool>(operand_bool, operand_enum);

  let is_iadd: own Bool = semantic_buffer_iadd_name_valid(source: source, tokens: tokens, token: head);
  let is_isub: own Bool = semantic_reader_isub_name_valid(source: source, tokens: tokens, token: head);
  let is_ige: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 105_u8, b: 103_u8, c: 101_u8);
  let is_ile: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 105_u8, b: 108_u8, c: 101_u8);
  let is_igt: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 105_u8, b: 103_u8, c: 116_u8);
  let is_ilt: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 105_u8, b: 108_u8, c: 116_u8);
  let is_ieq: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 105_u8, b: 101_u8, c: 113_u8);
  let is_ine: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 105_u8, b: 110_u8, c: 101_u8);
  let is_eeq: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 101_u8, b: 101_u8, c: 113_u8);
  let is_ene: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 101_u8, b: 110_u8, c: 101_u8);
  let is_band: own Bool = parser_word4(source: source, tokens: tokens, token: head, a: 98_u8, b: 97_u8, c: 110_u8, d: 100_u8);
  let is_bor: own Bool = parser_word3(source: source, tokens: tokens, token: head, a: 98_u8, b: 111_u8, c: 114_u8);

  let result_type: own u64 = semantic_facts_none;
  let operation_ok: own Bool = False();
  let matched: own Bool = False();
  let arithmetic: own Bool = bor<Bool>(is_iadd, is_isub);
  match arithmetic {
    True() => {
      set matched = True();
      set result_type = semantic_buffer_type_u64;
      set operation_ok = operand_u64;
    }
    False() => {
    }
  }
  let ordered_first: own Bool = bor<Bool>(is_ige, is_ile);
  let ordered_second: own Bool = bor<Bool>(is_igt, is_ilt);
  let ordered: own Bool = bor<Bool>(ordered_first, ordered_second);
  match ordered {
    True() => {
      set matched = True();
      set result_type = semantic_buffer_type_bool;
      set operation_ok = operand_scalar;
    }
    False() => {
    }
  }
  let equality: own Bool = bor<Bool>(is_ieq, is_ine);
  match equality {
    True() => {
      set matched = True();
      set result_type = semantic_buffer_type_bool;
      set operation_ok = operand_scalar;
    }
    False() => {
    }
  }
  let enum_equality: own Bool = bor<Bool>(is_eeq, is_ene);
  match enum_equality {
    True() => {
      set matched = True();
      set result_type = semantic_buffer_type_bool;
      set operation_ok = operand_tag_only;
    }
    False() => {
    }
  }
  let logical: own Bool = bor<Bool>(is_band, is_bor);
  match logical {
    True() => {
      set matched = True();
      set result_type = semantic_buffer_type_bool;
      set operation_ok = operand_bool;
    }
    False() => {
    }
  }
  match matched {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = head;
      return semantic_facts_none;
    }
  }
  match operation_ok {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = type_node;
      return semantic_facts_none;
    }
  }
  let left_ok: own Bool = semantic_reader_operand(source: source, tokens: tokens, ast: ast, scratch: scratch, node: left_node, expected_type: operand_type);
  let right_ok: own Bool = semantic_reader_operand(source: source, tokens: tokens, ast: ast, scratch: scratch, node: right_node, expected_type: operand_type);
  match band<Bool>(left_ok, right_ok) {
    True() => {
      return result_type;
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = head;
      return semantic_facts_none;
    }
  }
}

fn semantic_reader_analyze_index ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, scratch: &'w SemanticBodyScratch, node: own u64, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  let ast_index_place_atom: own AstKind = AstIndexPlace();
  let kind_ok: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_index_place_atom);
  let shape_ok: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 3_u64);
  let token_ok: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  let first: own Bool = band<Bool>(kind_ok, shape_ok);
  let root_ok: own Bool = band<Bool>(first, token_ok);
  match root_ok {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = node;
      return semantic_facts_none;
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let index_word: own Bool = parser_word5(source: source, tokens: tokens, token: head, a: 105_u8, b: 110_u8, c: 100_u8, d: 101_u8, e: 120_u8);
  match index_word {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = head;
      return semantic_facts_none;
    }
  }
  let type_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
  let base_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
  let subscript_node: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 2_u64);
  let want_element: own u64 = semantic_reader_type_arg_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: type_node);
  let want_u8: own Bool = ieq<u64>(want_element, semantic_buffer_type_u8);
  let want_u64: own Bool = ieq<u64>(want_element, semantic_buffer_type_u64);
  let want_enum_low: own Bool = ige<u64>(want_element, semantic_reader_enum_type_base);
  let want_enum_high: own Bool = ilt<u64>(want_element, semantic_reader_struct_type_base);
  let want_enum: own Bool = band<Bool>(want_enum_low, want_enum_high);
  let want_int: own Bool = bor<Bool>(want_u8, want_u64);
  match bor<Bool>(want_int, want_enum) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = type_node;
      return semantic_facts_none;
    }
  }
  let subscript_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: subscript_node);
  match ieq<u64>(subscript_type, semantic_buffer_type_u64) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = subscript_node;
      return semantic_facts_none;
    }
  }
  let ast_deref_place_atom: own AstKind = AstDerefPlace();
  let ast_field_place_atom_idx: own AstKind = AstFieldPlace();
  let base_is_deref: own Bool = semantic_body_kind_is(ast: ast, node: base_node, want: ast_deref_place_atom);
  let base_is_field: own Bool = semantic_body_kind_is(ast: ast, node: base_node, want: ast_field_place_atom_idx);
  let base_element: own u64 = semantic_facts_none;
  match base_is_deref {
    True() => {
      let base_shape: own Bool = semantic_body_exact_children(ast: ast, node: base_node, want: 1_u64);
      let base_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: base_node);
      match band<Bool>(base_shape, base_token) {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = base_node;
          return semantic_facts_none;
        }
      }
      let base_head: own u64 = index<u64>(deref(ast).heads, base_node);
      let deref_word: own Bool = parser_word5(source: source, tokens: tokens, token: base_head, a: 100_u8, b: 101_u8, c: 114_u8, d: 101_u8, e: 102_u8);
      match deref_word {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = base_head;
          return semantic_facts_none;
        }
      }
      let source_place: own u64 = semantic_body_child_at(ast: ast, node: base_node, ordinal: 0_u64);
      let source_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: source_place);
      match ieq<u64>(source_type, semantic_buffer_type_u8_buffer) {
        True() => {
          set base_element = semantic_buffer_type_u8;
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = source_place;
          return semantic_facts_none;
        }
      }
    }
    False() => {
    }
  }
  match base_is_field {
    True() => {
      set base_element = semantic_reader_index_field_element(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: scratch, field_node: base_node);
    }
    False() => {
    }
  }
  let base_recognized: own Bool = bor<Bool>(base_is_deref, base_is_field);
  match base_recognized {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = base_node;
      return semantic_facts_none;
    }
  }
  match ieq<u64>(base_element, semantic_facts_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = base_node;
      return semantic_facts_none;
    }
    False() => {
    }
  }
  match ieq<u64>(want_element, base_element) {
    True() => {
      return want_element;
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = type_node;
      return semantic_facts_none;
    }
  }
}

fn semantic_reader_index_field_element ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, scratch: &'w SemanticBodyScratch, field_node: own u64) -> own u64 reads('c 'w), traps {
  let ast_deref_place_atom: own AstKind = AstDerefPlace();
  let base: own u64 = semantic_body_child_at(ast: ast, node: field_node, ordinal: 0_u64);
  let base_ok: own Bool = semantic_body_kind_is(ast: ast, node: base, want: ast_deref_place_atom);
  let base_shape: own Bool = semantic_body_exact_children(ast: ast, node: base, want: 1_u64);
  match band<Bool>(base_ok, base_shape) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let place_node: own u64 = semantic_body_child_at(ast: ast, node: base, ordinal: 0_u64);
  let struct_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: place_node);
  let is_struct: own Bool = ige<u64>(struct_type, semantic_reader_struct_type_base);
  match is_struct {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let struct_decl: own u64 = isub.wrap<u64>(struct_type, semantic_reader_struct_type_base);
  let decl_ok: own Bool = semantic_reader_struct_decl_valid(ast: ast, struct_decl: struct_decl);
  match decl_ok {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let field_name_head: own u64 = index<u64>(deref(ast).heads, field_node);
  let ast_count: own u64 = deref(ast).count;
  let ast_field_atom: own AstKind = AstField();
  let first: own u64 = index<u64>(deref(ast).first_children, struct_decl);
  let last: own u64 = index<u64>(deref(ast).last_children, struct_decl);
  let child: own u64 = first;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_index_field_scan {
    match ilt<u64>(child, ast_count) {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
    let child_kind: own AstKind = index<AstKind>(deref(ast).kinds, child);
    let is_field: own Bool = eeq<AstKind>(child_kind, ast_field_atom);
    match is_field {
      True() => {
        let fhead: own u64 = index<u64>(deref(ast).heads, child);
        let same: own Bool = token_text_equal(source: source, tokens: tokens, left: fhead, right: field_name_head);
        match same {
          True() => {
            let fieldtype: own u64 = index<u64>(deref(ast).first_children, child);
            let ft_shape: own Bool = semantic_body_exact_children(ast: ast, node: fieldtype, want: 1_u64);
            match ft_shape {
              True() => {
              }
              False() => {
                return semantic_facts_none;
              }
            }
            let ft_head: own u64 = index<u64>(deref(ast).heads, fieldtype);
            let buffer_word: own Bool = parser_word6(source: source, tokens: tokens, token: ft_head, a: 98_u8, b: 117_u8, c: 102_u8, d: 102_u8, e: 101_u8, f: 114_u8);
            match buffer_word {
              True() => {
              }
              False() => {
                return semantic_facts_none;
              }
            }
            let element: own u64 = semantic_body_child_at(ast: ast, node: fieldtype, ordinal: 0_u64);
            let elem_u8: own Bool = semantic_body_node_is_u8(source: source, tokens: tokens, ast: ast, node: element);
            match elem_u8 {
              True() => {
                return semantic_buffer_type_u8;
              }
              False() => {
              }
            }
            let elem_u64: own Bool = semantic_buffer_node_is_u64(source: source, tokens: tokens, ast: ast, node: element);
            match elem_u64 {
              True() => {
                return semantic_buffer_type_u64;
              }
              False() => {
              }
            }
            let ast_nested_type_atom: own AstKind = AstNestedType();
            let element_kind: own Bool = semantic_body_kind_is(ast: ast, node: element, want: ast_nested_type_atom);
            match element_kind {
              True() => {
              }
              False() => {
                return semantic_facts_none;
              }
            }
            let enum_id: own u64 = semantic_reader_leaf_enum_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: element);
            match ieq<u64>(enum_id, semantic_facts_none) {
              True() => {
                return semantic_facts_none;
              }
              False() => {
                return enum_id;
              }
            }
          }
          False() => {
          }
        }
      }
      False() => {
      }
    }
    match ieq<u64>(child, last) {
      True() => {
        return semantic_facts_none;
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match ilt<u64>(next, ast_count) {
      True() => {
        set child = next;
      }
      False() => {
        return semantic_facts_none;
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
  }
}

fn semantic_reader_enum_decl_valid ['c] (ast: &'c AstTape, enum_decl: own u64) -> own Bool reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  match ilt<u64>(enum_decl, ast_count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let ast_enum_decl_atom: own AstKind = AstEnumDecl();
  return semantic_body_kind_is(ast: ast, node: enum_decl, want: ast_enum_decl_atom);
}

fn semantic_reader_struct_decl_valid ['c] (ast: &'c AstTape, struct_decl: own u64) -> own Bool reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
