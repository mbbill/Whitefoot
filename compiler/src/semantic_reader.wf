          }
        }
        set count = iadd.trap<u64>(count, 1_u64);
      }
      False() => {
        match is_name {
          True() => {
            let name_first: own Bool = ieq<u64>(name_count, 0_u64);
            let variants_empty: own Bool = ieq<u64>(count, 0_u64);
            match band<Bool>(name_first, variants_empty) {
