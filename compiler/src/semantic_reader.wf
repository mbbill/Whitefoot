      let base: own u64 = semantic_body_child_at(ast: ast, node: expr, ordinal: 1_u64);
      let ast_deref_place_atom: own AstKind = AstDerefPlace();
      let base_is_deref: own Bool = semantic_body_kind_is(ast: ast, node: base, want: ast_deref_place_atom);
      let region: own u64 = ast_none;
      match base_is_deref {
        True() => {
          let place: own u64 = semantic_body_child_at(ast: ast, node: base, ordinal: 0_u64);
          let place_head: own u64 = index<u64>(deref(ast).heads, place);
