fn semantic_reader_analyze_match ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, region_token: own u64, return_type: own u64, statement: own u64, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own SemanticReaderFlow reads('c 'w), writes('w), traps {
  let match_shape: own Bool = semantic_body_exact_children(ast: ast, node: statement, want: 3_u64);
  let match_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: statement);
  match band<Bool>(match_shape, match_token) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = statement;
      return SemanticReaderFlowError();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, statement);
  let match_word: own Bool = parser_word5(source: source, tokens: tokens, token: head, a: 109_u8, b: 97_u8, c: 116_u8, d: 99_u8, e: 104_u8);
  match match_word {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = head;
      return SemanticReaderFlowError();
    }
  }
  let scrutinee: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 0_u64);
  let true_arm: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 1_u64);
  let false_arm: own u64 = semantic_body_child_at(ast: ast, node: statement, ordinal: 2_u64);

  let scrutinee_type: own u64 = semantic_facts_none;
  region 'semantic_reader_match_scrutinee {
    set scrutinee_type = semantic_reader_analyze_expr(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, node: scrutinee, scratch: &'semantic_reader_match_scrutinee deref(scratch), report: &uniq 'semantic_reader_match_scrutinee deref(report));
  }
  match ieq<u64>(scrutinee_type, semantic_facts_none) {
    True() => {
      return SemanticReaderFlowError();
    }
    False() => {
    }
  }
  match ieq<u64>(scrutinee_type, semantic_buffer_type_bool) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = scrutinee;
      set deref(report).related = statement;
      return SemanticReaderFlowError();
    }
  }

  let true_true: own Bool = True();
  let true_arm_ok: own Bool = semantic_reader_arm_valid(source: source, tokens: tokens, ast: ast, arm: true_arm, truth: true_true);
  let false_false: own Bool = False();
  let false_arm_ok: own Bool = semantic_reader_arm_valid(source: source, tokens: tokens, ast: ast, arm: false_arm, truth: false_false);
  match band<Bool>(true_arm_ok, false_arm_ok) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = statement;
      set deref(report).related = true_arm;
      return SemanticReaderFlowError();
    }
  }

  let true_block: own u64 = semantic_body_child_at(ast: ast, node: true_arm, ordinal: 0_u64);
  let false_block: own u64 = semantic_body_child_at(ast: ast, node: false_arm, ordinal: 0_u64);

  let true_saved: own u64 = deref(scratch).count;
  let true_flow: own SemanticReaderFlow = SemanticReaderFlowError();
  region 'semantic_reader_match_true {
    set true_flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, return_type: return_type, block: true_block, scratch: &uniq 'semantic_reader_match_true deref(scratch), report: &uniq 'semantic_reader_match_true deref(report));
  }
  set deref(scratch).count = true_saved;
  let true_returns: own Bool = False();
  match true_flow {
    SemanticReaderFlowReturns() => {
      set true_returns = True();
    }
    SemanticReaderFlowFalls() => {
    }
    SemanticReaderFlowError() => {
      return SemanticReaderFlowError();
    }
  }

  let false_saved: own u64 = deref(scratch).count;
  let false_flow: own SemanticReaderFlow = SemanticReaderFlowError();
  region 'semantic_reader_match_false {
    set false_flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, return_type: return_type, block: false_block, scratch: &uniq 'semantic_reader_match_false deref(scratch), report: &uniq 'semantic_reader_match_false deref(report));
  }
  set deref(scratch).count = false_saved;
  let false_returns: own Bool = False();
  match false_flow {
    SemanticReaderFlowReturns() => {
      set false_returns = True();
    }
    SemanticReaderFlowFalls() => {
    }
    SemanticReaderFlowError() => {
      return SemanticReaderFlowError();
    }
  }

  match band<Bool>(true_returns, false_returns) {
    True() => {
      return SemanticReaderFlowReturns();
    }
    False() => {
      return SemanticReaderFlowFalls();
    }
  }
}

fn semantic_reader_analyze_block ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, region_token: own u64, return_type: own u64, block: own u64, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own SemanticReaderFlow reads('c 'w), writes('w), traps {
  let ast_block_atom: own AstKind = AstBlock();
  let block_kind: own Bool = semantic_body_kind_is(ast: ast, node: block, want: ast_block_atom);
  let block_token: own Bool = semantic_buffer_single_symbol_node(source: source, tokens: tokens, ast: ast, node: block, want: 123_u8);
  match band<Bool>(block_kind, block_token) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = block;
      set deref(report).related = block;
      return SemanticReaderFlowError();
    }
  }
  let ast_count: own u64 = deref(ast).count;
  let statement: own u64 = index<u64>(deref(ast).first_children, block);
  let last_statement: own u64 = index<u64>(deref(ast).last_children, block);
  let first_none: own Bool = ieq<u64>(statement, ast_none);
  let last_none: own Bool = ieq<u64>(last_statement, ast_none);
  match band<Bool>(first_none, last_none) {
    True() => {
      return SemanticReaderFlowFalls();
    }
    False() => {
    }
  }
  match bor<Bool>(first_none, last_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = block;
      set deref(report).related = statement;
      return SemanticReaderFlowError();
    }
    False() => {
    }
  }

  let flow: own SemanticReaderFlow = SemanticReaderFlowFalls();
  let block_steps: own u64 = 0_u64;
  loop @semantic_reader_block_statements {
    match ilt<u64>(statement, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = block;
        set deref(report).related = statement;
        return SemanticReaderFlowError();
      }
    }
    let statement_kind: own AstKind = index<AstKind>(deref(ast).kinds, statement);
    let at_last: own Bool = ieq<u64>(statement, last_statement);
    let next_statement: own u64 = index<u64>(deref(ast).next_siblings, statement);

    let ast_let_atom: own AstKind = AstLet();
    let is_let: own Bool = ieq<AstKind>(statement_kind, ast_let_atom);
    let ast_match_atom: own AstKind = AstMatch();
    let is_match: own Bool = ieq<AstKind>(statement_kind, ast_match_atom);
    let ast_return_atom: own AstKind = AstReturn();
    let is_return: own Bool = ieq<AstKind>(statement_kind, ast_return_atom);

    let statement_flow: own SemanticReaderFlow = SemanticReaderFlowFalls();
    let statement_error: own Bool = False();

    match is_let {
      True() => {
        let let_clean: own Bool = False();
        region 'semantic_reader_stmt_let {
          set let_clean = semantic_reader_analyze_let(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, statement: statement, scratch: &uniq 'semantic_reader_stmt_let deref(scratch), report: &uniq 'semantic_reader_stmt_let deref(report));
        }
        match let_clean {
          True() => {
            set statement_flow = SemanticReaderFlowFalls();
          }
          False() => {
            set statement_error = True();
          }
        }
      }
      False() => {
        match is_match {
          True() => {
            region 'semantic_reader_stmt_match {
              set statement_flow = semantic_reader_analyze_match(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, return_type: return_type, statement: statement, scratch: &uniq 'semantic_reader_stmt_match deref(scratch), report: &uniq 'semantic_reader_stmt_match deref(report));
            }
          }
          False() => {
            match is_return {
              True() => {
                let return_clean: own Bool = False();
                region 'semantic_reader_stmt_return {
                  set return_clean = semantic_reader_analyze_return(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, return_type: return_type, statement: statement, scratch: &uniq 'semantic_reader_stmt_return deref(scratch), report: &uniq 'semantic_reader_stmt_return deref(report));
                }
                match return_clean {
                  True() => {
                    set statement_flow = SemanticReaderFlowReturns();
                  }
                  False() => {
                    set statement_error = True();
                  }
                }
              }
              False() => {
                set statement_error = True();
                let unknown_head: own u64 = index<u64>(deref(ast).heads, statement);
                set deref(report).status = SemanticBodyUnsupported();
                set deref(report).node = statement;
                set deref(report).related = unknown_head;
              }
            }
          }
        }
      }
    }

    match statement_error {
      True() => {
        return SemanticReaderFlowError();
      }
      False() => {
      }
    }

    let statement_returns: own Bool = False();
    match statement_flow {
      SemanticReaderFlowReturns() => {
        set statement_returns = True();
      }
      SemanticReaderFlowFalls() => {
      }
      SemanticReaderFlowError() => {
        return SemanticReaderFlowError();
      }
    }

    match at_last {
      True() => {
        match ieq<u64>(next_statement, ast_none) {
          True() => {
            set flow = statement_flow;
            break @semantic_reader_block_statements;
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = block;
            set deref(report).related = next_statement;
            return SemanticReaderFlowError();
          }
        }
      }
      False() => {
        match statement_returns {
          True() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = statement;
            set deref(report).related = next_statement;
            return SemanticReaderFlowError();
          }
          False() => {
          }
        }
        match ilt<u64>(next_statement, ast_count) {
          True() => {
            set statement = next_statement;
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = block;
            set deref(report).related = next_statement;
            return SemanticReaderFlowError();
          }
        }
      }
    }
    set block_steps = iadd.trap<u64>(block_steps, 1_u64);
    match ilt<u64>(block_steps, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = block;
        set deref(report).related = block_steps;
        return SemanticReaderFlowError();
      }
    }
  }
  return flow;
}

fn semantic_reader_signature_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64) -> own Bool reads('c), traps {
