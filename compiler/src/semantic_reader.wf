fn semantic_reader_arg_matches ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, scratch: &'w SemanticBodyScratch, actual: own u64, expected_type: own u64, expected_mode: own SemanticValueMode, expected_region: own u64) -> own Bool reads('c 'w), traps {
