      return table_type;
    }
    False() => {
    }
  }
  let ast_index_place_atom: own AstKind = AstIndexPlace();
  let is_index: own Bool = ieq<AstKind>(node_kind, ast_index_place_atom);
  match is_index {
    True() => {
      let index_type: own u64 = semantic_facts_none;
      region 'semantic_reader_expr_index {
        set index_type = semantic_reader_analyze_index(source: source, tokens: tokens, ast: ast, scratch: scratch, node: node, report: &uniq 'semantic_reader_expr_index deref(report));
      }
      return index_type;
    }
    False() => {
    }
  }
  let ast_user_call_atom: own AstKind = AstUserCall();
  let is_call: own Bool = ieq<AstKind>(node_kind, ast_user_call_atom);
  match is_call {
