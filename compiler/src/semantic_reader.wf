        False() => {
        }
      }
    }
    False() => {
    }
  }

  let ast_count: own u64 = deref(ast).count;
  let function_first: own u64 = index<u64>(deref(ast).first_children, function);
  let function_last: own u64 = index<u64>(deref(ast).last_children, function);
  let function_first_none: own Bool = ieq<u64>(function_first, ast_none);
  let function_last_none: own Bool = ieq<u64>(function_last, ast_none);
  match bor<Bool>(function_first_none, function_last_none) {
    True() => {
      return False();
    }
    False() => {
    }
  }

  let ast_region_parameters_atom: own AstKind = AstRegionParameters();
  let ast_parameter_atom: own AstKind = AstParameter();
  let ast_own_mode_atom: own AstKind = AstOwnMode();
  let ast_return_type_atom: own AstKind = AstReturnType();
  let ast_pure_effect_atom: own AstKind = AstPureEffect();
  let ast_reads_effect_atom: own AstKind = AstReadsEffect();
  let ast_traps_effect_atom: own AstKind = AstTrapsEffect();
  let ast_block_atom: own AstKind = AstBlock();

  let name_count: own u64 = 0_u64;
  let regions_node: own u64 = ast_none;
  let regions_count: own u64 = 0_u64;
  let params_ok: own Bool = True();
  let return_mode_node: own u64 = ast_none;
  let return_mode_count: own u64 = 0_u64;
  let return_type_node: own u64 = ast_none;
  let return_type_count: own u64 = 0_u64;
  let pure_seen: own Bool = False();
  let reads_node: own u64 = ast_none;
  let reads_count: own u64 = 0_u64;
  let traps_seen: own Bool = False();
  let block_node: own u64 = ast_none;
  let block_count: own u64 = 0_u64;
  let other_child: own Bool = False();

  let scan_child: own u64 = function_first;
  let scan_steps: own u64 = 0_u64;
  loop @semantic_reader_signature_scan {
    match ilt<u64>(scan_child, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let scan_kind: own AstKind = index<AstKind>(deref(ast).kinds, scan_child);
    let ast_function_name_atom_scan: own AstKind = AstFunctionName();
    let is_name: own Bool = eeq<AstKind>(scan_kind, ast_function_name_atom_scan);
    match is_name {
      True() => {
        set name_count = iadd.trap<u64>(name_count, 1_u64);
      }
      False() => {
      }
    }
    let is_region: own Bool = eeq<AstKind>(scan_kind, ast_region_parameters_atom);
    match is_region {
      True() => {
        set regions_node = scan_child;
        set regions_count = iadd.trap<u64>(regions_count, 1_u64);
      }
      False() => {
      }
    }
    let is_param: own Bool = eeq<AstKind>(scan_kind, ast_parameter_atom);
    match is_param {
      True() => {
        let admitted: own Bool = semantic_reader_admitted_param(source: source, tokens: tokens, ast: ast, symbols: symbols, parameter: scan_child, regions_node: regions_node);
        match admitted {
          True() => {
          }
          False() => {
            set params_ok = False();
          }
        }
      }
      False() => {
      }
    }
    let is_return_mode: own Bool = eeq<AstKind>(scan_kind, ast_own_mode_atom);
    match is_return_mode {
      True() => {
        set return_mode_node = scan_child;
        set return_mode_count = iadd.trap<u64>(return_mode_count, 1_u64);
      }
      False() => {
      }
    }
    let is_return_type: own Bool = eeq<AstKind>(scan_kind, ast_return_type_atom);
    match is_return_type {
      True() => {
        set return_type_node = scan_child;
        set return_type_count = iadd.trap<u64>(return_type_count, 1_u64);
      }
      False() => {
      }
    }
    let is_pure: own Bool = eeq<AstKind>(scan_kind, ast_pure_effect_atom);
    match is_pure {
      True() => {
        set pure_seen = True();
      }
      False() => {
      }
    }
    let is_reads: own Bool = eeq<AstKind>(scan_kind, ast_reads_effect_atom);
    match is_reads {
      True() => {
        set reads_node = scan_child;
        set reads_count = iadd.trap<u64>(reads_count, 1_u64);
      }
      False() => {
      }
    }
    let is_traps: own Bool = eeq<AstKind>(scan_kind, ast_traps_effect_atom);
    match is_traps {
      True() => {
        set traps_seen = True();
      }
      False() => {
      }
    }
    let is_block: own Bool = eeq<AstKind>(scan_kind, ast_block_atom);
    match is_block {
      True() => {
        set block_node = scan_child;
        set block_count = iadd.trap<u64>(block_count, 1_u64);
      }
      False() => {
      }
    }
    let recognized_a: own Bool = bor<Bool>(is_name, is_region);
    let recognized_b: own Bool = bor<Bool>(is_param, is_return_mode);
    let recognized_c: own Bool = bor<Bool>(is_return_type, is_pure);
    let recognized_d: own Bool = bor<Bool>(is_reads, is_traps);
    let recognized_ab: own Bool = bor<Bool>(recognized_a, recognized_b);
    let recognized_cd: own Bool = bor<Bool>(recognized_c, recognized_d);
    let recognized_abcd: own Bool = bor<Bool>(recognized_ab, recognized_cd);
    let recognized: own Bool = bor<Bool>(recognized_abcd, is_block);
    match recognized {
      True() => {
      }
      False() => {
        set other_child = True();
      }
    }
    match ieq<u64>(scan_child, function_last) {
      True() => {
        break @semantic_reader_signature_scan;
      }
      False() => {
      }
    }
    let scan_next: own u64 = index<u64>(deref(ast).next_siblings, scan_child);
    match ilt<u64>(scan_next, ast_count) {
      True() => {
        set scan_child = scan_next;
      }
      False() => {
        return False();
      }
    }
    set scan_steps = iadd.trap<u64>(scan_steps, 1_u64);
    match ilt<u64>(scan_steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }

  let name_ok: own Bool = ieq<u64>(name_count, 1_u64);
  let regions_single: own Bool = ilt<u64>(regions_count, 2_u64);
  let return_mode_one: own Bool = ieq<u64>(return_mode_count, 1_u64);
  let return_type_one: own Bool = ieq<u64>(return_type_count, 1_u64);
  let block_one: own Bool = ieq<u64>(block_count, 1_u64);
  let reads_single: own Bool = ilt<u64>(reads_count, 2_u64);
  let no_other: own Bool = bnot<Bool>(other_child);
  let struct_a: own Bool = band<Bool>(name_ok, regions_single);
  let struct_b: own Bool = band<Bool>(return_mode_one, return_type_one);
  let struct_c: own Bool = band<Bool>(block_one, reads_single);
  let struct_d: own Bool = band<Bool>(no_other, params_ok);
  let struct_ab: own Bool = band<Bool>(struct_a, struct_b);
  let struct_cd: own Bool = band<Bool>(struct_c, struct_d);
  match band<Bool>(struct_ab, struct_cd) {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let reader_return_mode_kind: own Bool = semantic_body_kind_is(ast: ast, node: return_mode_node, want: ast_own_mode_atom);
  let reader_return_mode_valid: own Bool = semantic_function_mode_valid(source: source, tokens: tokens, ast: ast, node: return_mode_node);
  let reader_return_mode_ok: own Bool = band<Bool>(reader_return_mode_kind, reader_return_mode_valid);
  let reader_return_type: own u64 = semantic_reader_return_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, node: return_type_node);
  let reader_return_type_valid: own Bool = ine<u64>(reader_return_type, semantic_facts_none);
  match band<Bool>(reader_return_mode_ok, reader_return_type_valid) {
    True() => {
    }
    False() => {
      return False();
    }
  }

  let has_regions: own Bool = ine<u64>(regions_node, ast_none);
  match has_regions {
    True() => {
      let regions_ok: own Bool = semantic_reader_regions_valid(source: source, tokens: tokens, ast: ast, regions_node: regions_node);
      match regions_ok {
        True() => {
        }
        False() => {
          return False();
        }
      }
    }
    False() => {
    }
  }

  let reads_present: own Bool = ine<u64>(reads_node, ast_none);
  let no_reads: own Bool = bnot<Bool>(reads_present);
  let no_traps: own Bool = bnot<Bool>(traps_seen);
  let no_pure: own Bool = bnot<Bool>(pure_seen);
  let effect_pure_a: own Bool = band<Bool>(pure_seen, no_reads);
  let effect_pure: own Bool = band<Bool>(effect_pure_a, no_traps);
  let effect_reads: own Bool = band<Bool>(reads_present, no_pure);
  let effect_traps_a: own Bool = band<Bool>(traps_seen, no_pure);
  let effect_traps: own Bool = band<Bool>(effect_traps_a, no_reads);
  let effect_pure_or_reads: own Bool = bor<Bool>(effect_pure, effect_reads);
  match bor<Bool>(effect_pure_or_reads, effect_traps) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  match effect_reads {
    True() => {
      let ast_reads_effect_atom_check: own AstKind = AstReadsEffect();
      let reads_kind: own Bool = semantic_body_kind_is(ast: ast, node: reads_node, want: ast_reads_effect_atom_check);
      let reads_word: own Bool = semantic_function_effect_word_valid(source: source, tokens: tokens, ast: ast, node: reads_node, code: 1_u64);
      let reads_head_ok: own Bool = band<Bool>(reads_kind, reads_word);
      match reads_head_ok {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let reads_regions_ok: own Bool = semantic_reader_reads_regions_declared(source: source, tokens: tokens, ast: ast, reads_node: reads_node, regions_node: regions_node);
      match reads_regions_ok {
        True() => {
        }
        False() => {
          return False();
        }
      }
    }
    False() => {
    }
  }

  let reader_block_kind: own Bool = semantic_body_kind_is(ast: ast, node: block_node, want: ast_block_atom);
  let reader_block_token: own Bool = semantic_buffer_single_symbol_node(source: source, tokens: tokens, ast: ast, node: block_node, want: 123_u8);
  return band<Bool>(reader_block_kind, reader_block_token);
}

fn semantic_reader_op_traps ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, op_token: own u64) -> own Bool reads('c), traps {
  let valid: own Bool = token_ordinal_valid(source: source, tokens: tokens, token: op_token);
  match valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, op_token);
  let end: own u64 = index<u64>(deref(tokens).ends, op_token);
  let width: own u64 = isub.wrap<u64>(end, start);
  let width_ok: own Bool = ige<u64>(width, 5_u64);
  match width_ok {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let p0: own u64 = isub.wrap<u64>(end, 5_u64);
  let p1: own u64 = isub.wrap<u64>(end, 4_u64);
  let p2: own u64 = isub.wrap<u64>(end, 3_u64);
  let p3: own u64 = isub.wrap<u64>(end, 2_u64);
  let p4: own u64 = isub.wrap<u64>(end, 1_u64);
  let b0: own u8 = index<u8>(deref(source), p0);
  let b1: own u8 = index<u8>(deref(source), p1);
  let b2: own u8 = index<u8>(deref(source), p2);
  let b3: own u8 = index<u8>(deref(source), p3);
  let b4: own u8 = index<u8>(deref(source), p4);
  let e0: own Bool = ieq<u8>(b0, 46_u8);
  let e1: own Bool = ieq<u8>(b1, 116_u8);
  let e2: own Bool = ieq<u8>(b2, 114_u8);
  let e3: own Bool = ieq<u8>(b3, 97_u8);
  let e4: own Bool = ieq<u8>(b4, 112_u8);
  let e01: own Bool = band<Bool>(e0, e1);
  let e23: own Bool = band<Bool>(e2, e3);
  let e0123: own Bool = band<Bool>(e01, e23);
  return band<Bool>(e0123, e4);
}

fn semantic_reader_function_param_region ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64, name_head: own u64) -> own u64 reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  let first: own u64 = index<u64>(deref(ast).first_children, function);
  let last: own u64 = index<u64>(deref(ast).last_children, function);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  match bor<Bool>(first_none, last_none) {
    True() => {
      return ast_none;
    }
    False() => {
    }
  }
  let ast_parameter_atom: own AstKind = AstParameter();
  let ast_shared_mode_atom: own AstKind = AstSharedMode();
  let child: own u64 = first;
  let steps: own u64 = 0_u64;
  loop @semantic_reader_param_region_scan {
    match ilt<u64>(child, ast_count) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
    let child_kind: own AstKind = index<AstKind>(deref(ast).kinds, child);
    let is_param: own Bool = eeq<AstKind>(child_kind, ast_parameter_atom);
    match is_param {
      True() => {
        let param_name_head: own u64 = index<u64>(deref(ast).heads, child);
        let same: own Bool = token_text_equal(source: source, tokens: tokens, left: name_head, right: param_name_head);
        match same {
          True() => {
            let mode_node: own u64 = semantic_body_child_at(ast: ast, node: child, ordinal: 0_u64);
            let mode_is_shared: own Bool = semantic_body_kind_is(ast: ast, node: mode_node, want: ast_shared_mode_atom);
            match mode_is_shared {
              True() => {
                let region_node: own u64 = semantic_body_child_at(ast: ast, node: mode_node, ordinal: 0_u64);
                return index<u64>(deref(ast).heads, region_node);
              }
              False() => {
                return ast_none;
              }
            }
          }
          False() => {
          }
        }
      }
      False() => {
      }
    }
    match ieq<u64>(child, last) {
      True() => {
        return ast_none;
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match ilt<u64>(next, ast_count) {
      True() => {
        set child = next;
      }
      False() => {
        return ast_none;
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
  }
}

fn semantic_reader_call_effects ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, call_node: own u64) -> own u64 reads('c), traps {
  let call_head: own u64 = index<u64>(deref(ast).heads, call_node);
  let symbol_value_atom: own SymbolNamespace = SymbolValue();
  let lookup: own SymbolLookupResult = symbol_lookup_in_scope(source: source, tokens: tokens, symbols: symbols, space: symbol_value_atom, scope: symbol_none, name_token: call_head);
  match lookup.status {
    SymbolLookupFound() => {
    }
    SymbolLookupNotFound() => {
      return 3_u64;
    }
    SymbolLookupInvalidTape() => {
      return 3_u64;
    }
    SymbolLookupInvalidToken() => {
      return 3_u64;
    }
  }
  let callee: own u64 = lookup.declaration;
  let ast_count: own u64 = deref(ast).count;
  let first: own u64 = index<u64>(deref(ast).first_children, callee);
  let last: own u64 = index<u64>(deref(ast).last_children, callee);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  match bor<Bool>(first_none, last_none) {
    True() => {
      return 3_u64;
    }
    False() => {
    }
  }
  let child: own u64 = first;
  let steps: own u64 = 0_u64;
  let ast_reads_effect_atom_call_scan: own AstKind = AstReadsEffect();
  let ast_traps_effect_atom_call_scan: own AstKind = AstTrapsEffect();
  let ast_block_atom_call_scan: own AstKind = AstBlock();
  loop @semantic_reader_call_effect_scan {
    match ilt<u64>(child, ast_count) {
      True() => {
      }
      False() => {
        return 3_u64;
      }
    }
    let child_kind: own AstKind = index<AstKind>(deref(ast).kinds, child);
    let is_reads: own Bool = eeq<AstKind>(child_kind, ast_reads_effect_atom_call_scan);
    match is_reads {
      True() => {
        match ieq<u64>(child, last) {
          True() => {
            return 3_u64;
          }
          False() => {
          }
        }
        let effect_next: own u64 = index<u64>(deref(ast).next_siblings, child);
        match ilt<u64>(effect_next, ast_count) {
          True() => {
          }
          False() => {
            return 3_u64;
          }
        }
        let effect_next_kind: own AstKind = index<AstKind>(deref(ast).kinds, effect_next);
        let reads_with_traps: own Bool = eeq<AstKind>(effect_next_kind, ast_traps_effect_atom_call_scan);
        match reads_with_traps {
          True() => {
            return 3_u64;
          }
          False() => {
          }
        }
        let reads_only: own Bool = eeq<AstKind>(effect_next_kind, ast_block_atom_call_scan);
        match reads_only {
          True() => {
            return 1_u64;
          }
          False() => {
            return 3_u64;
          }
        }
      }
      False() => {
      }
    }
    let is_traps: own Bool = eeq<AstKind>(child_kind, ast_traps_effect_atom_call_scan);
    match is_traps {
      True() => {
        return 2_u64;
      }
      False() => {
      }
    }
    match ieq<u64>(child, last) {
      True() => {
        return 0_u64;
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match ilt<u64>(next, ast_count) {
      True() => {
        set child = next;
      }
      False() => {
        return 3_u64;
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return 3_u64;
      }
    }
  }
}

fn semantic_reader_expr_effect ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, region_token: own u64, reads_node: own u64, want_region: own u64, mode: own u64, expr: own u64) -> own Bool reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  match ilt<u64>(expr, ast_count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let kind: own AstKind = index<AstKind>(deref(ast).kinds, expr);
  let ast_index_place_atom: own AstKind = AstIndexPlace();
  let is_index: own Bool = eeq<AstKind>(kind, ast_index_place_atom);
  match is_index {
    True() => {
      match ieq<u64>(mode, semantic_reader_effect_user_call) {
