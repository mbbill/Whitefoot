const semantic_reader_enum_type_base: u64 = 1000000000_u64;
const semantic_reader_struct_type_base: u64 = 2000000000_u64;

const semantic_reader_effect_traps: u64 = 0_u64;
const semantic_reader_effect_undeclared: u64 = 1_u64;
const semantic_reader_effect_reads_region: u64 = 2_u64;
const semantic_reader_effect_user_call: u64 = 3_u64;

enum SemanticReaderFlow {
  SemanticReaderFlowReturns();
  SemanticReaderFlowFalls();
  SemanticReaderFlowBreaks();
  SemanticReaderFlowFallsOrReturns();
  SemanticReaderFlowFallsOrBreaks();
  SemanticReaderFlowReturnsOrBreaks();
  SemanticReaderFlowFallsOrReturnsOrBreaks();
  SemanticReaderFlowError();
}

fn semantic_reader_flow_has_fall (flow: own SemanticReaderFlow) -> own Bool pure {
  match flow {
    SemanticReaderFlowReturns() => {
      return False();
    }
    SemanticReaderFlowFalls() => {
      return True();
    }
    SemanticReaderFlowBreaks() => {
      return False();
    }
    SemanticReaderFlowFallsOrReturns() => {
      return True();
    }
    SemanticReaderFlowFallsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowReturnsOrBreaks() => {
      return False();
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowError() => {
      return False();
    }
  }
}

fn semantic_reader_flow_has_return (flow: own SemanticReaderFlow) -> own Bool pure {
  match flow {
    SemanticReaderFlowReturns() => {
      return True();
    }
    SemanticReaderFlowFalls() => {
      return False();
    }
    SemanticReaderFlowBreaks() => {
      return False();
    }
    SemanticReaderFlowFallsOrReturns() => {
      return True();
    }
    SemanticReaderFlowFallsOrBreaks() => {
      return False();
    }
    SemanticReaderFlowReturnsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowError() => {
      return False();
    }
  }
}

fn semantic_reader_flow_has_break (flow: own SemanticReaderFlow) -> own Bool pure {
  match flow {
    SemanticReaderFlowReturns() => {
      return False();
    }
    SemanticReaderFlowFalls() => {
      return False();
    }
    SemanticReaderFlowBreaks() => {
      return True();
    }
    SemanticReaderFlowFallsOrReturns() => {
      return False();
    }
    SemanticReaderFlowFallsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowReturnsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
      return True();
    }
    SemanticReaderFlowError() => {
      return False();
    }
  }
}

fn semantic_reader_flow_from_flags (falls: own Bool, returns: own Bool, breaks: own Bool) -> own SemanticReaderFlow pure {
  match falls {
    True() => {
      match returns {
        True() => {
          match breaks {
            True() => {
              return SemanticReaderFlowFallsOrReturnsOrBreaks();
            }
            False() => {
              return SemanticReaderFlowFallsOrReturns();
            }
          }
        }
        False() => {
          match breaks {
            True() => {
              return SemanticReaderFlowFallsOrBreaks();
            }
            False() => {
              return SemanticReaderFlowFalls();
            }
          }
        }
      }
    }
    False() => {
      match returns {
        True() => {
          match breaks {
            True() => {
              return SemanticReaderFlowReturnsOrBreaks();
            }
            False() => {
              return SemanticReaderFlowReturns();
            }
          }
        }
        False() => {
          match breaks {
            True() => {
              return SemanticReaderFlowBreaks();
            }
            False() => {
              return SemanticReaderFlowError();
            }
          }
        }
      }
    }
  }
}

fn semantic_reader_flow_join (left: own SemanticReaderFlow, right: own SemanticReaderFlow) -> own SemanticReaderFlow pure {
  match left {
    SemanticReaderFlowError() => {
      return SemanticReaderFlowError();
    }
    SemanticReaderFlowReturns() => {
    }
    SemanticReaderFlowFalls() => {
    }
    SemanticReaderFlowBreaks() => {
    }
    SemanticReaderFlowFallsOrReturns() => {
    }
    SemanticReaderFlowFallsOrBreaks() => {
    }
    SemanticReaderFlowReturnsOrBreaks() => {
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
    }
  }
  match right {
    SemanticReaderFlowError() => {
      return SemanticReaderFlowError();
    }
    SemanticReaderFlowReturns() => {
    }
    SemanticReaderFlowFalls() => {
    }
    SemanticReaderFlowBreaks() => {
    }
    SemanticReaderFlowFallsOrReturns() => {
    }
    SemanticReaderFlowFallsOrBreaks() => {
    }
    SemanticReaderFlowReturnsOrBreaks() => {
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
    }
  }
  let left_falls: own Bool = semantic_reader_flow_has_fall(flow: left);
  let right_falls: own Bool = semantic_reader_flow_has_fall(flow: right);
  let falls: own Bool = bor<Bool>(left_falls, right_falls);
  let left_returns: own Bool = semantic_reader_flow_has_return(flow: left);
  let right_returns: own Bool = semantic_reader_flow_has_return(flow: right);
  let returns: own Bool = bor<Bool>(left_returns, right_returns);
  let left_breaks: own Bool = semantic_reader_flow_has_break(flow: left);
  let right_breaks: own Bool = semantic_reader_flow_has_break(flow: right);
  let breaks: own Bool = bor<Bool>(left_breaks, right_breaks);
  return semantic_reader_flow_from_flags(falls: falls, returns: returns, breaks: breaks);
}

fn semantic_reader_flow_then (before: own SemanticReaderFlow, statement: own SemanticReaderFlow) -> own SemanticReaderFlow pure {
  match before {
    SemanticReaderFlowError() => {
      return SemanticReaderFlowError();
    }
    SemanticReaderFlowReturns() => {
    }
    SemanticReaderFlowFalls() => {
    }
    SemanticReaderFlowBreaks() => {
    }
    SemanticReaderFlowFallsOrReturns() => {
    }
    SemanticReaderFlowFallsOrBreaks() => {
    }
    SemanticReaderFlowReturnsOrBreaks() => {
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
    }
  }
  match statement {
    SemanticReaderFlowError() => {
      return SemanticReaderFlowError();
    }
    SemanticReaderFlowReturns() => {
    }
    SemanticReaderFlowFalls() => {
    }
    SemanticReaderFlowBreaks() => {
    }
    SemanticReaderFlowFallsOrReturns() => {
    }
    SemanticReaderFlowFallsOrBreaks() => {
    }
    SemanticReaderFlowReturnsOrBreaks() => {
    }
    SemanticReaderFlowFallsOrReturnsOrBreaks() => {
    }
  }
  let before_falls: own Bool = semantic_reader_flow_has_fall(flow: before);
  let statement_falls: own Bool = semantic_reader_flow_has_fall(flow: statement);
  let falls: own Bool = band<Bool>(before_falls, statement_falls);
  let statement_returns: own Bool = semantic_reader_flow_has_return(flow: statement);
  let reached_return: own Bool = band<Bool>(before_falls, statement_returns);
  let before_returns: own Bool = semantic_reader_flow_has_return(flow: before);
  let returns: own Bool = bor<Bool>(before_returns, reached_return);
  let statement_breaks: own Bool = semantic_reader_flow_has_break(flow: statement);
  let reached_break: own Bool = band<Bool>(before_falls, statement_breaks);
  let before_breaks: own Bool = semantic_reader_flow_has_break(flow: before);
  let breaks: own Bool = bor<Bool>(before_breaks, reached_break);
  return semantic_reader_flow_from_flags(falls: falls, returns: returns, breaks: breaks);
}

fn semantic_reader_isub_name_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, token: own u64) -> own Bool reads('c), traps {
  let valid: own Bool = symbol_name_token_valid(source: source, tokens: tokens, token: token, want_kind: 2_u64);
  match valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, token);
  let end: own u64 = index<u64>(deref(tokens).ends, token);
  let width: own u64 = isub.wrap<u64>(end, start);
  match ieq<u64>(width, 9_u64) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let e0: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 0_u64, want: 105_u8);
  let e1: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 1_u64, want: 115_u8);
  let e2: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 2_u64, want: 117_u8);
  let e3: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 3_u64, want: 98_u8);
  let e4: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 4_u64, want: 46_u8);
  let e5: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 5_u64, want: 119_u8);
  let e6: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 6_u64, want: 114_u8);
  let e7: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 7_u64, want: 97_u8);
  let e8: own Bool = parser_word_byte(source: source, tokens: tokens, token: token, offset: 8_u64, want: 112_u8);
  let p0: own Bool = band<Bool>(e0, e1);
  let p1: own Bool = band<Bool>(e2, e3);
  let p2: own Bool = band<Bool>(e4, e5);
  let p3: own Bool = band<Bool>(e6, e7);
  let q0: own Bool = band<Bool>(p0, p1);
  let q1: own Bool = band<Bool>(p2, p3);
  let q2: own Bool = band<Bool>(q0, q1);
  return band<Bool>(q2, e8);
}

fn semantic_reader_u64_literal_any ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let candidate: own u64 = 1_u64;
  loop @semantic_reader_u64_literal_scan {
    match igt<u64>(candidate, 9_u64) {
      True() => {
        return False();
      }
      False() => {
      }
    }
    let matched: own Bool = semantic_buffer_u64_literal_valid<'c>(source: source, tokens: tokens, ast: ast, node: node, value: candidate);
    match matched {
      True() => {
        return True();
      }
      False() => {
      }
    }
    set candidate = iadd.trap<u64>(candidate, 1_u64);
  }
}

fn semantic_reader_place_slot ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, scratch: &'w SemanticBodyScratch, node: own u64) -> own u64 reads('c 'w), traps {
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let place_kind: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_place_use_atom);
  let place_leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
  let place_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  let place_first: own Bool = band<Bool>(place_kind, place_leaf);
  let place_valid: own Bool = band<Bool>(place_first, place_token);
  match place_valid {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  return semantic_body_scope_find(source: source, tokens: tokens, scratch: scratch, name_token: head);
}

fn semantic_reader_place_type ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, scratch: &'w SemanticBodyScratch, node: own u64) -> own u64 reads('c 'w), traps {
  let slot: own u64 = semantic_reader_place_slot(source: source, tokens: tokens, ast: ast, scratch: scratch, node: node);
  match ieq<u64>(slot, semantic_facts_none) {
    True() => {
      return semantic_facts_none;
    }
    False() => {
    }
  }
  return index<u64>(deref(scratch).type_ids, slot);
}

fn semantic_reader_leaf_enum_id ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, node: own u64) -> own u64 reads('c), traps {
  let leaf_ok: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
  let token_ok: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  match band<Bool>(leaf_ok, token_ok) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let symbol_type_atom: own SymbolNamespace = SymbolType();
  let lookup: own SymbolLookupResult = symbol_lookup_in_scope(source: source, tokens: tokens, symbols: symbols, space: symbol_type_atom, scope: symbol_none, name_token: head);
  match lookup.status {
    SymbolLookupFound() => {
    }
    SymbolLookupNotFound() => {
      return semantic_facts_none;
    }
    SymbolLookupInvalidTape() => {
      return semantic_facts_none;
    }
    SymbolLookupInvalidToken() => {
      return semantic_facts_none;
    }
  }
  let enum_decl: own u64 = lookup.declaration;
  let decl_valid: own Bool = semantic_reader_enum_decl_valid(ast: ast, enum_decl: enum_decl);
  match decl_valid {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let variant_count: own u64 = semantic_reader_tag_only_enum_variant_count(source: source, tokens: tokens, ast: ast, enum_decl: enum_decl);
  match ine<u64>(variant_count, semantic_facts_none) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let enum_name: own u64 = index<u64>(deref(ast).first_children, enum_decl);
  let enum_name_head: own u64 = index<u64>(deref(ast).heads, enum_name);
  let name_matches: own Bool = token_text_equal(source: source, tokens: tokens, left: head, right: enum_name_head);
  match name_matches {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let enum_decl_limit: own u64 = isub.wrap<u64>(semantic_reader_struct_type_base, semantic_reader_enum_type_base);
  let enum_decl_in_range: own Bool = ilt<u64>(enum_decl, enum_decl_limit);
  match enum_decl_in_range {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  return iadd.trap<u64>(enum_decl, semantic_reader_enum_type_base);
}

