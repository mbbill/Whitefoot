          return bnot<Bool>(declared);
        }
        False() => {
        }
      }
      return token_text_equal(source: source, tokens: tokens, left: want_region, right: region);
    }
    False() => {
    }
  }
  let ast_field_place_atom_eff: own AstKind = AstFieldPlace();
  let is_field_eff: own Bool = eeq<AstKind>(kind, ast_field_place_atom_eff);
  match is_field_eff {
    True() => {
      match ieq<u64>(mode, semantic_reader_effect_user_call) {
        True() => {
          return False();
        }
        False() => {
        }
      }
      match ieq<u64>(mode, semantic_reader_effect_traps) {
        True() => {
          return False();
        }
        False() => {
        }
      }
      let fbase: own u64 = semantic_body_child_at(ast: ast, node: expr, ordinal: 0_u64);
      let ast_deref_place_atom_f: own AstKind = AstDerefPlace();
      let fbase_is_deref: own Bool = semantic_body_kind_is(ast: ast, node: fbase, want: ast_deref_place_atom_f);
      let fregion: own u64 = ast_none;
      match fbase_is_deref {
        True() => {
          let fplace: own u64 = semantic_body_child_at(ast: ast, node: fbase, ordinal: 0_u64);
          let fplace_head: own u64 = index<u64>(deref(ast).heads, fplace);
          set fregion = semantic_reader_function_param_region(source: source, tokens: tokens, ast: ast, function: function, name_head: fplace_head);
        }
        False() => {
        }
      }
      match ieq<u64>(mode, semantic_reader_effect_undeclared) {
        True() => {
          let fdeclared: own Bool = semantic_reader_region_declared(source: source, tokens: tokens, ast: ast, regions_node: reads_node, head_token: fregion);
