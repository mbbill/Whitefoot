      }
      return call_type;
    }
    False() => {
      let other_head: own u64 = index<u64>(deref(ast).heads, node);
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = other_head;
      return semantic_facts_none;
    }
  }
