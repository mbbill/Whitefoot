      let type_ok: own Bool = ieq<u64>(actual_type, expected_type);
      let mode_ok: own Bool = eeq<SemanticValueMode>(actual_mode, expected_mode);
      match band<Bool>(type_ok, mode_ok) {
        True() => {
        }
        False() => {
          return False();
        }
      }
      match expected_mode {
        SemanticModeOwn() => {
          return True();
        }
        SemanticModeShared() => {
        }
        SemanticModeUniq() => {
          return False();
        }
        SemanticModeNone() => {
          return False();
        }
      }
      match ine<u64>(expected_region, ast_none) {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let declaration: own u64 = index<u64>(deref(scratch).declarations, slot);
      match ilt<u64>(declaration, ast_count) {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let ast_parameter_atom: own AstKind = AstParameter();
      let declaration_parameter: own Bool = semantic_body_kind_is<'c>(ast: ast, node: declaration, want: ast_parameter_atom);
      let declaration_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: declaration, want: 2_u64);
      match band<Bool>(declaration_parameter, declaration_shape) {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let mode_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: declaration, ordinal: 0_u64);
      let ast_shared_mode_atom: own AstKind = AstSharedMode();
      let mode_shared: own Bool = semantic_body_kind_is<'c>(ast: ast, node: mode_node, want: ast_shared_mode_atom);
      let mode_valid: own Bool = semantic_function_mode_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: mode_node);
      match band<Bool>(mode_shared, mode_valid) {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let region_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: mode_node, ordinal: 0_u64);
      let region_valid: own Bool = semantic_function_region_leaf_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: region_node);
      match region_valid {
        True() => {
        }
        False() => {
