  let region_node: own u64 = ast_none;
  let first_param: own u64 = ast_none;
  let param_count: own u64 = 0_u64;
  let return_mode_node: own u64 = ast_none;
  let return_type_node: own u64 = ast_none;
  let pure_seen: own Bool = False();
  let reads_node: own u64 = ast_none;
  let traps_seen: own Bool = False();
  let other_effect: own Bool = False();
  let block_node: own u64 = ast_none;
  let name_node: own u64 = ast_none;
  let name_count: own u64 = 0_u64;
  let region_count: own u64 = 0_u64;
  let return_mode_count: own u64 = 0_u64;
  let return_type_count: own u64 = 0_u64;
  let pure_count: own u64 = 0_u64;
  let reads_count: own u64 = 0_u64;
  let traps_count: own u64 = 0_u64;
  let block_count: own u64 = 0_u64;
  let signature_nodes_ok: own Bool = True();
  let scan_stage: own u64 = 0_u64;

  let ast_function_name_atom: own AstKind = AstFunctionName();
  let ast_region_parameters_atom: own AstKind = AstRegionParameters();
  let ast_parameter_atom: own AstKind = AstParameter();
  let ast_own_mode_atom: own AstKind = AstOwnMode();
  let ast_return_type_atom: own AstKind = AstReturnType();
  let ast_pure_effect_atom: own AstKind = AstPureEffect();
  let ast_reads_effect_atom: own AstKind = AstReadsEffect();
  let ast_traps_effect_atom: own AstKind = AstTrapsEffect();
  let ast_block_atom: own AstKind = AstBlock();

  let scan_child: own u64 = callee_first;
  let scan_steps: own u64 = 0_u64;
  loop @semantic_reader_callee_scan {
    match ilt<u64>(scan_child, ast_count) {
      True() => {
