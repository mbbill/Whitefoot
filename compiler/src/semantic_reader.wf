      let is_enum_low: own Bool = ige<u64>(type_id, semantic_reader_enum_type_base);
      let is_enum_high: own Bool = ilt<u64>(type_id, semantic_reader_struct_type_base);
      let is_enum: own Bool = band<Bool>(is_enum_low, is_enum_high);
      let scalar_a: own Bool = bor<Bool>(is_u8, is_u64);
      let scalar: own Bool = bor<Bool>(scalar_a, is_bool);
      return bor<Bool>(scalar, is_enum);
    }
    False() => {
    }
  }
  let is_shared: own Bool = eeq<SemanticValueMode>(mode, mode_shared_atom);
  match is_shared {
