    False() => {
      return False();
    }
  }
  let mode_head: own u64 = index<u64>(deref(ast).heads, mode_region);
  return semantic_reader_region_declared(source: source, tokens: tokens, ast: ast, regions_node: regions_node, head_token: mode_head);
}

