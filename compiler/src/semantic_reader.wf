    match ilt<u64>(arg_child, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = node;
        set deref(report).related = arg_child;
        return semantic_facts_none;
      }
    }
    let arg_kind: own AstKind = index<AstKind>(deref(ast).kinds, arg_child);
    let arg_is_region: own Bool = eeq<AstKind>(arg_kind, ast_region_argument_atom);
    match arg_is_region {
      True() => {
        match ieq<u64>(named_seen, 0_u64) {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let arg_region_leaf: own Bool = semantic_body_exact_children<'c>(ast: ast, node: arg_child, want: 0_u64);
        let arg_region_token_valid: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: arg_child);
        match band<Bool>(arg_region_leaf, arg_region_token_valid) {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let arg_region_head: own u64 = index<u64>(deref(ast).heads, arg_child);
        let arg_region_kind: own Bool = parser_kind_at_is<'c>(tokens: tokens, token: arg_region_head, want: 4_u64);
        match arg_region_kind {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let region_live: own Bool = semantic_reader_region_declared(source: source, tokens: tokens, ast: ast, regions_node: regions_node, head_token: arg_region_head);
        match region_live {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        set region_args_seen = iadd.trap<u64>(region_args_seen, 1_u64);
      }
      False() => {
        let arg_is_named: own Bool = eeq<AstKind>(arg_kind, ast_named_argument_atom);
        match arg_is_named {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        match ilt<u64>(param_cursor, ast_count) {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let param_is_parameter: own Bool = semantic_body_kind_is(ast: ast, node: param_cursor, want: ast_parameter_atom);
        match param_is_parameter {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let arg_shape: own Bool = semantic_body_exact_children(ast: ast, node: arg_child, want: 1_u64);
        let arg_token: own Bool = semantic_buffer_declaration_word_valid<'c>(source: source, tokens: tokens, ast: ast, node: arg_child);
        match band<Bool>(arg_shape, arg_token) {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let arg_name_head: own u64 = index<u64>(deref(ast).heads, arg_child);
        let param_name_head: own u64 = index<u64>(deref(ast).heads, param_cursor);
        let name_same: own Bool = token_text_equal(source: source, tokens: tokens, left: arg_name_head, right: param_name_head);
        match name_same {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_child;
            return semantic_facts_none;
          }
        }
        let param_type: own u64 = semantic_reader_param_type_id(source: source, tokens: tokens, ast: ast, symbols: symbols, parameter: param_cursor);
        match ieq<u64>(param_type, semantic_facts_none) {
          True() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = param_cursor;
            return semantic_facts_none;
          }
          False() => {
          }
        }
        let param_mode: own SemanticValueMode = semantic_reader_param_mode(source: source, tokens: tokens, ast: ast, parameter: param_cursor);
        let semantic_mode_none_atom: own SemanticValueMode = SemanticModeNone();
        match eeq<SemanticValueMode>(param_mode, semantic_mode_none_atom) {
          True() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = param_cursor;
            return semantic_facts_none;
          }
          False() => {
          }
        }
        let expected_region: own u64 = ast_none;
        match param_mode {
          SemanticModeOwn() => {
          }
          SemanticModeShared() => {
            match has_region {
              True() => {
              }
              False() => {
                set deref(report).status = SemanticBodyUnsupported();
                set deref(report).node = node;
                set deref(report).related = param_cursor;
                return semantic_facts_none;
              }
            }
            let param_mode_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: param_cursor, ordinal: 0_u64);
            let ast_shared_mode_atom: own AstKind = AstSharedMode();
            let param_mode_shared: own Bool = semantic_body_kind_is<'c>(ast: ast, node: param_mode_node, want: ast_shared_mode_atom);
            let param_mode_valid: own Bool = semantic_function_mode_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: param_mode_node);
            match band<Bool>(param_mode_shared, param_mode_valid) {
              True() => {
              }
              False() => {
                set deref(report).status = SemanticBodyUnsupported();
                set deref(report).node = node;
                set deref(report).related = param_cursor;
                return semantic_facts_none;
              }
            }
            let param_region_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: param_mode_node, ordinal: 0_u64);
            let param_region_valid: own Bool = semantic_function_region_leaf_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: param_region_node);
            match param_region_valid {
              True() => {
              }
              False() => {
                set deref(report).status = SemanticBodyUnsupported();
                set deref(report).node = node;
                set deref(report).related = param_region_node;
                return semantic_facts_none;
              }
            }
            let param_region_head: own u64 = index<u64>(deref(ast).heads, param_region_node);
            let mapped_region: own u64 = ast_none;
            let map_formal: own u64 = index<u64>(deref(ast).first_children, region_node);
            let map_formal_last: own u64 = index<u64>(deref(ast).last_children, region_node);
            let map_actual: own u64 = call_first;
            let map_steps: own u64 = 0_u64;
            loop @semantic_reader_call_region_map {
              let map_formal_in_bounds: own Bool = ilt<u64>(map_formal, ast_count);
              let map_actual_in_bounds: own Bool = ilt<u64>(map_actual, ast_count);
              match band<Bool>(map_formal_in_bounds, map_actual_in_bounds) {
                True() => {
                }
                False() => {
                  set deref(report).status = SemanticBodyUnsupported();
                  set deref(report).node = node;
                  set deref(report).related = map_actual;
                  return semantic_facts_none;
                }
              }
              let map_actual_is_region: own Bool = semantic_body_kind_is<'c>(ast: ast, node: map_actual, want: ast_region_argument_atom);
              match map_actual_is_region {
                True() => {
                }
                False() => {
                  set deref(report).status = SemanticBodyUnsupported();
                  set deref(report).node = node;
                  set deref(report).related = map_actual;
                  return semantic_facts_none;
                }
              }
              let map_formal_head: own u64 = index<u64>(deref(ast).heads, map_formal);
              let map_formal_matches: own Bool = token_text_equal<'c, 'c>(source: source, tokens: tokens, left: param_region_head, right: map_formal_head);
              match map_formal_matches {
                True() => {
                  set mapped_region = index<u64>(deref(ast).heads, map_actual);
                  break @semantic_reader_call_region_map;
                }
                False() => {
                }
              }
              match ieq<u64>(map_formal, map_formal_last) {
                True() => {
                  break @semantic_reader_call_region_map;
                }
                False() => {
                }
              }
              let map_formal_next: own u64 = index<u64>(deref(ast).next_siblings, map_formal);
              let map_actual_next: own u64 = index<u64>(deref(ast).next_siblings, map_actual);
              let map_formal_next_valid: own Bool = ilt<u64>(map_formal_next, ast_count);
              let map_actual_next_valid: own Bool = ilt<u64>(map_actual_next, ast_count);
              match band<Bool>(map_formal_next_valid, map_actual_next_valid) {
                True() => {
                  set map_formal = map_formal_next;
                  set map_actual = map_actual_next;
                }
                False() => {
                  set deref(report).status = SemanticBodyUnsupported();
                  set deref(report).node = node;
                  set deref(report).related = map_actual_next;
                  return semantic_facts_none;
                }
              }
              set map_steps = iadd.trap<u64>(map_steps, 1_u64);
              match ilt<u64>(map_steps, ast_count) {
                True() => {
                }
                False() => {
                  set deref(report).status = SemanticBodyUnsupported();
                  set deref(report).node = node;
                  set deref(report).related = map_steps;
                  return semantic_facts_none;
                }
              }
            }
            match ine<u64>(mapped_region, ast_none) {
              True() => {
              }
              False() => {
                set deref(report).status = SemanticBodyUnsupported();
                set deref(report).node = node;
                set deref(report).related = param_region_node;
                return semantic_facts_none;
              }
            }
            set expected_region = mapped_region;
          }
          SemanticModeUniq() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = param_cursor;
            return semantic_facts_none;
          }
          SemanticModeNone() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = param_cursor;
            return semantic_facts_none;
          }
        }
        let arg_actual: own u64 = semantic_body_child_at(ast: ast, node: arg_child, ordinal: 0_u64);
        let arg_ok: own Bool = semantic_reader_arg_matches<'c, 'w>(source: source, tokens: tokens, ast: ast, scratch: scratch, actual: arg_actual, expected_type: param_type, expected_mode: param_mode, expected_region: expected_region);
        match arg_ok {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_actual;
            return semantic_facts_none;
          }
        }
        set named_seen = iadd.trap<u64>(named_seen, 1_u64);
        set param_cursor = index<u64>(deref(ast).next_siblings, param_cursor);
      }
    }
    match ieq<u64>(arg_child, call_last) {
      True() => {
        let arg_terminal: own u64 = index<u64>(deref(ast).next_siblings, arg_child);
        match ieq<u64>(arg_terminal, ast_none) {
          True() => {
          }
          False() => {
            set deref(report).status = SemanticBodyUnsupported();
            set deref(report).node = node;
            set deref(report).related = arg_terminal;
            return semantic_facts_none;
          }
        }
        break @semantic_reader_call_arguments;
      }
      False() => {
      }
    }
    let arg_next: own u64 = index<u64>(deref(ast).next_siblings, arg_child);
    match ilt<u64>(arg_next, ast_count) {
      True() => {
        set arg_child = arg_next;
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = node;
        set deref(report).related = arg_next;
        return semantic_facts_none;
      }
    }
    set arg_steps = iadd.trap<u64>(arg_steps, 1_u64);
    match ilt<u64>(arg_steps, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyUnsupported();
        set deref(report).node = node;
        set deref(report).related = arg_steps;
        return semantic_facts_none;
      }
    }
  }

  let region_count_ok: own Bool = ieq<u64>(region_args_seen, callee_region_count);
  let named_count_ok: own Bool = ieq<u64>(named_seen, param_count);
  match band<Bool>(region_count_ok, named_count_ok) {
    True() => {
      return return_type_id;
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = callee;
      return semantic_facts_none;
    }
  }
}

fn semantic_reader_u64_literal_canonical ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let kind: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_numeric_literal_atom);
  let leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
  let token_valid: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  let first: own Bool = band<Bool>(kind, leaf);
  let ok: own Bool = band<Bool>(first, token_valid);
  match ok {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let token: own u64 = index<u64>(deref(ast).heads, node);
  let number_kind: own Bool = parser_kind_at_is(tokens: tokens, token: token, want: 6_u64);
  match number_kind {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, token);
  let end: own u64 = index<u64>(deref(tokens).ends, token);
  let width: own u64 = isub.wrap<u64>(end, start);
  let width_ok: own Bool = ige<u64>(width, 5_u64);
  match width_ok {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let mant_end: own u64 = isub.wrap<u64>(end, 4_u64);
  let suffix_u: own u8 = index<u8>(deref(source), mant_end);
  let suffix_pos1: own u64 = isub.wrap<u64>(end, 3_u64);
  let suffix_pos2: own u64 = isub.wrap<u64>(end, 2_u64);
  let suffix_pos3: own u64 = isub.wrap<u64>(end, 1_u64);
  let suffix_letter: own u8 = index<u8>(deref(source), suffix_pos1);
  let suffix_six: own u8 = index<u8>(deref(source), suffix_pos2);
  let suffix_four: own u8 = index<u8>(deref(source), suffix_pos3);
  let suffix_a: own Bool = ieq<u8>(suffix_u, 95_u8);
  let suffix_b: own Bool = ieq<u8>(suffix_letter, 117_u8);
  let suffix_c: own Bool = ieq<u8>(suffix_six, 54_u8);
  let suffix_d: own Bool = ieq<u8>(suffix_four, 52_u8);
  let suffix_ab: own Bool = band<Bool>(suffix_a, suffix_b);
  let suffix_cd: own Bool = band<Bool>(suffix_c, suffix_d);
  match band<Bool>(suffix_ab, suffix_cd) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let mant_len: own u64 = isub.wrap<u64>(width, 4_u64);
  let len_lo: own Bool = ige<u64>(mant_len, 1_u64);
  let len_hi: own Bool = ile<u64>(mant_len, 19_u64);
  match band<Bool>(len_lo, len_hi) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let scan: own u64 = start;
  let position: own u64 = 0_u64;
  loop @semantic_reader_u64_literal_digits {
    match ige<u64>(scan, mant_end) {
      True() => {
        return True();
      }
      False() => {
      }
    }
    let byte: own u8 = index<u8>(deref(source), scan);
    let digit_lo: own Bool = ige<u8>(byte, 48_u8);
    let digit_hi: own Bool = ile<u8>(byte, 57_u8);
    match band<Bool>(digit_lo, digit_hi) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let at_first: own Bool = ieq<u64>(position, 0_u64);
    let multi_digit: own Bool = igt<u64>(mant_len, 1_u64);
    match band<Bool>(at_first, multi_digit) {
      True() => {
        match ieq<u8>(byte, 48_u8) {
          True() => {
            return False();
          }
          False() => {
          }
        }
      }
      False() => {
      }
    }
    set scan = iadd.trap<u64>(scan, 1_u64);
    set position = iadd.trap<u64>(position, 1_u64);
  }
}

fn semantic_reader_literal_type ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own u64 reads('c), traps {
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let kind: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_numeric_literal_atom);
  let leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
  let token_valid: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  let first: own Bool = band<Bool>(kind, leaf);
  let ok: own Bool = band<Bool>(first, token_valid);
  match ok {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let u8_parse: own SemanticU8LiteralResult = semantic_body_parse_u8_literal(source: source, tokens: tokens, token: head);
  match u8_parse.status {
    SemanticU8LiteralReady() => {
      return semantic_buffer_type_u8;
    }
    SemanticU8LiteralWrongType() => {
    }
    SemanticU8LiteralMissingSuffix() => {
    }
    SemanticU8LiteralNoncanonical() => {
    }
    SemanticU8LiteralInvalidValue() => {
    }
    SemanticU8LiteralMalformed() => {
    }
  }
  let u64_ok: own Bool = semantic_reader_u64_literal_canonical(source: source, tokens: tokens, ast: ast, node: node);
  match u64_ok {
    True() => {
      return semantic_buffer_type_u64;
    }
    False() => {
      return semantic_facts_none;
    }
  }
}

fn semantic_reader_analyze_expr ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, regions_node: own u64, node: own u64, scratch: &'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  let ast_count: own u64 = deref(ast).count;
  match ilt<u64>(node, ast_count) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = ast_count;
      return semantic_facts_none;
    }
  }
  let node_kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let is_place: own Bool = eeq<AstKind>(node_kind, ast_place_use_atom);
  match is_place {
    True() => {
      let place_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: node);
      match ieq<u64>(place_type, semantic_facts_none) {
        True() => {
          let place_head: own u64 = index<u64>(deref(ast).heads, node);
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = place_head;
          return semantic_facts_none;
        }
        False() => {
          return place_type;
        }
      }
    }
    False() => {
    }
  }
  let ast_table_call_atom: own AstKind = AstTableCall();
  let is_table: own Bool = eeq<AstKind>(node_kind, ast_table_call_atom);
  match is_table {
    True() => {
      let table_type: own u64 = semantic_facts_none;
      region 'semantic_reader_expr_table {
        set table_type = semantic_reader_analyze_table_call(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: scratch, node: node, report: &uniq 'semantic_reader_expr_table deref(report));
      }
      return table_type;
    }
    False() => {
    }
  }
  let ast_index_place_atom: own AstKind = AstIndexPlace();
  let is_index: own Bool = eeq<AstKind>(node_kind, ast_index_place_atom);
  match is_index {
    True() => {
      let index_type: own u64 = semantic_facts_none;
      region 'semantic_reader_expr_index {
        set index_type = semantic_reader_analyze_index(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: scratch, node: node, report: &uniq 'semantic_reader_expr_index deref(report));
      }
      return index_type;
    }
    False() => {
    }
  }
  let ast_field_place_atom: own AstKind = AstFieldPlace();
  let is_field_place: own Bool = eeq<AstKind>(node_kind, ast_field_place_atom);
  match is_field_place {
    True() => {
      let field_place_type: own u64 = semantic_facts_none;
      region 'semantic_reader_expr_field {
        set field_place_type = semantic_reader_analyze_field_place(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: scratch, node: node, report: &uniq 'semantic_reader_expr_field deref(report));
      }
      return field_place_type;
    }
    False() => {
    }
  }
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let is_literal: own Bool = eeq<AstKind>(node_kind, ast_numeric_literal_atom);
  match is_literal {
    True() => {
      let literal_type: own u64 = semantic_reader_literal_type(source: source, tokens: tokens, ast: ast, node: node);
      match ieq<u64>(literal_type, semantic_facts_none) {
        True() => {
          let literal_head: own u64 = index<u64>(deref(ast).heads, node);
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).node = node;
          set deref(report).related = literal_head;
          return semantic_facts_none;
        }
        False() => {
          return literal_type;
        }
      }
    }
    False() => {
    }
  }
  let ast_constructor_atom: own AstKind = AstConstructor();
  let is_constructor: own Bool = eeq<AstKind>(node_kind, ast_constructor_atom);
  match is_constructor {
    True() => {
      let ctor_shape: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
      let ctor_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
