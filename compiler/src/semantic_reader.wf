          set deref(report).node = node;
          set deref(report).related = place_head;
          return semantic_facts_none;
        }
        False() => {
          return place_type;
        }
      }
    }
    False() => {
    }
  }
  let ast_table_call_atom: own AstKind = AstTableCall();
  let is_table: own Bool = ieq<AstKind>(node_kind, ast_table_call_atom);
  match is_table {
    True() => {
      let table_type: own u64 = semantic_facts_none;
      region 'semantic_reader_expr_table {
        set table_type = semantic_reader_analyze_table_call(source: source, tokens: tokens, ast: ast, scratch: scratch, node: node, report: &uniq 'semantic_reader_expr_table deref(report));
