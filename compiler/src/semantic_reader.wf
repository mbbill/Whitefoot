  let is_buffer: own Bool = ieq<u64>(type_id, semantic_buffer_type_u8_buffer);
  let is_struct: own Bool = ige<u64>(type_id, semantic_reader_struct_type_base);
  let shared_type_ok: own Bool = bor<Bool>(is_buffer, is_struct);
  match shared_type_ok {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let mode_region: own u64 = semantic_body_child_at(ast: ast, node: mode_node, ordinal: 0_u64);
