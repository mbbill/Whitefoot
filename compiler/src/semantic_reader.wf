      set deref(report).related = base_node;
      return semantic_facts_none;
    }
  }
  let place_node: own u64 = semantic_body_child_at(ast: ast, node: base_node, ordinal: 0_u64);
  let struct_type: own u64 = semantic_reader_place_type(source: source, tokens: tokens, ast: ast, scratch: scratch, node: place_node);
  let is_struct: own Bool = ige<u64>(struct_type, semantic_reader_struct_type_base);
  match is_struct {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
