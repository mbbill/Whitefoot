fn semantic_reader_run ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own unit reads('c 'w), writes('w), traps {
  set deref(report).status = SemanticBodyUnsupported();
  set deref(report).node = function;
  set deref(report).related = function;
  set deref(report).rule = SemanticRuleNone();
  set deref(report).fix = SemanticFixNone();
  set deref(report).related_node = ast_none;

  let reader_signature: own Bool = semantic_reader_signature_valid(source: source, tokens: tokens, ast: ast, function: function);
  match reader_signature {
    True() => {
    }
    False() => {
      return unit;
    }
  }
  let reader_symbols_valid: own Bool = symbol_lookup_entries_valid(source: source, tokens: tokens, symbols: symbols);
  match reader_symbols_valid {
    True() => {
    }
    False() => {
      return unit;
    }
  }
  let reader_scratch_capacity: own Bool = False();
  region 'semantic_reader_run_scratch_capacity {
    set reader_scratch_capacity = semantic_body_scratch_capacity_valid(scratch: &'semantic_reader_run_scratch_capacity deref(scratch), needed: 34_u64);
  }
  match reader_scratch_capacity {
    True() => {
    }
    False() => {
      return unit;
    }
  }

  set deref(scratch).count = 0_u64;
  let reader_regions: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 1_u64);
  let reader_region: own u64 = semantic_body_child_at(ast: ast, node: reader_regions, ordinal: 0_u64);
  let region_token: own u64 = index<u64>(deref(ast).heads, reader_region);
  let reader_source: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 2_u64);
  let reader_start: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 3_u64);
  let reader_size: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 4_u64);
  let reader_source_head: own u64 = index<u64>(deref(ast).heads, reader_source);
  let reader_start_head: own u64 = index<u64>(deref(ast).heads, reader_start);
  let reader_size_head: own u64 = index<u64>(deref(ast).heads, reader_size);

  let pushed_source: own Bool = False();
  region 'semantic_reader_run_push_source {
    let semantic_mode_shared_atom: own SemanticValueMode = SemanticModeShared();
    set pushed_source = semantic_body_scope_push(source: source, tokens: tokens, scratch: &uniq 'semantic_reader_run_push_source deref(scratch), name_token: reader_source_head, declaration: reader_source, type_id: semantic_buffer_type_u8_buffer, mode: semantic_mode_shared_atom);
  }
  let pushed_start: own Bool = False();
  region 'semantic_reader_run_push_start {
    let semantic_mode_own_start: own SemanticValueMode = SemanticModeOwn();
    set pushed_start = semantic_body_scope_push(source: source, tokens: tokens, scratch: &uniq 'semantic_reader_run_push_start deref(scratch), name_token: reader_start_head, declaration: reader_start, type_id: semantic_buffer_type_u64, mode: semantic_mode_own_start);
  }
  let pushed_size: own Bool = False();
  region 'semantic_reader_run_push_size {
    let semantic_mode_own_size: own SemanticValueMode = SemanticModeOwn();
    set pushed_size = semantic_body_scope_push(source: source, tokens: tokens, scratch: &uniq 'semantic_reader_run_push_size deref(scratch), name_token: reader_size_head, declaration: reader_size, type_id: semantic_buffer_type_u64, mode: semantic_mode_own_size);
  }
  let pushed_first: own Bool = band<Bool>(pushed_source, pushed_start);
  let pushed_all: own Bool = band<Bool>(pushed_first, pushed_size);
  match pushed_all {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = function;
      return unit;
    }
  }

  let reader_block: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 9_u64);
  let flow: own SemanticReaderFlow = SemanticReaderFlowError();
  region 'semantic_reader_run_block {
    set flow = semantic_reader_analyze_block(source: source, tokens: tokens, ast: ast, symbols: symbols, region_token: region_token, return_type: semantic_buffer_type_u64, block: reader_block, scratch: &uniq 'semantic_reader_run_block deref(scratch), report: &uniq 'semantic_reader_run_block deref(report));
  }
  match flow {
    SemanticReaderFlowReturns() => {
      set deref(report).status = SemanticBodyClean();
      set deref(report).node = semantic_facts_none;
      set deref(report).related = semantic_facts_none;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowFalls() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = function;
      set deref(report).related = reader_block;
      set deref(report).rule = SemanticRuleNone();
      set deref(report).fix = SemanticFixNone();
      set deref(report).related_node = ast_none;
      return unit;
    }
    SemanticReaderFlowError() => {
      set deref(report).status = SemanticBodyUnsupported();
      return unit;
    }
  }
}
