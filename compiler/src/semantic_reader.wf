fn semantic_reader_analyze_call ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, regions_node: own u64, node: own u64, scratch: &'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  let ast_user_call_atom: own AstKind = AstUserCall();
  let kind_ok: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_user_call_atom);
  let token_ok: own Bool = semantic_buffer_declaration_word_valid<'c>(source: source, tokens: tokens, ast: ast, node: node);
  match band<Bool>(kind_ok, token_ok) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = node;
      return semantic_facts_none;
    }
  }
  let call_head: own u64 = index<u64>(deref(ast).heads, node);
  let symbol_value_atom: own SymbolNamespace = SymbolValue();
  let callee_lookup: own SymbolLookupResult = symbol_lookup_in_scope(source: source, tokens: tokens, symbols: symbols, space: symbol_value_atom, scope: symbol_none, name_token: call_head);
  match callee_lookup.status {
    SymbolLookupFound() => {
    }
    SymbolLookupNotFound() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = call_head;
      return semantic_facts_none;
    }
    SymbolLookupInvalidTape() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = call_head;
      return semantic_facts_none;
    }
    SymbolLookupInvalidToken() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = call_head;
      return semantic_facts_none;
    }
  }
  let callee: own u64 = callee_lookup.declaration;
  let callee_top_level: own Bool = semantic_buffer_top_level_function_valid(ast: ast, function: callee);
  let ast_function_atom: own AstKind = AstFunction();
  let callee_kind: own Bool = semantic_body_kind_is(ast: ast, node: callee, want: ast_function_atom);
  match band<Bool>(callee_top_level, callee_kind) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = callee;
      return semantic_facts_none;
    }
  }
  let callee_token_valid: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: callee);
  match callee_token_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = callee;
      return semantic_facts_none;
    }
  }
  let callee_head: own u64 = index<u64>(deref(ast).heads, callee);
  let callee_fn_word: own Bool = parser_word2<'c, 'c>(source: source, tokens: tokens, token: callee_head, a: 102_u8, b: 110_u8);
  match callee_fn_word {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = callee;
      return semantic_facts_none;
    }
  }

  let ast_count: own u64 = deref(ast).count;
  let callee_first: own u64 = index<u64>(deref(ast).first_children, callee);
  let callee_last: own u64 = index<u64>(deref(ast).last_children, callee);
  let callee_first_none: own Bool = ieq<u64>(callee_first, ast_none);
  let callee_last_none: own Bool = ieq<u64>(callee_last, ast_none);
  match bor<Bool>(callee_first_none, callee_last_none) {
    True() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = callee;
      return semantic_facts_none;
    }
    False() => {
    }
