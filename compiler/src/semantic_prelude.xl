fn semantic_prelude_type_code ['s, 't] (source: &'s buffer<u8>, tokens: &'t TokenTape, token: own u64) -> own PreludeTypeCode reads('s 't), traps {
  let is_bool: own Bool = semantic_prelude_is_bool(source: source, tokens: tokens, token: token);
  match is_bool {
    True() => {
      return PreludeTypeBool();
    }
    False() => {
    }
  }
  let is_option: own Bool = semantic_prelude_is_option(source: source, tokens: tokens, token: token);
  match is_option {
    True() => {
      return PreludeTypeOption();
    }
    False() => {
    }
  }
  let is_result: own Bool = semantic_prelude_is_result(source: source, tokens: tokens, token: token);
  match is_result {
    True() => {
      return PreludeTypeResult();
    }
    False() => {
    }
  }
  let is_overflow: own Bool = semantic_prelude_is_overflow(source: source, tokens: tokens, token: token);
  match is_overflow {
    True() => {
      return PreludeTypeOverflow();
    }
    False() => {
    }
  }
  let is_div_error: own Bool = semantic_prelude_is_div_error(source: source, tokens: tokens, token: token);
  match is_div_error {
    True() => {
      return PreludeTypeDivError();
    }
    False() => {
    }
  }
  let is_narrow_error: own Bool = semantic_prelude_is_narrow_error(source: source, tokens: tokens, token: token);
  match is_narrow_error {
    True() => {
      return PreludeTypeNarrowError();
    }
    False() => {
      return PreludeTypeUnknown();
    }
  }
}

