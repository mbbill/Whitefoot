fn semantic_prelude_typeid_width ['s, 't] (source: &'s buffer<u8>, tokens: &'t TokenTape, token: own u64, width: own u64) -> own Bool reads('s 't), traps {
  let ordinal_valid: own Bool = token_ordinal_valid(source: source, tokens: tokens, token: token);
  match ordinal_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let kinds_length: own u64 = len<TokenKind>(deref(tokens).kinds);
  match ilt<u64>(token, kinds_length) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed_kind: own TokenKind = index<TokenKind>(deref(tokens).kinds, token);
  let typeid_kind: own TokenKind = TokTypeId();
  let correct_kind: own Bool = ieq<TokenKind>(observed_kind, typeid_kind);
  match correct_kind {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, token);
  let end: own u64 = index<u64>(deref(tokens).ends, token);
  let observed_width: own u64 = isub.wrap<u64>(end, start);
  return ieq<u64>(observed_width, width);
}

fn semantic_prelude_chunk1 ['s] (source: &'s buffer<u8>, start: own u64, a: own u8) -> own Bool reads('s), traps {
  let b0: own u8 = index<u8>(deref(source), start);
  return ieq<u8>(b0, a);
}

fn semantic_prelude_chunk2 ['s] (source: &'s buffer<u8>, start: own u64, a: own u8, b: own u8) -> own Bool reads('s), traps {
  let p1: own u64 = iadd.trap<u64>(start, 1_u64);
  let b0: own u8 = index<u8>(deref(source), start);
  let b1: own u8 = index<u8>(deref(source), p1);
  let e0: own Bool = ieq<u8>(b0, a);
  let e1: own Bool = ieq<u8>(b1, b);
  return band<Bool>(e0, e1);
}

fn semantic_prelude_chunk3 ['s] (source: &'s buffer<u8>, start: own u64, a: own u8, b: own u8, c: own u8) -> own Bool reads('s), traps {
  let p1: own u64 = iadd.trap<u64>(start, 1_u64);
  let p2: own u64 = iadd.trap<u64>(start, 2_u64);
  let b0: own u8 = index<u8>(deref(source), start);
  let b1: own u8 = index<u8>(deref(source), p1);
  let b2: own u8 = index<u8>(deref(source), p2);
  let e0: own Bool = ieq<u8>(b0, a);
  let e1: own Bool = ieq<u8>(b1, b);
  let e2: own Bool = ieq<u8>(b2, c);
  let first: own Bool = band<Bool>(e0, e1);
  return band<Bool>(first, e2);
}

fn semantic_prelude_chunk4 ['s] (source: &'s buffer<u8>, start: own u64, a: own u8, b: own u8, c: own u8, d: own u8) -> own Bool reads('s), traps {
  let p1: own u64 = iadd.trap<u64>(start, 1_u64);
  let p2: own u64 = iadd.trap<u64>(start, 2_u64);
  let p3: own u64 = iadd.trap<u64>(start, 3_u64);
  let b0: own u8 = index<u8>(deref(source), start);
  let b1: own u8 = index<u8>(deref(source), p1);
  let b2: own u8 = index<u8>(deref(source), p2);
  let b3: own u8 = index<u8>(deref(source), p3);
  let e0: own Bool = ieq<u8>(b0, a);
  let e1: own Bool = ieq<u8>(b1, b);
  let e2: own Bool = ieq<u8>(b2, c);
  let e3: own Bool = ieq<u8>(b3, d);
  let first: own Bool = band<Bool>(e0, e1);
  let second: own Bool = band<Bool>(e2, e3);
  return band<Bool>(first, second);
}

fn semantic_prelude_is_bool ['s, 't] (source: &'s buffer<u8>, tokens: &'t TokenTape, token: own u64) -> own Bool reads('s 't), traps {
  let valid: own Bool = semantic_prelude_typeid_width(source: source, tokens: tokens, token: token, width: 4_u64);
  match valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, token);
  return semantic_prelude_chunk4(source: source, start: start, a: 66_u8, b: 111_u8, c: 111_u8, d: 108_u8);
}

