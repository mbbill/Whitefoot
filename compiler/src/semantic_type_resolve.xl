              False() => {
                region 'buffer_child_error {
                  let semantic_type_resolve_malformed_type_atom_0447: own SemanticTypeResolveStatus = SemanticTypeResolveMalformedType();
                  semantic_type_resolve_set_report(report: &uniq 'buffer_child_error deref(report), status: semantic_type_resolve_malformed_type_atom_0447, node: current, related: child);
                }
                return unit;
              }
            }
            let child_kind: own AstKind = index<AstKind>(deref(ast).kinds, child);
            let nested_tag: own AstKind = AstNestedType();
            let nested: own Bool = ieq<AstKind>(child_kind, nested_tag);
            let child_next: own u64 = index<u64>(deref(ast).next_siblings, child);
            let chain_end: own Bool = ieq<u64>(child_next, ast_none);
            let child_shape: own Bool = band<Bool>(nested, chain_end);
            match child_shape {
              True() => {
                set index<u64>(deref(validation).stack, stack_count) = child;
                set stack_count = iadd.trap<u64>(stack_count, 1_u64);
              }
              False() => {
                region 'buffer_nested_error {
                  let semantic_type_resolve_malformed_type_atom_0448: own SemanticTypeResolveStatus = SemanticTypeResolveMalformedType();
                  semantic_type_resolve_set_report(report: &uniq 'buffer_nested_error deref(report), status: semantic_type_resolve_malformed_type_atom_0448, node: current, related: child);
                }
                return unit;
              }
            }
          }
          False() => {
            match array_type {
              True() => {
                let nested_child: own u64 = index<u64>(deref(ast).first_children, current);
