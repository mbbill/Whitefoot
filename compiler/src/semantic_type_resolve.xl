                  let semantic_type_resolve_malformed_type_atom_0446: own SemanticTypeResolveStatus = SemanticTypeResolveMalformedType();
                  semantic_type_resolve_set_report(report: &uniq 'buffer_arity_error deref(report), status: semantic_type_resolve_malformed_type_atom_0446, node: current, related: last);
                }
