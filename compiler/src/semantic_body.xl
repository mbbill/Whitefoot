    let argument_lookup_status: own SymbolLookupStatus = argument_lookup.status;
    match argument_lookup_status {
      SymbolLookupFound() => {
      }
      SymbolLookupNotFound() => {
        set deref(report).status = SemanticBodyUnknownName();
        set deref(report).node = argument;
        set deref(report).related = argument_head;
        return semantic_facts_none;
      }
      SymbolLookupInvalidTape() => {
        set deref(report).status = SemanticBodyInvalidSymbolTape();
        set deref(report).node = argument;
        set deref(report).related = deref(symbols).count;
        return semantic_facts_none;
      }
      SymbolLookupInvalidToken() => {
        set deref(report).status = SemanticBodyMalformed();
        set deref(report).node = argument;
        set deref(report).related = argument_head;
        return semantic_facts_none;
      }
    }
    match ieq<u64>(argument_lookup.declaration, formal) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyInvalidSymbolTape();
        set deref(report).node = argument;
        set deref(report).related = argument_lookup.declaration;
        return semantic_facts_none;
      }
    }
    match argument_seen {
      True() => {
        set deref(report).status = SemanticBodyMalformed();
        set deref(report).node = argument;
        set deref(report).related = formal;
        return semantic_facts_none;
      }
      False() => {
        set argument_seen = True();
      }
    }
    let actual: own u64 = semantic_body_child_at(ast: ast, node: argument, ordinal: 0_u64);
    let actual_type: own u64 = semantic_facts_none;
    region 'semantic_body_user_actual {
      set actual_type = semantic_body_analyze_atom(source: source, tokens: tokens, ast: ast, node: actual, u8_type: u8_type, facts: &uniq 'semantic_body_user_actual deref(facts), scratch: scratch, report: &uniq 'semantic_body_user_actual deref(report));
    }
    match ieq<u64>(actual_type, u8_type) {
      True() => {
      }
      False() => {
        match ieq<u64>(actual_type, semantic_facts_none) {
          True() => {
            return semantic_facts_none;
          }
          False() => {
            set deref(report).status = SemanticBodyTypeMismatch();
            set deref(report).node = actual;
            set deref(report).related = u8_type;
            return semantic_facts_none;
          }
        }
      }
    }
    let actual_mode: own SemanticValueMode = index<SemanticValueMode>(deref(facts).modes, actual);
    match actual_mode {
      SemanticModeOwn() => {
      }
      SemanticModeNone() => {
        set deref(report).status = SemanticBodyTypeMismatch();
        set deref(report).node = actual;
        set deref(report).related = formal;
        return semantic_facts_none;
      }
      SemanticModeShared() => {
        set deref(report).status = SemanticBodyTypeMismatch();
        set deref(report).node = actual;
        set deref(report).related = formal;
        return semantic_facts_none;
      }
      SemanticModeUniq() => {
        set deref(report).status = SemanticBodyTypeMismatch();
        set deref(report).node = actual;
        set deref(report).related = formal;
        return semantic_facts_none;
      }
    }
    set index<u64>(deref(facts).type_ids, argument) = u8_type;
    set index<u64>(deref(facts).resolved_declarations, argument) = formal;
    set index<u64>(deref(facts).ordinals, argument) = 0_u64;
    set index<SemanticValueMode>(deref(facts).modes, argument) = SemanticModeOwn();

    let at_last: own Bool = ieq<u64>(argument, last_argument);
    let next_argument: own u64 = index<u64>(deref(ast).next_siblings, argument);
    match at_last {
      True() => {
        match ieq<u64>(next_argument, ast_none) {
          True() => {
            break @semantic_body_user_arguments;
          }
          False() => {
            set deref(report).status = SemanticBodyMalformed();
            set deref(report).node = argument;
            set deref(report).related = next_argument;
            return semantic_facts_none;
          }
        }
      }
      False() => {
        set argument = next_argument;
      }
    }
    set argument_steps = iadd.trap<u64>(argument_steps, 1_u64);
    match ilt<u64>(argument_steps, ast_count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticBodyMalformed();
        set deref(report).node = node;
        set deref(report).related = argument_steps;
        return semantic_facts_none;
      }
    }
  }

  set index<u64>(deref(facts).type_ids, node) = bool_type;
  set index<u64>(deref(facts).resolved_declarations, node) = callee;
  set index<u64>(deref(facts).ordinals, node) = value_ordinal;
  set index<SemanticValueMode>(deref(facts).modes, node) = SemanticModeOwn();
  return bool_type;
}

fn semantic_body_analyze_expression ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, node: own u64, value_ordinal: own u64, u8_type: own u64, bool_type: own u64, facts: &uniq 'w NodeFacts, scratch: &'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  match ilt<u64>(node, deref(ast).count) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = deref(ast).count;
      return semantic_facts_none;
    }
  }
  let kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  let table_tag: own AstKind = AstTableCall();
  match ieq<AstKind>(kind, table_tag) {
    True() => {
      let table_result: own u64 = semantic_facts_none;
      region 'semantic_body_dispatch_table {
        set table_result = semantic_body_analyze_table_call(source: source, tokens: tokens, ast: ast, node: node, value_ordinal: value_ordinal, u8_type: u8_type, bool_type: bool_type, facts: &uniq 'semantic_body_dispatch_table deref(facts), scratch: scratch, report: &uniq 'semantic_body_dispatch_table deref(report));
      }
      return table_result;
    }
    False() => {
    }
  }
  let user_tag: own AstKind = AstUserCall();
  match ieq<AstKind>(kind, user_tag) {
    True() => {
      let user_result: own u64 = semantic_facts_none;
      region 'semantic_body_dispatch_user {
        set user_result = semantic_body_analyze_user_call(source: source, tokens: tokens, ast: ast, symbols: symbols, node: node, value_ordinal: value_ordinal, u8_type: u8_type, bool_type: bool_type, facts: &uniq 'semantic_body_dispatch_user deref(facts), scratch: scratch, report: &uniq 'semantic_body_dispatch_user deref(report));
      }
      return user_result;
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = node;
      set deref(report).related = index<u64>(deref(ast).heads, node);
      return semantic_facts_none;
    }
  }
}

fn semantic_body_analyze_bool_match ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64, node: own u64, continuation: own u64, expected_let: own u64, value_ordinal: own u64, bool_type: own u64, facts: &uniq 'w NodeFacts, scratch: &'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own Bool reads('c 'w), writes('w), traps {
  let ast_count: own u64 = deref(ast).count;
  let function_valid: own Bool = ilt<u64>(function, ast_count);
  let continuation_valid: own Bool = ilt<u64>(continuation, ast_count);
  let expected_valid: own Bool = ilt<u64>(expected_let, ast_count);
  let targets_first: own Bool = band<Bool>(function_valid, continuation_valid);
  let targets_valid: own Bool = band<Bool>(targets_first, expected_valid);
  let ast_match_atom_0284: own AstKind = AstMatch();
  let match_kind: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_match_atom_0284);
  let match_shape: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 3_u64);
  let ast_let_atom_0285: own AstKind = AstLet();
  let expected_kind: own Bool = semantic_body_kind_is(ast: ast, node: expected_let, want: ast_let_atom_0285);
  let root_first: own Bool = band<Bool>(targets_valid, match_kind);
  let root_second: own Bool = band<Bool>(match_shape, expected_kind);
  match band<Bool>(root_first, root_second) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = continuation;
      return False();
    }
  }

  let scrutinee: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 0_u64);
  let true_arm: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 1_u64);
  let false_arm: own u64 = semantic_body_child_at(ast: ast, node: node, ordinal: 2_u64);
  let ast_place_use_atom_0286: own AstKind = AstPlaceUse();
  let scrutinee_kind: own Bool = semantic_body_kind_is(ast: ast, node: scrutinee, want: ast_place_use_atom_0286);
  let scrutinee_leaf: own Bool = semantic_body_exact_children(ast: ast, node: scrutinee, want: 0_u64);
  let ast_match_arm_atom_0287: own AstKind = AstMatchArm();
  let true_arm_kind: own Bool = semantic_body_kind_is(ast: ast, node: true_arm, want: ast_match_arm_atom_0287);
  let ast_match_arm_atom_0288: own AstKind = AstMatchArm();
  let false_arm_kind: own Bool = semantic_body_kind_is(ast: ast, node: false_arm, want: ast_match_arm_atom_0288);
  let true_arm_shape: own Bool = semantic_body_exact_children(ast: ast, node: true_arm, want: 1_u64);
  let false_arm_shape: own Bool = semantic_body_exact_children(ast: ast, node: false_arm, want: 1_u64);
  let scrutinee_ok: own Bool = band<Bool>(scrutinee_kind, scrutinee_leaf);
  let arm_kinds: own Bool = band<Bool>(true_arm_kind, false_arm_kind);
  let arm_shapes: own Bool = band<Bool>(true_arm_shape, false_arm_shape);
  let arms_ok: own Bool = band<Bool>(arm_kinds, arm_shapes);
  match band<Bool>(scrutinee_ok, arms_ok) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = scrutinee;
      return False();
    }
  }

  let true_block: own u64 = semantic_body_child_at(ast: ast, node: true_arm, ordinal: 0_u64);
  let false_block: own u64 = semantic_body_child_at(ast: ast, node: false_arm, ordinal: 0_u64);
  let ast_block_atom_0289: own AstKind = AstBlock();
  let true_block_kind: own Bool = semantic_body_kind_is(ast: ast, node: true_block, want: ast_block_atom_0289);
  let ast_block_atom_0290: own AstKind = AstBlock();
  let false_block_kind: own Bool = semantic_body_kind_is(ast: ast, node: false_block, want: ast_block_atom_0290);
  let true_block_shape: own Bool = semantic_body_exact_children(ast: ast, node: true_block, want: 1_u64);
  let false_block_shape: own Bool = semantic_body_exact_children(ast: ast, node: false_block, want: 0_u64);
  let block_kinds: own Bool = band<Bool>(true_block_kind, false_block_kind);
  let block_shapes: own Bool = band<Bool>(true_block_shape, false_block_shape);
  match band<Bool>(block_kinds, block_shapes) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = true_block;
      return False();
    }
  }

  let early_return: own u64 = semantic_body_child_at(ast: ast, node: true_block, ordinal: 0_u64);
  let ast_return_atom_0291: own AstKind = AstReturn();
  let return_kind: own Bool = semantic_body_kind_is(ast: ast, node: early_return, want: ast_return_atom_0291);
  let return_shape: own Bool = semantic_body_exact_children(ast: ast, node: early_return, want: 1_u64);
  let constructor: own u64 = semantic_body_child_at(ast: ast, node: early_return, ordinal: 0_u64);
  let ast_constructor_atom_0292: own AstKind = AstConstructor();
  let constructor_kind: own Bool = semantic_body_kind_is(ast: ast, node: constructor, want: ast_constructor_atom_0292);
  let constructor_shape: own Bool = semantic_body_exact_children(ast: ast, node: constructor, want: 0_u64);
  let return_ok: own Bool = band<Bool>(return_kind, return_shape);
  let constructor_ok: own Bool = band<Bool>(constructor_kind, constructor_shape);
  match band<Bool>(return_ok, constructor_ok) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = early_return;
      return False();
    }
  }

  let true_head: own u64 = index<u64>(deref(ast).heads, true_arm);
  let false_head: own u64 = index<u64>(deref(ast).heads, false_arm);
  let constructor_head: own u64 = index<u64>(deref(ast).heads, constructor);
  let true_code: own PreludeConstructorCode = semantic_prelude_constructor_code(source: source, tokens: tokens, token: true_head);
  let false_code: own PreludeConstructorCode = semantic_prelude_constructor_code(source: source, tokens: tokens, token: false_head);
  let constructor_code: own PreludeConstructorCode = semantic_prelude_constructor_code(source: source, tokens: tokens, token: constructor_head);
  let true_tag: own PreludeConstructorCode = PreludeConstructorTrue();
  let false_tag: own PreludeConstructorCode = PreludeConstructorFalse();
  let true_pattern: own Bool = ieq<PreludeConstructorCode>(true_code, true_tag);
  let false_pattern: own Bool = ieq<PreludeConstructorCode>(false_code, false_tag);
  let return_true: own Bool = ieq<PreludeConstructorCode>(constructor_code, true_tag);
  let patterns: own Bool = band<Bool>(true_pattern, false_pattern);
  match band<Bool>(patterns, return_true) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = true_arm;
      return False();
    }
  }

  let scrutinee_type: own u64 = semantic_facts_none;
  region 'semantic_body_match_scrutinee {
    set scrutinee_type = semantic_body_analyze_atom(source: source, tokens: tokens, ast: ast, node: scrutinee, u8_type: 0_u64, facts: &uniq 'semantic_body_match_scrutinee deref(facts), scratch: scratch, report: &uniq 'semantic_body_match_scrutinee deref(report));
  }
  let scrutinee_declaration: own u64 = index<u64>(deref(facts).resolved_declarations, scrutinee);
  let scrutinee_mode: own SemanticValueMode = index<SemanticValueMode>(deref(facts).modes, scrutinee);
  let semantic_mode_own_atom_0293: own SemanticValueMode = SemanticModeOwn();
  let scrutinee_own: own Bool = ieq<SemanticValueMode>(scrutinee_mode, semantic_mode_own_atom_0293);
  let declaration_matches: own Bool = ieq<u64>(scrutinee_declaration, expected_let);
  let declaration_ordinal: own u64 = index<u64>(deref(facts).ordinals, expected_let);
  let ordinal_dominates: own Bool = ilt<u64>(declaration_ordinal, value_ordinal);
  let type_matches: own Bool = ieq<u64>(scrutinee_type, bool_type);
  let resolution_ok: own Bool = band<Bool>(declaration_matches, ordinal_dominates);
  let scrutinee_facts: own Bool = band<Bool>(type_matches, scrutinee_own);
  match band<Bool>(resolution_ok, scrutinee_facts) {
    True() => {
    }
    False() => {
      match ieq<u64>(scrutinee_type, semantic_facts_none) {
        True() => {
          return False();
        }
        False() => {
          set deref(report).status = SemanticBodyTypeMismatch();
          set deref(report).node = scrutinee;
          set deref(report).related = expected_let;
          return False();
        }
      }
    }
  }

  set index<u64>(deref(facts).control_targets, node) = continuation;
  set index<u64>(deref(facts).control_targets, scrutinee) = node;
  set index<u64>(deref(facts).type_ids, true_arm) = bool_type;
  set index<u64>(deref(facts).ordinals, true_arm) = 0_u64;
  set index<u64>(deref(facts).constant_values, true_arm) = 1_u64;
  set index<u64>(deref(facts).control_targets, true_arm) = early_return;
  set index<PreludeConstructorCode>(deref(facts).prelude_constructors, true_arm) = true_tag;
  set index<u64>(deref(facts).type_ids, false_arm) = bool_type;
  set index<u64>(deref(facts).ordinals, false_arm) = 1_u64;
  set index<u64>(deref(facts).constant_values, false_arm) = 0_u64;
  set index<u64>(deref(facts).control_targets, false_arm) = continuation;
  set index<PreludeConstructorCode>(deref(facts).prelude_constructors, false_arm) = false_tag;
  set index<u64>(deref(facts).control_targets, true_block) = early_return;
  set index<u64>(deref(facts).control_targets, false_block) = continuation;
  set index<u64>(deref(facts).type_ids, early_return) = bool_type;
  set index<SemanticValueMode>(deref(facts).modes, early_return) = SemanticModeOwn();
  set index<u64>(deref(facts).control_targets, early_return) = function;
  set index<u64>(deref(facts).type_ids, constructor) = bool_type;
  set index<u64>(deref(facts).constant_values, constructor) = 1_u64;
  set index<u64>(deref(facts).control_targets, constructor) = early_return;
  set index<SemanticValueMode>(deref(facts).modes, constructor) = SemanticModeOwn();
  set index<PreludeConstructorCode>(deref(facts).prelude_constructors, constructor) = true_tag;
  return True();
}

fn semantic_body_run ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64, validation: &'c AstValidationReport, symbols: &'c SymbolTape, types: &uniq 'w TypeTape, facts: &uniq 'w NodeFacts, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own unit reads('c 'w), writes('w), traps {
  set deref(types).status = SemanticFactsInvalidShape();
  set deref(types).node = semantic_facts_none;
  set deref(types).related = semantic_facts_none;
  set deref(facts).status = SemanticFactsInvalidShape();
  set deref(facts).node = semantic_facts_none;
  set deref(facts).related = semantic_facts_none;
  set deref(report).status = SemanticBodyInvalidTokenTape();
  set deref(report).node = ast_none;
  set deref(report).related = semantic_facts_none;

  let body_tokens_valid: own Bool = symbol_token_tape_shape_valid(tokens: tokens);
  match body_tokens_valid {
    True() => {
    }
    False() => {
      set deref(report).related = deref(tokens).count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_ast_valid: own Bool = semantic_body_ast_columns_valid(tokens: tokens, ast: ast);
  match body_ast_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidAstTape();
      set deref(report).node = function;
      set deref(report).related = deref(ast).count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_validation_tag: own AstValidationStatus = AstValidationClean();
  let body_validation_clean: own Bool = ieq<AstValidationStatus>(deref(validation).status, body_validation_tag);
  match body_validation_clean {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidValidation();
      set deref(report).node = deref(validation).node;
      set deref(report).related = deref(validation).related;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_symbols_valid: own Bool = symbol_lookup_entries_valid(source: source, tokens: tokens, symbols: symbols);
  match body_symbols_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidSymbolTape();
      set deref(report).node = function;
      set deref(report).related = deref(symbols).count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_count: own u64 = deref(ast).count;
  match ilt<u64>(function, body_count) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidFunction();
      set deref(report).node = function;
      set deref(report).related = body_count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_types_shape: own Bool = False();
  region 'semantic_body_check_type_shape {
    set body_types_shape = semantic_type_tape_shape_valid(types: &'semantic_body_check_type_shape deref(types));
  }
  let body_types_empty: own Bool = ieq<u64>(deref(types).count, 0_u64);
  let body_types_ready: own Bool = band<Bool>(body_types_shape, body_types_empty);
  match body_types_ready {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidTypeTape();
      set deref(report).node = function;
      set deref(report).related = deref(types).count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_facts_shape: own Bool = False();
  region 'semantic_body_check_fact_shape {
    set body_facts_shape = semantic_node_facts_shape_valid(facts: &'semantic_body_check_fact_shape deref(facts));
  }
  let body_facts_empty: own Bool = ieq<u64>(deref(facts).count, 0_u64);
  let body_facts_ready: own Bool = band<Bool>(body_facts_shape, body_facts_empty);
  match body_facts_ready {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidNodeFacts();
      set deref(report).node = function;
      set deref(report).related = deref(facts).count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let body_scratch_shape: own Bool = False();
  region 'semantic_body_check_scratch_shape {
    set body_scratch_shape = semantic_body_scratch_shape_valid(scratch: &'semantic_body_check_scratch_shape deref(scratch));
  }
  match body_scratch_shape {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidScratch();
      set deref(report).node = function;
      set deref(report).related = deref(scratch).count;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

  let ast_function_atom_0294: own AstKind = AstFunction();
  let body_function_kind: own Bool = semantic_body_kind_is(ast: ast, node: function, want: ast_function_atom_0294);
  let body_function_arity: own Bool = semantic_body_exact_children(ast: ast, node: function, want: 6_u64);
  let body_function_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: function);
  let body_function_first: own Bool = band<Bool>(body_function_kind, body_function_arity);
  let body_function_shape: own Bool = band<Bool>(body_function_first, body_function_token);
  match body_function_shape {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidFunction();
      set deref(report).node = function;
      set deref(report).related = 6_u64;
      set deref(types).status = SemanticFactsInvalidShape();
      set deref(facts).status = SemanticFactsInvalidShape();
      return unit;
    }
  }

