enum SemanticBodyStatus {
  SemanticBodyClean();
  SemanticBodyInvalidTokenTape();
  SemanticBodyInvalidAstTape();
  SemanticBodyInvalidValidation();
  SemanticBodyInvalidFunction();
  SemanticBodyInvalidTypeTape();
  SemanticBodyInvalidNodeFacts();
  SemanticBodyInvalidScratch();
  SemanticBodyCapacity();
  SemanticBodyMalformed();
  SemanticBodyUnsupported();
  SemanticBodyUnknownName();
  SemanticBodyTypeMismatch();
  SemanticBodyInvalidLiteral();
  SemanticBodyInvalidSymbolTape();
}

struct SemanticBodyReport {
  status: SemanticBodyStatus;
  node: u64;
  related: u64;
}

struct SemanticBodyScratch {
  name_tokens: buffer<u64>;
  declarations: buffer<u64>;
  type_ids: buffer<u64>;
  modes: buffer<SemanticValueMode>;
  count: u64;
}

fn semantic_body_set_report ['w] (report: &uniq 'w SemanticBodyReport, status: own SemanticBodyStatus, node: own u64, related: own u64) -> own unit writes('w) {
  set deref(report).status = status;
  set deref(report).node = node;
  set deref(report).related = related;
  return unit;
}

fn semantic_body_mark_failure ['w] (types: &uniq 'w TypeTape, facts: &uniq 'w NodeFacts, report: &uniq 'w SemanticBodyReport, status: own SemanticBodyStatus, node: own u64, related: own u64, fact_status: own SemanticFactsStatus) -> own unit writes('w) {
  set deref(types).status = fact_status;
  set deref(types).node = node;
  set deref(types).related = related;
  set deref(facts).status = fact_status;
  set deref(facts).node = node;
  set deref(facts).related = related;
  set deref(report).status = status;
  set deref(report).node = node;
  set deref(report).related = related;
  return unit;
}

fn semantic_body_ast_columns_valid ['c] (tokens: &'c TokenTape, ast: &'c AstTape) -> own Bool reads('c) {
  let parse_tag: own ParseStatus = ParseClean();
  let parse_clean: own Bool = ieq<ParseStatus>(deref(ast).status, parse_tag);
  match parse_clean {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let count: own u64 = deref(ast).count;
  let token_count: own u64 = deref(tokens).count;
  let kinds_length: own u64 = len<AstKind>(deref(ast).kinds);
  let heads_length: own u64 = len<u64>(deref(ast).heads);
  let starts_length: own u64 = len<u64>(deref(ast).starts);
  let ends_length: own u64 = len<u64>(deref(ast).ends);
  let first_length: own u64 = len<u64>(deref(ast).first_children);
  let last_length: own u64 = len<u64>(deref(ast).last_children);
  let next_length: own u64 = len<u64>(deref(ast).next_siblings);
  let kinds_ok: own Bool = ige<u64>(kinds_length, count);
  let heads_ok: own Bool = ige<u64>(heads_length, count);
  let starts_ok: own Bool = ige<u64>(starts_length, count);
  let ends_ok: own Bool = ige<u64>(ends_length, count);
  let first_ok: own Bool = ige<u64>(first_length, count);
  let last_ok: own Bool = ige<u64>(last_length, count);
  let next_ok: own Bool = ige<u64>(next_length, count);
  let pair0: own Bool = band<Bool>(kinds_ok, heads_ok);
  let pair1: own Bool = band<Bool>(starts_ok, ends_ok);
  let pair2: own Bool = band<Bool>(first_ok, last_ok);
  let first_four: own Bool = band<Bool>(pair0, pair1);
  let first_six: own Bool = band<Bool>(first_four, pair2);
  let columns_ok: own Bool = band<Bool>(first_six, next_ok);
  let count_ok: own Bool = ile<u64>(count, token_count);
  return band<Bool>(columns_ok, count_ok);
}

fn semantic_body_kind_is ['a] (ast: &'a AstTape, node: own u64, want: own AstKind) -> own Bool reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed: own AstKind = index<AstKind>(deref(ast).kinds, node);
  return ieq<AstKind>(observed, want);
}

fn semantic_body_exact_children ['a] (ast: &'a AstTape, node: own u64, want: own u64) -> own Bool reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let first: own u64 = index<u64>(deref(ast).first_children, node);
  let last: own u64 = index<u64>(deref(ast).last_children, node);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  match ieq<u64>(want, 0_u64) {
    True() => {
      return band<Bool>(first_none, last_none);
    }
    False() => {
    }
  }
  let either_none: own Bool = bor<Bool>(first_none, last_none);
  match either_none {
    True() => {
      return False();
    }
    False() => {
    }
  }
  let child: own u64 = first;
  let observed_count: own u64 = 0_u64;
  let steps: own u64 = 0_u64;
  loop @semantic_body_child_count {
    match ilt<u64>(child, count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    set observed_count = iadd.trap<u64>(observed_count, 1_u64);
    let at_last: own Bool = ieq<u64>(child, last);
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match at_last {
      True() => {
        let terminated: own Bool = ieq<u64>(next, ast_none);
        let exact: own Bool = ieq<u64>(observed_count, want);
        return band<Bool>(terminated, exact);
      }
      False() => {
      }
    }
    match ilt<u64>(next, count) {
      True() => {
        set child = next;
      }
      False() => {
        return False();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }
}

fn semantic_body_child_at ['a] (ast: &'a AstTape, node: own u64, ordinal: own u64) -> own u64 reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return ast_none;
    }
  }
  let child: own u64 = index<u64>(deref(ast).first_children, node);
  let cursor: own u64 = 0_u64;
  loop @semantic_body_child_at_loop {
    match ilt<u64>(child, count) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
    match ieq<u64>(cursor, ordinal) {
      True() => {
        return child;
      }
      False() => {
      }
    }
    let next_child: own u64 = index<u64>(deref(ast).next_siblings, child);
    set child = next_child;
    set cursor = iadd.trap<u64>(cursor, 1_u64);
    match ilt<u64>(cursor, count) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
  }
}

fn semantic_body_node_token_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  return token_ordinal_valid(source: source, tokens: tokens, token: head);
}

fn semantic_body_node_is_u8 ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let token_valid: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  match token_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
  match leaf {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  return parser_word2(source: source, tokens: tokens, token: head, a: 117_u8, b: 56_u8);
}

fn semantic_body_node_is_bool ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let token_valid: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
  match token_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
  match leaf {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  return semantic_prelude_is_bool(source: source, tokens: tokens, token: head);
}

fn semantic_body_scratch_shape_valid ['w] (scratch: &'w SemanticBodyScratch) -> own Bool reads('w) {
  let count: own u64 = deref(scratch).count;
  let names_length: own u64 = len<u64>(deref(scratch).name_tokens);
  let declarations_length: own u64 = len<u64>(deref(scratch).declarations);
  let types_length: own u64 = len<u64>(deref(scratch).type_ids);
  let modes_length: own u64 = len<SemanticValueMode>(deref(scratch).modes);
  let names_ok: own Bool = ile<u64>(count, names_length);
  let declarations_ok: own Bool = ile<u64>(count, declarations_length);
  let types_ok: own Bool = ile<u64>(count, types_length);
  let modes_ok: own Bool = ile<u64>(count, modes_length);
  let first: own Bool = band<Bool>(names_ok, declarations_ok);
  let second: own Bool = band<Bool>(types_ok, modes_ok);
  return band<Bool>(first, second);
}

fn semantic_body_scratch_capacity_valid ['w] (scratch: &'w SemanticBodyScratch, needed: own u64) -> own Bool reads('w) {
  let names_length: own u64 = len<u64>(deref(scratch).name_tokens);
  let declarations_length: own u64 = len<u64>(deref(scratch).declarations);
  let types_length: own u64 = len<u64>(deref(scratch).type_ids);
  let modes_length: own u64 = len<SemanticValueMode>(deref(scratch).modes);
  let names_ok: own Bool = ige<u64>(names_length, needed);
  let declarations_ok: own Bool = ige<u64>(declarations_length, needed);
  let types_ok: own Bool = ige<u64>(types_length, needed);
  let modes_ok: own Bool = ige<u64>(modes_length, needed);
  let first: own Bool = band<Bool>(names_ok, declarations_ok);
  let second: own Bool = band<Bool>(types_ok, modes_ok);
  return band<Bool>(first, second);
}

fn semantic_body_scope_push ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, scratch: &uniq 'w SemanticBodyScratch, name_token: own u64, declaration: own u64, type_id: own u64, mode: own SemanticValueMode) -> own Bool reads('c 'w), writes('w), traps {
  let name_valid: own Bool = symbol_name_token_valid(source: source, tokens: tokens, token: name_token, want_kind: 1_u64);
  match name_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let existing_slot: own u64 = semantic_facts_none;
  region 'semantic_body_scope_duplicate {
    set existing_slot = semantic_body_scope_find(source: source, tokens: tokens, scratch: &'semantic_body_scope_duplicate deref(scratch), name_token: name_token);
  }
  match ieq<u64>(existing_slot, semantic_facts_none) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let slot: own u64 = deref(scratch).count;
  let next_count: own u64 = iadd.trap<u64>(slot, 1_u64);
  let capacity_valid: own Bool = False();
  region 'semantic_body_scope_capacity {
    set capacity_valid = semantic_body_scratch_capacity_valid(scratch: &'semantic_body_scope_capacity deref(scratch), needed: next_count);
  }
  match capacity_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  set index<u64>(deref(scratch).name_tokens, slot) = name_token;
  set index<u64>(deref(scratch).declarations, slot) = declaration;
  set index<u64>(deref(scratch).type_ids, slot) = type_id;
  set index<SemanticValueMode>(deref(scratch).modes, slot) = mode;
  set deref(scratch).count = next_count;
  return True();
}

fn semantic_body_scope_find ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, scratch: &'w SemanticBodyScratch, name_token: own u64) -> own u64 reads('c 'w), traps {
  let query_valid: own Bool = symbol_name_token_valid(source: source, tokens: tokens, token: name_token, want_kind: 1_u64);
  match query_valid {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let cursor: own u64 = deref(scratch).count;
  loop @semantic_body_scope_lookup {
    match ieq<u64>(cursor, 0_u64) {
      True() => {
        return semantic_facts_none;
      }
      False() => {
      }
    }
    set cursor = isub.wrap<u64>(cursor, 1_u64);
    let candidate: own u64 = index<u64>(deref(scratch).name_tokens, cursor);
    let same: own Bool = token_text_equal(source: source, tokens: tokens, left: candidate, right: name_token);
    match same {
      True() => {
        return cursor;
      }
      False() => {
      }
    }
  }
}

fn semantic_body_initialize_types ['w] (types: &uniq 'w TypeTape) -> own unit writes('w), traps {
  set index<SemanticTypeKind>(deref(types).kinds, 0_u64) = SemanticTypeU8();
  set index<u64>(deref(types).declarations, 0_u64) = semantic_facts_none;
  set index<u64>(deref(types).element_types, 0_u64) = semantic_facts_none;
  set index<u64>(deref(types).array_lengths, 0_u64) = semantic_facts_none;
  set index<u64>(deref(types).source_nodes, 0_u64) = semantic_facts_none;
  set index<PreludeTypeCode>(deref(types).prelude_types, 0_u64) = PreludeTypeUnknown();

  set index<SemanticTypeKind>(deref(types).kinds, 1_u64) = SemanticTypeBool();
  set index<u64>(deref(types).declarations, 1_u64) = semantic_facts_none;
  set index<u64>(deref(types).element_types, 1_u64) = semantic_facts_none;
  set index<u64>(deref(types).array_lengths, 1_u64) = semantic_facts_none;
  set index<u64>(deref(types).source_nodes, 1_u64) = semantic_facts_none;
  set index<PreludeTypeCode>(deref(types).prelude_types, 1_u64) = PreludeTypeBool();
  set deref(types).count = 2_u64;
  set deref(types).status = SemanticFactsClean();
  set deref(types).node = semantic_facts_none;
  set deref(types).related = semantic_facts_none;
  return unit;
}

fn semantic_body_initialize_facts ['w] (facts: &uniq 'w NodeFacts, count: own u64) -> own unit writes('w), traps {
  let cursor: own u64 = 0_u64;
  loop @semantic_body_clear_fact_rows {
    match ige<u64>(cursor, count) {
      True() => {
        break @semantic_body_clear_fact_rows;
      }
      False() => {
      }
    }
    set index<u64>(deref(facts).type_ids, cursor) = semantic_facts_none;
    set index<u64>(deref(facts).resolved_declarations, cursor) = semantic_facts_none;
    set index<u64>(deref(facts).ordinals, cursor) = semantic_facts_none;
    set index<SemanticOperation>(deref(facts).operations, cursor) = SemanticOperationNone();
    set index<u64>(deref(facts).constant_values, cursor) = semantic_facts_none;
    set index<u64>(deref(facts).control_targets, cursor) = semantic_facts_none;
    set index<SemanticValueMode>(deref(facts).modes, cursor) = SemanticModeNone();
    set index<PreludeConstructorCode>(deref(facts).prelude_constructors, cursor) = PreludeConstructorUnknown();
    set cursor = iadd.trap<u64>(cursor, 1_u64);
  }
  set deref(facts).count = count;
  set deref(facts).status = SemanticFactsClean();
  set deref(facts).node = semantic_facts_none;
  set deref(facts).related = semantic_facts_none;
  return unit;
}

fn semantic_body_set_value_fact ['w] (facts: &uniq 'w NodeFacts, node: own u64, type_id: own u64, mode: own SemanticValueMode) -> own unit writes('w), traps {
  set index<u64>(deref(facts).type_ids, node) = type_id;
  set index<SemanticValueMode>(deref(facts).modes, node) = mode;
  return unit;
}

fn semantic_body_decimal_digit (byte: own u8) -> own u64 pure {
  match ieq<u8>(byte, 48_u8) {
    True() => {
      return 0_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 49_u8) {
    True() => {
      return 1_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 50_u8) {
    True() => {
      return 2_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 51_u8) {
    True() => {
      return 3_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 52_u8) {
    True() => {
      return 4_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 53_u8) {
    True() => {
      return 5_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 54_u8) {
    True() => {
      return 6_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 55_u8) {
    True() => {
      return 7_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 56_u8) {
    True() => {
      return 8_u64;
    }
    False() => {
    }
  }
  match ieq<u8>(byte, 57_u8) {
    True() => {
      return 9_u64;
    }
    False() => {
    }
  }
  return semantic_facts_none;
}

fn semantic_body_parse_u8_literal ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, token: own u64) -> own u64 reads('c), traps {
  let ordinal_valid: own Bool = token_ordinal_valid(source: source, tokens: tokens, token: token);
  match ordinal_valid {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let number_kind: own Bool = parser_kind_at_is(tokens: tokens, token: token, want: 6_u64);
  match number_kind {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, token);
  let end: own u64 = index<u64>(deref(tokens).ends, token);
  let width: own u64 = isub.wrap<u64>(end, start);
  match ige<u64>(width, 4_u64) {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let digit_count: own u64 = isub.wrap<u64>(width, 3_u64);
  let underscore_position: own u64 = iadd.trap<u64>(start, digit_count);
  let u_position: own u64 = iadd.trap<u64>(underscore_position, 1_u64);
  let eight_position: own u64 = iadd.trap<u64>(underscore_position, 2_u64);
  let underscore_byte: own u8 = index<u8>(deref(source), underscore_position);
  let u_byte: own u8 = index<u8>(deref(source), u_position);
  let eight_byte: own u8 = index<u8>(deref(source), eight_position);
  let underscore_ok: own Bool = ieq<u8>(underscore_byte, 95_u8);
  let u_ok: own Bool = ieq<u8>(u_byte, 117_u8);
  let eight_ok: own Bool = ieq<u8>(eight_byte, 56_u8);
  let suffix_first: own Bool = band<Bool>(underscore_ok, u_ok);
  let suffix_ok: own Bool = band<Bool>(suffix_first, eight_ok);
  match suffix_ok {
    True() => {
    }
    False() => {
      return semantic_facts_none;
    }
  }
  let first_byte: own u8 = index<u8>(deref(source), start);
  let leading_zero: own Bool = ieq<u8>(first_byte, 48_u8);
  let several_digits: own Bool = igt<u64>(digit_count, 1_u64);
  let noncanonical_zero: own Bool = band<Bool>(leading_zero, several_digits);
  match noncanonical_zero {
    True() => {
      return semantic_facts_none;
    }
    False() => {
    }
  }
  let offset: own u64 = 0_u64;
  let value: own u64 = 0_u64;
  loop @semantic_body_u8_digits {
    match ige<u64>(offset, digit_count) {
      True() => {
        return value;
      }
      False() => {
      }
    }
    let position: own u64 = iadd.trap<u64>(start, offset);
    let digit_byte: own u8 = index<u8>(deref(source), position);
    let digit_value: own u64 = semantic_body_decimal_digit(byte: digit_byte);
    match ieq<u64>(digit_value, semantic_facts_none) {
      True() => {
        return semantic_facts_none;
      }
      False() => {
      }
    }
    let below_twenty_five: own Bool = ilt<u64>(value, 25_u64);
    let at_twenty_five: own Bool = ieq<u64>(value, 25_u64);
    let final_digit_ok: own Bool = ile<u64>(digit_value, 5_u64);
    let edge_ok: own Bool = band<Bool>(at_twenty_five, final_digit_ok);
    let in_range: own Bool = bor<Bool>(below_twenty_five, edge_ok);
    match in_range {
      True() => {
      }
      False() => {
        return semantic_facts_none;
      }
    }
    let shifted: own u64 = imul.trap<u64>(value, 10_u64);
    set value = iadd.trap<u64>(shifted, digit_value);
    set offset = iadd.trap<u64>(offset, 1_u64);
  }
}

fn semantic_body_analyze_atom ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64, u8_type: own u64, facts: &uniq 'w NodeFacts, scratch: &'w SemanticBodyScratch, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  let atom_count: own u64 = deref(ast).count;
  match ilt<u64>(node, atom_count) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyMalformed();
      set deref(report).node = node;
      set deref(report).related = atom_count;
      return semantic_facts_none;
    }
  }
  let atom_kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  let place_tag: own AstKind = AstPlaceUse();
  let is_place: own Bool = ieq<AstKind>(atom_kind, place_tag);
  match is_place {
    True() => {
      let place_leaf: own Bool = semantic_body_exact_children(ast: ast, node: node, want: 0_u64);
      let place_token_ok: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: node);
      let place_shape_ok: own Bool = band<Bool>(place_leaf, place_token_ok);
      match place_shape_ok {
        True() => {
        }
        False() => {
