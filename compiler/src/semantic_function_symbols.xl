  let mode_kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  let own_tag: own AstKind = AstOwnMode();
  let shared_tag: own AstKind = AstSharedMode();
  let uniq_tag: own AstKind = AstUniqMode();
  let own_mode: own Bool = ieq<AstKind>(mode_kind, own_tag);
  let shared_mode: own Bool = ieq<AstKind>(mode_kind, shared_tag);
  let uniq_mode: own Bool = ieq<AstKind>(mode_kind, uniq_tag);
  match own_mode {
    True() => {
      let own_leaf: own Bool = semantic_function_leaf_valid(ast: ast, node: node);
      match own_leaf {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let own_head_valid: own Bool = semantic_function_head_token_valid(source: source, tokens: tokens, ast: ast, node: node, want_kind: 1_u64);
      match own_head_valid {
        True() => {
        }
        False() => {
          return False();
        }
      }
      let own_head: own u64 = index<u64>(deref(ast).heads, node);
      return parser_word3(source: source, tokens: tokens, token: own_head, a: 111_u8, b: 119_u8, c: 110_u8);
    }
    False() => {
    }
  }
  let borrow_mode: own Bool = bor<Bool>(shared_mode, uniq_mode);
  match borrow_mode {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let borrow_head: own u64 = index<u64>(deref(ast).heads, node);
  let borrow_token_valid: own Bool = token_ordinal_valid(source: source, tokens: tokens, token: borrow_head);
  match borrow_token_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let borrow_want_kind: own u64 = 10_u64;
  match uniq_mode {
    True() => {
      set borrow_want_kind = 11_u64;
    }
    False() => {
    }
  }
  let borrow_kind_valid: own Bool = parser_kind_at_is(tokens: tokens, token: borrow_head, want: borrow_want_kind);
  match borrow_kind_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let borrow_first: own u64 = index<u64>(deref(ast).first_children, node);
  let borrow_last: own u64 = index<u64>(deref(ast).last_children, node);
  let one_region: own Bool = ieq<u64>(borrow_first, borrow_last);
  match one_region {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let borrow_region_valid: own Bool = semantic_function_region_leaf_valid(source: source, tokens: tokens, ast: ast, node: borrow_first);
  match borrow_region_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let borrow_region_next: own u64 = index<u64>(deref(ast).next_siblings, borrow_first);
  return ieq<u64>(borrow_region_next, ast_none);
}

fn semantic_function_type_root_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, node: own u64, want: own AstKind) -> own Bool reads('s 't 'a), traps {
