enum SemanticFunctionSymbolsStatus {
  SemanticFunctionSymbolsClean();
  SemanticFunctionSymbolsInvalidTokenTape();
  SemanticFunctionSymbolsInvalidAstTape();
  SemanticFunctionSymbolsExpectedFunction();
  SemanticFunctionSymbolsMalformedFunction();
  SemanticFunctionSymbolsInvalidNameToken();
  SemanticFunctionSymbolsDuplicate();
  SemanticFunctionSymbolsCapacity();
  SemanticFunctionSymbolsInvalidSymbolTape();
}

struct SemanticFunctionSymbolsReport {
  status: SemanticFunctionSymbolsStatus;
  declaration: u64;
  related: u64;
}

fn semantic_function_node_valid ['a] (ast: &'a AstTape, node: own u64) -> own Bool reads('a) {
  return ilt<u64>(node, deref(ast).count);
}

fn semantic_function_leaf_valid ['a] (ast: &'a AstTape, node: own u64) -> own Bool reads('a), traps {
  let node_valid: own Bool = semantic_function_node_valid(ast: ast, node: node);
  match node_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let first_child: own u64 = index<u64>(deref(ast).first_children, node);
  let last_child: own u64 = index<u64>(deref(ast).last_children, node);
  let first_none: own Bool = ieq<u64>(first_child, ast_none);
  let last_none: own Bool = ieq<u64>(last_child, ast_none);
  return band<Bool>(first_none, last_none);
}

fn semantic_function_kind_is ['a] (ast: &'a AstTape, node: own u64, want: own AstKind) -> own Bool reads('a), traps {
  let node_valid: own Bool = semantic_function_node_valid(ast: ast, node: node);
  match node_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed_kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  return ieq<AstKind>(observed_kind, want);
}

fn semantic_function_head_token_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, node: own u64, want_kind: own u64) -> own Bool reads('s 't 'a), traps {
  let node_valid: own Bool = semantic_function_node_valid(ast: ast, node: node);
  match node_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head_token: own u64 = index<u64>(deref(ast).heads, node);
  return symbol_name_token_valid(source: source, tokens: tokens, token: head_token, want_kind: want_kind);
}

fn semantic_function_region_leaf_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, node: own u64) -> own Bool reads('s 't 'a), traps {
  let ast_region_atom_0470: own AstKind = AstRegion();
  let region_kind: own Bool = semantic_function_kind_is(ast: ast, node: node, want: ast_region_atom_0470);
  match region_kind {
