  let effect_head: own u64 = index<u64>(deref(ast).heads, node);
  match ieq<u64>(code, 0_u64) {
    True() => {
      return parser_word4(source: source, tokens: tokens, token: effect_head, a: 112_u8, b: 117_u8, c: 114_u8, d: 101_u8);
    }
    False() => {
