fn semantic_function_prior_region_duplicate ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, first: own u64, current: own u64, current_name: own u64) -> own u64 reads('s 't 'a), traps {
  let prior_region: own u64 = first;
  let duplicate_steps: own u64 = 0_u64;
  let duplicate_limit: own u64 = deref(ast).count;
  loop @prior_regions {
    match ieq<u64>(prior_region, current) {
      True() => {
        return ast_none;
      }
      False() => {
      }
    }
    match ilt<u64>(duplicate_steps, duplicate_limit) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
    let prior_region_name: own u64 = index<u64>(deref(ast).heads, prior_region);
    let same_region_name: own Bool = token_text_equal(source: source, tokens: tokens, left: prior_region_name, right: current_name);
    match same_region_name {
      True() => {
        return prior_region;
      }
      False() => {
      }
    }
    set prior_region = index<u64>(deref(ast).next_siblings, prior_region);
    set duplicate_steps = iadd.trap<u64>(duplicate_steps, 1_u64);
  }
}

