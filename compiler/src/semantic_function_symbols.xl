fn semantic_index_function_symbols ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64, symbols: &uniq 'w SymbolTape, report: &uniq 'w SemanticFunctionSymbolsReport) -> own unit reads('c 'w), writes('w), traps {
  set deref(report).status = SemanticFunctionSymbolsInvalidTokenTape();
  set deref(report).declaration = function;
  set deref(report).related = symbol_none;

  let function_token_tape_valid: own Bool = symbol_token_tape_shape_valid(tokens: tokens);
  match function_token_tape_valid {
    True() => {
    }
    False() => {
      set deref(report).related = deref(tokens).count;
      return unit;
    }
  }

  let function_ast_tape_valid: own Bool = semantic_globals_ast_tape_valid(ast: ast);
  match function_ast_tape_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticFunctionSymbolsInvalidAstTape();
      set deref(report).related = deref(ast).count;
      return unit;
    }
  }

  let function_symbols_valid: own Bool = False();
  region 'function_symbols_validate {
    set function_symbols_valid = symbol_tape_entries_valid(source: source, tokens: tokens, symbols: &uniq 'function_symbols_validate deref(symbols));
  }
  match function_symbols_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticFunctionSymbolsInvalidSymbolTape();
      set deref(report).related = deref(symbols).count;
      return unit;
    }
  }

  let function_ref_valid: own Bool = semantic_function_node_valid(ast: ast, node: function);
  match function_ref_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticFunctionSymbolsExpectedFunction();
      set deref(report).related = function;
      return unit;
    }
  }
  let ast_function_atom_0473: own AstKind = AstFunction();
  let function_kind_valid: own Bool = semantic_function_kind_is(ast: ast, node: function, want: ast_function_atom_0473);
  match function_kind_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticFunctionSymbolsExpectedFunction();
      set deref(report).related = function;
      return unit;
    }
  }
  let function_head_valid: own Bool = semantic_function_head_token_valid(source: source, tokens: tokens, ast: ast, node: function, want_kind: 1_u64);
  match function_head_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticFunctionSymbolsMalformedFunction();
      set deref(report).related = function;
      return unit;
    }
  }
  let function_head: own u64 = index<u64>(deref(ast).heads, function);
  let function_word_valid: own Bool = parser_word2(source: source, tokens: tokens, token: function_head, a: 102_u8, b: 110_u8);
  match function_word_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticFunctionSymbolsMalformedFunction();
      set deref(report).related = function_head;
      return unit;
    }
