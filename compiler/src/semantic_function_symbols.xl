            match arena_word_valid {
              True() => {
              }
              False() => {
                return False();
              }
            }
            let arena_region: own u64 = index<u64>(deref(ast).first_children, storage_cursor);
            let arena_region_last: own u64 = index<u64>(deref(ast).last_children, storage_cursor);
            let arena_one_region: own Bool = ieq<u64>(arena_region, arena_region_last);
            match arena_one_region {
