  match ieq<u64>(code, 1_u64) {
    True() => {
      return parser_word5(source: source, tokens: tokens, token: effect_head, a: 114_u8, b: 101_u8, c: 97_u8, d: 100_u8, e: 115_u8);
    }
    False() => {
    }
  }
  match ieq<u64>(code, 2_u64) {
    True() => {
      return parser_word6(source: source, tokens: tokens, token: effect_head, a: 119_u8, b: 114_u8, c: 105_u8, d: 116_u8, e: 101_u8, f: 115_u8);
    }
    False() => {
    }
  }
  return parser_word5(source: source, tokens: tokens, token: effect_head, a: 116_u8, b: 114_u8, c: 97_u8, d: 112_u8, e: 115_u8);
}

fn semantic_function_allocation_children_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, parent: own u64) -> own Bool reads('s 't 'a), traps {
