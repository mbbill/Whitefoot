    }
    False() => {
      return False();
    }
  }
  let region_leaf: own Bool = semantic_function_leaf_valid(ast: ast, node: node);
  match region_leaf {
    True() => {
    }
    False() => {
      return False();
    }
  }
  return semantic_function_head_token_valid(source: source, tokens: tokens, ast: ast, node: node, want_kind: 4_u64);
}

fn semantic_function_mode_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, node: own u64) -> own Bool reads('s 't 'a), traps {
