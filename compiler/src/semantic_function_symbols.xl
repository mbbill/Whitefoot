fn semantic_function_region_children_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, parent: own u64) -> own Bool reads('s 't 'a), traps {
  let region_parent_valid: own Bool = semantic_function_node_valid(ast: ast, node: parent);
  match region_parent_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let region_first: own u64 = index<u64>(deref(ast).first_children, parent);
  let region_last: own u64 = index<u64>(deref(ast).last_children, parent);
  let region_first_none: own Bool = ieq<u64>(region_first, ast_none);
  let region_last_none: own Bool = ieq<u64>(region_last, ast_none);
  let region_pair_valid: own Bool = ieq<Bool>(region_first_none, region_last_none);
  match region_pair_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  match region_first_none {
    True() => {
      return False();
    }
    False() => {
    }
  }
  let region_cursor: own u64 = region_first;
  let region_previous: own u64 = ast_none;
  let region_steps: own u64 = 0_u64;
  let ast_count: own u64 = deref(ast).count;
  loop @semantic_region_children {
    match ilt<u64>(region_steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let region_valid: own Bool = semantic_function_region_leaf_valid(source: source, tokens: tokens, ast: ast, node: region_cursor);
    match region_valid {
      True() => {
      }
      False() => {
        return False();
      }
    }
    set region_previous = region_cursor;
    let region_next: own u64 = index<u64>(deref(ast).next_siblings, region_cursor);
    match ieq<u64>(region_next, ast_none) {
      True() => {
        return ieq<u64>(region_previous, region_last);
      }
      False() => {
      }
    }
    let region_next_valid: own Bool = semantic_function_node_valid(ast: ast, node: region_next);
    match region_next_valid {
      True() => {
      }
      False() => {
        return False();
      }
    }
    set region_cursor = region_next;
    set region_steps = iadd.trap<u64>(region_steps, 1_u64);
  }
}

fn semantic_function_parameter_shape_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, parameter: own u64) -> own Bool reads('s 't 'a), traps {
  let ast_parameter_atom_0471: own AstKind = AstParameter();
  let parameter_kind: own Bool = semantic_function_kind_is(ast: ast, node: parameter, want: ast_parameter_atom_0471);
