}

fn semantic_unit_run ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, validation: &'c AstValidationReport, symbols: &'c SymbolTape, types: &uniq 'w TypeTape, facts: &uniq 'w NodeFacts, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticUnitReport) -> own unit reads('c 'w), writes('w), traps {
  set deref(report).status = SemanticUnitInvalidTokenTape();
  set deref(report).total = 0_u64;
  set deref(report).clean = 0_u64;
  set deref(report).unsupported = 0_u64;
  set deref(report).rejected = 0_u64;
  set deref(report).first_unsupported = semantic_facts_none;
  set deref(report).first_rejected = semantic_facts_none;

  let tokens_valid: own Bool = symbol_token_tape_shape_valid(tokens: tokens);
  match tokens_valid {
    True() => {
    }
    False() => {
      return unit;
    }
  }
  let ast_valid: own Bool = semantic_globals_ast_tape_valid(ast: ast);
  let ast_program_atom_0429: own AstKind = AstProgram();
  let root_kind: own Bool = semantic_body_kind_is(ast: ast, node: deref(ast).root, want: ast_program_atom_0429);
  match band<Bool>(ast_valid, root_kind) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticUnitInvalidAstTape();
      return unit;
    }
  }
  let ast_validation_clean_atom_0430: own AstValidationStatus = AstValidationClean();
  match ieq<AstValidationStatus>(deref(validation).status, ast_validation_clean_atom_0430) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticUnitInvalidValidation();
      return unit;
    }
  }
  let symbols_valid: own Bool = symbol_lookup_entries_valid(source: source, tokens: tokens, symbols: symbols);
  match symbols_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticUnitInvalidSymbolTape();
      return unit;
    }
  }

  let types_valid: own Bool = False();
  let facts_valid: own Bool = False();
  let scratch_valid: own Bool = False();
  region 'semantic_unit_run_type_shape {
    set types_valid = semantic_type_tape_shape_valid(types: &'semantic_unit_run_type_shape deref(types));
  }
  region 'semantic_unit_run_fact_shape {
    set facts_valid = semantic_node_facts_shape_valid(facts: &'semantic_unit_run_fact_shape deref(facts));
  }
  region 'semantic_unit_run_scratch_shape {
    set scratch_valid = semantic_body_scratch_shape_valid(scratch: &'semantic_unit_run_scratch_shape deref(scratch));
  }
  let work_first: own Bool = band<Bool>(types_valid, facts_valid);
  match band<Bool>(work_first, scratch_valid) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticUnitInvalidWork();
      return unit;
    }
  }

  let type_length0: own u64 = len<SemanticTypeKind>(deref(types).kinds);
  let type_length1: own u64 = len<u64>(deref(types).declarations);
  let type_length2: own u64 = len<u64>(deref(types).element_types);
  let type_length3: own u64 = len<u64>(deref(types).array_lengths);
  let type_length4: own u64 = len<u64>(deref(types).source_nodes);
  let type_length5: own u64 = len<PreludeTypeCode>(deref(types).prelude_types);
  let type_capacity0: own Bool = ige<u64>(type_length0, 4_u64);
  let type_capacity1: own Bool = ige<u64>(type_length1, 4_u64);
  let type_capacity2: own Bool = ige<u64>(type_length2, 4_u64);
  let type_capacity3: own Bool = ige<u64>(type_length3, 4_u64);
  let type_capacity4: own Bool = ige<u64>(type_length4, 4_u64);
  let type_capacity5: own Bool = ige<u64>(type_length5, 4_u64);
  let type_pair0: own Bool = band<Bool>(type_capacity0, type_capacity1);
  let type_pair1: own Bool = band<Bool>(type_capacity2, type_capacity3);
  let type_pair2: own Bool = band<Bool>(type_capacity4, type_capacity5);
  let type_first: own Bool = band<Bool>(type_pair0, type_pair1);
  let type_capacity: own Bool = band<Bool>(type_first, type_pair2);
  let needed_facts: own u64 = deref(ast).count;
  let fact_length0: own u64 = len<u64>(deref(facts).type_ids);
  let fact_length1: own u64 = len<u64>(deref(facts).resolved_declarations);
  let fact_length2: own u64 = len<u64>(deref(facts).ordinals);
  let fact_length3: own u64 = len<SemanticOperation>(deref(facts).operations);
  let fact_length4: own u64 = len<u64>(deref(facts).constant_values);
  let fact_length5: own u64 = len<u64>(deref(facts).control_targets);
  let fact_length6: own u64 = len<SemanticValueMode>(deref(facts).modes);
  let fact_length7: own u64 = len<PreludeConstructorCode>(deref(facts).prelude_constructors);
  let fact_capacity0: own Bool = ige<u64>(fact_length0, needed_facts);
  let fact_capacity1: own Bool = ige<u64>(fact_length1, needed_facts);
  let fact_capacity2: own Bool = ige<u64>(fact_length2, needed_facts);
  let fact_capacity3: own Bool = ige<u64>(fact_length3, needed_facts);
  let fact_capacity4: own Bool = ige<u64>(fact_length4, needed_facts);
  let fact_capacity5: own Bool = ige<u64>(fact_length5, needed_facts);
  let fact_capacity6: own Bool = ige<u64>(fact_length6, needed_facts);
  let fact_capacity7: own Bool = ige<u64>(fact_length7, needed_facts);
  let fact_pair0: own Bool = band<Bool>(fact_capacity0, fact_capacity1);
  let fact_pair1: own Bool = band<Bool>(fact_capacity2, fact_capacity3);
  let fact_pair2: own Bool = band<Bool>(fact_capacity4, fact_capacity5);
  let fact_pair3: own Bool = band<Bool>(fact_capacity6, fact_capacity7);
  let fact_first: own Bool = band<Bool>(fact_pair0, fact_pair1);
  let fact_second: own Bool = band<Bool>(fact_pair2, fact_pair3);
  let fact_capacity: own Bool = band<Bool>(fact_first, fact_second);
  let scratch_capacity: own Bool = False();
  region 'semantic_unit_run_scratch_capacity {
    set scratch_capacity = semantic_body_scratch_capacity_valid(scratch: &'semantic_unit_run_scratch_capacity deref(scratch), needed: 34_u64);
  }
  let capacity_first: own Bool = band<Bool>(type_capacity, fact_capacity);
  match band<Bool>(capacity_first, scratch_capacity) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticUnitCapacity();
      return unit;
    }
  }

  let root: own u64 = deref(ast).root;
  let first: own u64 = index<u64>(deref(ast).first_children, root);
  let last: own u64 = index<u64>(deref(ast).last_children, root);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  match band<Bool>(first_none, last_none) {
    True() => {
      set deref(report).status = SemanticUnitClean();
      return unit;
    }
    False() => {
    }
  }
  match bor<Bool>(first_none, last_none) {
    True() => {
      set deref(report).status = SemanticUnitInvalidAstTape();
      return unit;
    }
    False() => {
    }
  }

  let preflight: own u64 = first;
  let preflight_steps: own u64 = 0_u64;
  loop @semantic_unit_preflight_children {
    match ilt<u64>(preflight, deref(ast).count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticUnitInvalidAstTape();
        return unit;
      }
    }
    let at_last: own Bool = ieq<u64>(preflight, last);
    let next: own u64 = index<u64>(deref(ast).next_siblings, preflight);
    match at_last {
      True() => {
        match ieq<u64>(next, ast_none) {
          True() => {
            break @semantic_unit_preflight_children;
          }
          False() => {
            set deref(report).status = SemanticUnitInvalidAstTape();
            return unit;
          }
        }
      }
      False() => {
        match ilt<u64>(next, deref(ast).count) {
          True() => {
            set preflight = next;
          }
          False() => {
            set deref(report).status = SemanticUnitInvalidAstTape();
            return unit;
          }
        }
      }
    }
    set preflight_steps = iadd.trap<u64>(preflight_steps, 1_u64);
    match ilt<u64>(preflight_steps, deref(ast).count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticUnitInvalidAstTape();
        return unit;
      }
    }
  }

  let total: own u64 = 0_u64;
  let clean: own u64 = 0_u64;
  let unsupported: own u64 = 0_u64;
  let rejected: own u64 = 0_u64;
  let first_unsupported: own u64 = semantic_facts_none;
