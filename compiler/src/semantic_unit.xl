              return SemanticCapabilityFailed();
            }
          }
        }
      }
    }
  }

  let scanner_signature: own Bool = semantic_scanner_signature_valid(source: source, tokens: tokens, ast: ast, function: function);
  let scanner_body: own Bool = False();
  match scanner_signature {
    True() => {
      set scanner_body = semantic_scanner_body_valid(source: source, tokens: tokens, ast: ast, function: function, symbols: symbols);
    }
    False() => {
    }
  }
  match band<Bool>(scanner_signature, scanner_body) {
    True() => {
      region 'semantic_unit_dispatch_scanner {
        semantic_scanner_run(source: source, tokens: tokens, ast: ast, function: function, validation: validation, symbols: symbols, types: &uniq 'semantic_unit_dispatch_scanner deref(types), facts: &uniq 'semantic_unit_dispatch_scanner deref(facts), scratch: &uniq 'semantic_unit_dispatch_scanner deref(scratch), report: &uniq 'semantic_unit_dispatch_scanner body);
      }
      set deref(report).status = body.status;
      set deref(report).function = function;
      set deref(report).related = body.related;
      let semantic_body_clean_atom_0417: own SemanticBodyStatus = SemanticBodyClean();
      match ieq<SemanticBodyStatus>(body.status, semantic_body_clean_atom_0417) {
        True() => {
          return SemanticCapabilityScanner();
        }
        False() => {
          let semantic_body_unsupported_atom_0418: own SemanticBodyStatus = SemanticBodyUnsupported();
          match ieq<SemanticBodyStatus>(body.status, semantic_body_unsupported_atom_0418) {
            True() => {
              return SemanticCapabilityUnsupported();
            }
            False() => {
              return SemanticCapabilityFailed();
            }
          }
        }
      }
    }
    False() => {
    }
  }

  let linear_shape: own Bool = semantic_body_exact_children(ast: ast, node: function, want: 6_u64);
  match linear_shape {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).related = function;
      return SemanticCapabilityUnsupported();
    }
  }
  let linear_name: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 0_u64);
  let linear_parameter: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 1_u64);
  let linear_return_mode: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 2_u64);
  let linear_return_type: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 3_u64);
  let linear_effect: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 4_u64);
  let linear_block: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 5_u64);
  let linear_parameter_mode: own u64 = semantic_body_child_at(ast: ast, node: linear_parameter, ordinal: 0_u64);
  let linear_parameter_type: own u64 = semantic_body_child_at(ast: ast, node: linear_parameter, ordinal: 1_u64);

  let ast_function_name_atom_0419: own AstKind = AstFunctionName();
  let linear_name_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_name, want: ast_function_name_atom_0419);
  let linear_name_leaf: own Bool = semantic_body_exact_children(ast: ast, node: linear_name, want: 0_u64);
  let linear_name_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: linear_name);
  let linear_name_first: own Bool = band<Bool>(linear_name_kind, linear_name_leaf);
  let linear_name_valid: own Bool = band<Bool>(linear_name_first, linear_name_token);
  let ast_parameter_atom_0420: own AstKind = AstParameter();
  let linear_parameter_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_parameter, want: ast_parameter_atom_0420);
  let linear_parameter_shape: own Bool = semantic_body_exact_children(ast: ast, node: linear_parameter, want: 2_u64);
  let linear_parameter_token: own Bool = semantic_body_node_token_valid(source: source, tokens: tokens, ast: ast, node: linear_parameter);
  let linear_parameter_first: own Bool = band<Bool>(linear_parameter_kind, linear_parameter_shape);
  let linear_parameter_valid: own Bool = band<Bool>(linear_parameter_first, linear_parameter_token);
  let ast_own_mode_atom_0421: own AstKind = AstOwnMode();
  let linear_parameter_mode_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_parameter_mode, want: ast_own_mode_atom_0421);
  let linear_parameter_mode_leaf: own Bool = semantic_body_exact_children(ast: ast, node: linear_parameter_mode, want: 0_u64);
  let linear_parameter_mode_valid: own Bool = band<Bool>(linear_parameter_mode_kind, linear_parameter_mode_leaf);
  let ast_parameter_type_atom_0422: own AstKind = AstParameterType();
  let linear_parameter_type_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_parameter_type, want: ast_parameter_type_atom_0422);
  let linear_parameter_type_text: own Bool = semantic_body_node_is_u8(source: source, tokens: tokens, ast: ast, node: linear_parameter_type);
  let linear_parameter_type_valid: own Bool = band<Bool>(linear_parameter_type_kind, linear_parameter_type_text);
  let ast_own_mode_atom_0423: own AstKind = AstOwnMode();
  let linear_return_mode_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_return_mode, want: ast_own_mode_atom_0423);
  let linear_return_mode_leaf: own Bool = semantic_body_exact_children(ast: ast, node: linear_return_mode, want: 0_u64);
  let linear_return_mode_valid: own Bool = band<Bool>(linear_return_mode_kind, linear_return_mode_leaf);
  let ast_return_type_atom_0424: own AstKind = AstReturnType();
  let linear_return_type_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_return_type, want: ast_return_type_atom_0424);
  let linear_return_type_text: own Bool = semantic_body_node_is_bool(source: source, tokens: tokens, ast: ast, node: linear_return_type);
  let linear_return_type_valid: own Bool = band<Bool>(linear_return_type_kind, linear_return_type_text);
  let ast_pure_effect_atom_0425: own AstKind = AstPureEffect();
  let linear_effect_kind: own Bool = semantic_body_kind_is(ast: ast, node: linear_effect, want: ast_pure_effect_atom_0425);
  let linear_effect_leaf: own Bool = semantic_body_exact_children(ast: ast, node: linear_effect, want: 0_u64);
  let linear_effect_valid: own Bool = band<Bool>(linear_effect_kind, linear_effect_leaf);
  let ast_block_atom_0426: own AstKind = AstBlock();
  let linear_block_valid: own Bool = semantic_body_kind_is(ast: ast, node: linear_block, want: ast_block_atom_0426);
  let linear_signature0: own Bool = band<Bool>(linear_name_valid, linear_parameter_valid);
  let linear_signature1: own Bool = band<Bool>(linear_parameter_mode_valid, linear_parameter_type_valid);
  let linear_signature2: own Bool = band<Bool>(linear_return_mode_valid, linear_return_type_valid);
  let linear_signature3: own Bool = band<Bool>(linear_effect_valid, linear_block_valid);
  let linear_signature01: own Bool = band<Bool>(linear_signature0, linear_signature1);
  let linear_signature23: own Bool = band<Bool>(linear_signature2, linear_signature3);
  match band<Bool>(linear_signature01, linear_signature23) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).related = function;
      return SemanticCapabilityUnsupported();
    }
  }

  region 'semantic_unit_dispatch_linear {
    semantic_body_run(source: source, tokens: tokens, ast: ast, function: function, validation: validation, symbols: symbols, types: &uniq 'semantic_unit_dispatch_linear deref(types), facts: &uniq 'semantic_unit_dispatch_linear deref(facts), scratch: &uniq 'semantic_unit_dispatch_linear deref(scratch), report: &uniq 'semantic_unit_dispatch_linear body);
  }
  set deref(report).status = body.status;
  set deref(report).function = function;
  set deref(report).related = body.related;
  let semantic_body_clean_atom_0427: own SemanticBodyStatus = SemanticBodyClean();
  match ieq<SemanticBodyStatus>(body.status, semantic_body_clean_atom_0427) {
    True() => {
      return SemanticCapabilityLinear();
    }
    False() => {
      let semantic_body_unsupported_atom_0428: own SemanticBodyStatus = SemanticBodyUnsupported();
      match ieq<SemanticBodyStatus>(body.status, semantic_body_unsupported_atom_0428) {
        True() => {
          return SemanticCapabilityUnsupported();
