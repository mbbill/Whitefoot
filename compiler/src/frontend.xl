enum FrontendStage {
  FrontendClean();
  FrontendLex();
  FrontendParse();
  FrontendAstValidation();
  FrontendGlobals();
  FrontendTypeMembers();
  FrontendTypes();
  FrontendFunctionSymbols();
}

struct FrontendReport {
  stage: FrontendStage;
  status: u64;
  error_start: u64;
  error_end: u64;
  node: u64;
  related: u64;
  token_count: u64;
  node_count: u64;
  type_count: u64;
  symbol_count: u64;
  function_count: u64;
}

struct AnalyzedUnit {
  tokens: TokenTape;
  ast: AstTape;
  validation: AstValidationReport;
  symbols: SymbolTape;
  types: TypeTape;
  facts: NodeFacts;
}

fn frontend_lex_status_code (status: own LexStatus) -> own u64 pure {
  match status {
    LexClean() => {
      return 0_u64;
    }
    LexUnknownByte() => {
      return 1_u64;
    }
    LexInvalidString() => {
      return 2_u64;
    }
    LexUnterminatedString() => {
      return 3_u64;
    }
    LexInvalidRegionId() => {
      return 4_u64;
    }
    LexInvalidLabel() => {
      return 5_u64;
    }
    LexComment() => {
      return 6_u64;
    }
    LexCapacity() => {
      return 7_u64;
    }
  }
}

fn frontend_parse_status_code (status: own ParseStatus) -> own u64 pure {
  match status {
    ParseClean() => {
      return 0_u64;
    }
    ParseLexError() => {
      return 1_u64;
    }
    ParseExpectedFunction() => {
      return 2_u64;
    }
    ParseExpectedName() => {
      return 3_u64;
    }
    ParseExpectedLeftParen() => {
      return 4_u64;
    }
    ParseExpectedRightParen() => {
      return 5_u64;
    }
    ParseExpectedArrow() => {
      return 6_u64;
    }
    ParseExpectedOwn() => {
      return 7_u64;
    }
    ParseExpectedReturnType() => {
      return 8_u64;
    }
    ParseExpectedPure() => {
      return 9_u64;
    }
    ParseExpectedLeftBrace() => {
      return 10_u64;
    }
    ParseExpectedReturn() => {
      return 11_u64;
    }
    ParseExpectedUnit() => {
      return 12_u64;
    }
    ParseExpectedSemicolon() => {
      return 13_u64;
    }
    ParseExpectedRightBrace() => {
      return 14_u64;
    }
    ParseTrailingToken() => {
      return 15_u64;
    }
    ParseExpectedEnd() => {
      return 16_u64;
    }
    ParseCapacity() => {
      return 17_u64;
    }
    ParseInvalidTokenTape() => {
      return 18_u64;
    }
    ParseExpectedColon() => {
      return 19_u64;
    }
    ParseExpectedCommaOrRightParen() => {
      return 20_u64;
    }
    ParseExpectedStatement() => {
      return 21_u64;
    }
    ParseExpectedEquals() => {
      return 22_u64;
    }
    ParseExpectedExpression() => {
      return 23_u64;
    }
    ParseExpectedAtom() => {
      return 24_u64;
    }
    ParseExpectedLeftAngle() => {
      return 25_u64;
    }
    ParseExpectedRightAngle() => {
      return 26_u64;
    }
    ParseExpectedType() => {
      return 27_u64;
    }
    ParseExpectedMode() => {
      return 28_u64;
    }
    ParseExpectedRegion() => {
      return 29_u64;
    }
    ParseExpectedConstArgument() => {
      return 30_u64;
    }
    ParseExpectedEffect() => {
      return 31_u64;
    }
    ParseExpectedRightSquare() => {
      return 32_u64;
    }
    ParseExpectedTopLevelItem() => {
      return 33_u64;
    }
    ParseExpectedTypeName() => {
      return 34_u64;
    }
    ParseExpectedConstValue() => {
      return 35_u64;
    }
    ParseExpectedCommaOrRightSquare() => {
      return 36_u64;
    }
    ParseExpectedPlace() => {
      return 37_u64;
    }
    ParseExpectedLabel() => {
      return 38_u64;
    }
    ParseExpectedFatArrow() => {
      return 39_u64;
    }
    ParseExpectedStorage() => {
      return 40_u64;
    }
  }
}

fn frontend_ast_validation_status_code (status: own AstValidationStatus) -> own u64 pure {
  match status {
    AstValidationClean() => {
      return 0_u64;
    }
    AstValidationColumnCapacity() => {
      return 1_u64;
    }
    AstValidationScratchCapacity() => {
      return 2_u64;
    }
    AstValidationCountExceedsTokens() => {
      return 3_u64;
    }
    AstValidationEmpty() => {
      return 4_u64;
    }
    AstValidationRootReference() => {
      return 5_u64;
    }
    AstValidationHeadReference() => {
      return 6_u64;
    }
    AstValidationDuplicateHead() => {
      return 7_u64;
    }
    AstValidationSpan() => {
      return 8_u64;
    }
    AstValidationChildPair() => {
      return 9_u64;
    }
    AstValidationChildReference() => {
      return 10_u64;
    }
    AstValidationSiblingReference() => {
      return 11_u64;
    }
    AstValidationLastChild() => {
      return 12_u64;
    }
    AstValidationDuplicateReach() => {
      return 13_u64;
    }
    AstValidationUnreachable() => {
      return 14_u64;
    }
  }
}

