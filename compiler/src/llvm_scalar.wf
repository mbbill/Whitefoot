fn llvm_scalar_emit_indent ['o] (out: &uniq 'o ByteTape) -> own unit reads('o), writes('o), traps {
  region 'indent {
    byte_tape_emit_chunk(out: &uniq 'indent deref(out), count: 2_u64, b0: 32_u8, b1: 32_u8, b2: 32_u8, b3: 32_u8, b4: 32_u8, b5: 32_u8, b6: 32_u8, b7: 32_u8);
  }
  return unit;
}

fn llvm_scalar_emit_resolved_operand ['a, 'f, 'o] (ast: &'a AstTape, facts: &'f NodeFacts, place: own u64, out: &uniq 'o ByteTape) -> own unit reads('a 'f 'o), writes('o), traps {
  let declaration: own u64 = index<u64>(deref(facts).resolved_declarations, place);
  let declaration_kind: own AstKind = index<AstKind>(deref(ast).kinds, declaration);
  let ordinal: own u64 = index<u64>(deref(facts).ordinals, declaration);
  let parameter_tag: own AstKind = AstParameter();
  let is_parameter: own Bool = ieq<AstKind>(declaration_kind, parameter_tag);
  match is_parameter {
    True() => {
      region 'parameter_operand {
        llvm_text_emit_place(out: &uniq 'parameter_operand deref(out), id: ordinal);
      }
      return unit;
    }
    False() => {
    }
  }
  let let_tag: own AstKind = AstLet();
  let is_let: own Bool = ieq<AstKind>(declaration_kind, let_tag);
  match is_let {
    True() => {
      region 'let_operand {
        llvm_text_emit_value(out: &uniq 'let_operand deref(out), id: ordinal);
      }
    }
    False() => {
      region 'invalid_operand {
        llvm_scalar_fail(out: &uniq 'invalid_operand deref(out));
      }
    }
  }
  return unit;
}

fn llvm_scalar_emit_compare ['a, 'f, 'o] (ast: &'a AstTape, facts: &'f NodeFacts, call: own u64, place: own u64, numeric: own u64, value: own u64, out: &uniq 'o ByteTape) -> own unit reads('a 'f 'o), writes('o), traps {
  region 'compare_indent {
    llvm_scalar_emit_indent(out: &uniq 'compare_indent deref(out));
  }
  region 'compare_result {
    llvm_text_emit_value(out: &uniq 'compare_result deref(out), id: value);
  }
  region 'compare_result_space {
    llvm_text_emit_space(out: &uniq 'compare_result_space deref(out));
  }
  region 'compare_equal {
    llvm_text_emit_equal(out: &uniq 'compare_equal deref(out));
  }
  region 'compare_equal_space {
    llvm_text_emit_space(out: &uniq 'compare_equal_space deref(out));
  }

  let operation: own SemanticOperation = index<SemanticOperation>(deref(facts).operations, call);
  let uge_tag: own SemanticOperation = SemanticOperationIge();
  let is_uge: own Bool = ieq<SemanticOperation>(operation, uge_tag);
  match is_uge {
    True() => {
      region 'compare_uge {
        llvm_text_emit_icmp_uge(out: &uniq 'compare_uge deref(out));
      }
    }
    False() => {
      let ule_tag: own SemanticOperation = SemanticOperationIle();
      let is_ule: own Bool = ieq<SemanticOperation>(operation, ule_tag);
      match is_ule {
        True() => {
          region 'compare_ule {
            llvm_text_emit_icmp_ule(out: &uniq 'compare_ule deref(out));
          }
        }
        False() => {
          region 'compare_invalid {
            llvm_scalar_fail(out: &uniq 'compare_invalid deref(out));
          }
          return unit;
        }
      }
    }
  }
  region 'compare_operation_space {
    llvm_text_emit_space(out: &uniq 'compare_operation_space deref(out));
  }
  region 'compare_type {
    llvm_text_emit_i8(out: &uniq 'compare_type deref(out));
  }
  region 'compare_type_space {
    llvm_text_emit_space(out: &uniq 'compare_type_space deref(out));
  }
  region 'compare_operand {
    llvm_scalar_emit_resolved_operand(ast: ast, facts: facts, place: place, out: &uniq 'compare_operand deref(out));
  }
  region 'compare_comma {
    llvm_text_emit_comma(out: &uniq 'compare_comma deref(out));
  }
  region 'compare_comma_space {
    llvm_text_emit_space(out: &uniq 'compare_comma_space deref(out));
  }
  let constant: own u64 = index<u64>(deref(facts).constant_values, numeric);
  region 'compare_constant {
    byte_tape_emit_u64(out: &uniq 'compare_constant deref(out), value: constant);
  }
  region 'compare_newline {
    llvm_text_emit_newline(out: &uniq 'compare_newline deref(out));
  }
  return unit;
}

fn llvm_scalar_emit_band ['a, 'f, 'o] (ast: &'a AstTape, facts: &'f NodeFacts, call: own u64, left: own u64, right: own u64, value: own u64, out: &uniq 'o ByteTape) -> own unit reads('a 'f 'o), writes('o), traps {
  let operation: own SemanticOperation = index<SemanticOperation>(deref(facts).operations, call);
  let band_tag: own SemanticOperation = SemanticOperationBand();
  let is_band: own Bool = ieq<SemanticOperation>(operation, band_tag);
  match is_band {
    True() => {
    }
    False() => {
      region 'band_invalid {
        llvm_scalar_fail(out: &uniq 'band_invalid deref(out));
      }
      return unit;
    }
  }
  region 'band_indent {
    llvm_scalar_emit_indent(out: &uniq 'band_indent deref(out));
  }
  region 'band_result {
    llvm_text_emit_value(out: &uniq 'band_result deref(out), id: value);
  }
  region 'band_result_space {
    llvm_text_emit_space(out: &uniq 'band_result_space deref(out));
  }
  region 'band_equal {
    llvm_text_emit_equal(out: &uniq 'band_equal deref(out));
  }
  region 'band_equal_space {
    llvm_text_emit_space(out: &uniq 'band_equal_space deref(out));
  }
  region 'band_operation {
    llvm_text_emit_and(out: &uniq 'band_operation deref(out));
  }
  region 'band_operation_space {
    llvm_text_emit_space(out: &uniq 'band_operation_space deref(out));
  }
  region 'band_type {
    llvm_text_emit_i1(out: &uniq 'band_type deref(out));
  }
  region 'band_type_space {
    llvm_text_emit_space(out: &uniq 'band_type_space deref(out));
  }
  region 'band_left {
    llvm_scalar_emit_resolved_operand(ast: ast, facts: facts, place: left, out: &uniq 'band_left deref(out));
  }
  region 'band_comma {
    llvm_text_emit_comma(out: &uniq 'band_comma deref(out));
  }
  region 'band_comma_space {
    llvm_text_emit_space(out: &uniq 'band_comma_space deref(out));
  }
  region 'band_right {
    llvm_scalar_emit_resolved_operand(ast: ast, facts: facts, place: right, out: &uniq 'band_right deref(out));
  }
  region 'band_newline {
    llvm_text_emit_newline(out: &uniq 'band_newline deref(out));
  }
  return unit;
}

fn llvm_scalar_emit_function ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  region 'scalar_reset {
    byte_tape_reset(out: &uniq 'scalar_reset deref(out));
  }

  let ast_valid: own Bool = semantic_globals_ast_tape_valid(ast: ast);
  let tokens_valid: own Bool = llvm_scalar_tokens_valid(tokens: tokens);
  let types_valid: own Bool = semantic_type_tape_shape_valid(types: types);
  let facts_valid: own Bool = semantic_node_facts_shape_valid(facts: facts);
  let facts_clean_tag: own SemanticFactsStatus = SemanticFactsClean();
  let types_clean: own Bool = ieq<SemanticFactsStatus>(deref(types).status, facts_clean_tag);
  let facts_clean: own Bool = ieq<SemanticFactsStatus>(deref(facts).status, facts_clean_tag);
  let fact_count_exact: own Bool = ieq<u64>(deref(facts).count, deref(ast).count);
  let syntax_valid: own Bool = band<Bool>(ast_valid, tokens_valid);
  let first_valid: own Bool = band<Bool>(syntax_valid, types_valid);
  let second_valid: own Bool = band<Bool>(facts_valid, types_clean);
  let third_valid: own Bool = band<Bool>(facts_clean, fact_count_exact);
  let first_two: own Bool = band<Bool>(first_valid, second_valid);
  let tapes_valid: own Bool = band<Bool>(first_two, third_valid);
  match tapes_valid {
    True() => {
    }
    False() => {
      region 'scalar_bad_tapes {
        llvm_scalar_fail(out: &uniq 'scalar_bad_tapes deref(out));
      }
      return unit;
    }
  }

  let function_tag: own AstKind = AstFunction();
  let function_name_tag: own AstKind = AstFunctionName();
  let parameter_tag: own AstKind = AstParameter();
  let own_tag: own AstKind = AstOwnMode();
  let return_type_tag: own AstKind = AstReturnType();
  let pure_tag: own AstKind = AstPureEffect();
  let block_tag: own AstKind = AstBlock();
  let parameter_type_tag: own AstKind = AstParameterType();
  let let_tag: own AstKind = AstLet();
  let return_tag: own AstKind = AstReturn();
  let binding_name_tag: own AstKind = AstBindingName();
  let binding_type_tag: own AstKind = AstBindingType();
  let table_call_tag: own AstKind = AstTableCall();
  let type_argument_tag: own AstKind = AstTypeArgument();
  let place_tag: own AstKind = AstPlaceUse();
  let numeric_tag: own AstKind = AstNumericLiteral();
  let function_is_function: own Bool = llvm_scalar_node_is(ast: ast, node: function, expected: function_tag);
  match function_is_function {
    True() => {
    }
    False() => {
      region 'scalar_bad_function {
        llvm_scalar_fail(out: &uniq 'scalar_bad_function deref(out));
      }
      return unit;
    }
  }

  let name: own u64 = llvm_scalar_first_child(ast: ast, node: function);
  match llvm_scalar_node_is(ast: ast, node: name, expected: function_name_tag) {
    True() => {
    }
    False() => {
      region 'scalar_bad_name {
        llvm_scalar_fail(out: &uniq 'scalar_bad_name deref(out));
      }
      return unit;
    }
  }
  let parameter: own u64 = llvm_scalar_next(ast: ast, node: name);
  let return_mode: own u64 = llvm_scalar_next(ast: ast, node: parameter);
  let return_type: own u64 = llvm_scalar_next(ast: ast, node: return_mode);
  let pure_effect: own u64 = llvm_scalar_next(ast: ast, node: return_type);
  let block: own u64 = llvm_scalar_next(ast: ast, node: pure_effect);
  let parameter_kind: own Bool = llvm_scalar_node_is(ast: ast, node: parameter, expected: parameter_tag);
  let return_mode_kind: own Bool = llvm_scalar_node_is(ast: ast, node: return_mode, expected: own_tag);
  let return_type_kind: own Bool = llvm_scalar_node_is(ast: ast, node: return_type, expected: return_type_tag);
  let pure_kind: own Bool = llvm_scalar_node_is(ast: ast, node: pure_effect, expected: pure_tag);
  let block_kind: own Bool = llvm_scalar_node_is(ast: ast, node: block, expected: block_tag);
  let function_last_child: own u64 = llvm_scalar_last_child(ast: ast, node: function);
  let function_last: own Bool = ieq<u64>(function_last_child, block);
  let block_last_sibling: own Bool = llvm_scalar_next_is(ast: ast, node: block, expected: ast_none);
  let signature_first: own Bool = band<Bool>(parameter_kind, return_mode_kind);
  let signature_second: own Bool = band<Bool>(return_type_kind, pure_kind);
  let signature_third: own Bool = band<Bool>(block_kind, function_last);
  let signature_first_four: own Bool = band<Bool>(signature_first, signature_second);
  let signature_first_six: own Bool = band<Bool>(signature_first_four, signature_third);
  let signature_valid: own Bool = band<Bool>(signature_first_six, block_last_sibling);
  match signature_valid {
    True() => {
    }
    False() => {
      region 'scalar_bad_signature {
        llvm_scalar_fail(out: &uniq 'scalar_bad_signature deref(out));
      }
      return unit;
    }
  }

  let parameter_mode: own u64 = llvm_scalar_first_child(ast: ast, node: parameter);
  let parameter_type: own u64 = llvm_scalar_next(ast: ast, node: parameter_mode);
  let parameter_mode_kind: own Bool = llvm_scalar_node_is(ast: ast, node: parameter_mode, expected: own_tag);
  let parameter_type_kind: own Bool = llvm_scalar_node_is(ast: ast, node: parameter_type, expected: parameter_type_tag);
  let parameter_last_child: own u64 = llvm_scalar_last_child(ast: ast, node: parameter);
  let parameter_last: own Bool = ieq<u64>(parameter_last_child, parameter_type);
  let parameter_end: own Bool = llvm_scalar_next_is(ast: ast, node: parameter_type, expected: ast_none);
  let parameter_first: own Bool = band<Bool>(parameter_mode_kind, parameter_type_kind);
  let parameter_second: own Bool = band<Bool>(parameter_last, parameter_end);
  match band<Bool>(parameter_first, parameter_second) {
    True() => {
    }
    False() => {
      region 'scalar_bad_parameter {
        llvm_scalar_fail(out: &uniq 'scalar_bad_parameter deref(out));
      }
      return unit;
    }
  }

  let first_let: own u64 = llvm_scalar_first_child(ast: ast, node: block);
  let second_let: own u64 = llvm_scalar_next(ast: ast, node: first_let);
  let return_node: own u64 = llvm_scalar_next(ast: ast, node: second_let);
  let first_let_kind: own Bool = llvm_scalar_node_is(ast: ast, node: first_let, expected: let_tag);
  let second_let_kind: own Bool = llvm_scalar_node_is(ast: ast, node: second_let, expected: let_tag);
  let return_kind: own Bool = llvm_scalar_node_is(ast: ast, node: return_node, expected: return_tag);
  let block_last_child: own u64 = llvm_scalar_last_child(ast: ast, node: block);
  let block_last: own Bool = ieq<u64>(block_last_child, return_node);
  let return_end: own Bool = llvm_scalar_next_is(ast: ast, node: return_node, expected: ast_none);
  let statements_first: own Bool = band<Bool>(first_let_kind, second_let_kind);
  let statements_second: own Bool = band<Bool>(return_kind, block_last);
  let statements_first_four: own Bool = band<Bool>(statements_first, statements_second);
