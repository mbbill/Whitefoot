fn llvm_scalar_fail ['o] (out: &uniq 'o ByteTape) -> own unit writes('o) {
  set deref(out).status = ByteInvalidState();
  return unit;
}

fn llvm_scalar_node_is ['a] (ast: &'a AstTape, node: own u64, expected: own AstKind) -> own Bool reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed: own AstKind = index<AstKind>(deref(ast).kinds, node);
  return ieq<AstKind>(observed, expected);
}

fn llvm_scalar_leaf ['a] (ast: &'a AstTape, node: own u64) -> own Bool reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let first: own u64 = index<u64>(deref(ast).first_children, node);
  let last: own u64 = index<u64>(deref(ast).last_children, node);
  let first_none: own Bool = ieq<u64>(first, ast_none);
  let last_none: own Bool = ieq<u64>(last, ast_none);
  return band<Bool>(first_none, last_none);
}

fn llvm_scalar_next_is ['a] (ast: &'a AstTape, node: own u64, expected: own u64) -> own Bool reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed: own u64 = index<u64>(deref(ast).next_siblings, node);
  return ieq<u64>(observed, expected);
}

fn llvm_scalar_first_child ['a] (ast: &'a AstTape, node: own u64) -> own u64 reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
      return index<u64>(deref(ast).first_children, node);
    }
    False() => {
      return ast_none;
    }
  }
}

fn llvm_scalar_last_child ['a] (ast: &'a AstTape, node: own u64) -> own u64 reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
      return index<u64>(deref(ast).last_children, node);
    }
    False() => {
      return ast_none;
    }
  }
}

fn llvm_scalar_next ['a] (ast: &'a AstTape, node: own u64) -> own u64 reads('a), traps {
  let count: own u64 = deref(ast).count;
  match ilt<u64>(node, count) {
    True() => {
      return index<u64>(deref(ast).next_siblings, node);
    }
