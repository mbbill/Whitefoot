  }
  region 'function_right_brace {
    llvm_text_emit_right_brace(out: &uniq 'function_right_brace deref(out));
  }
  region 'function_newline {
    llvm_text_emit_newline(out: &uniq 'function_newline deref(out));
  }
  return unit;
}
