fn llvm_scalar_type_is ['y] (types: &'y TypeTape, type_id: own u64, expected: own SemanticTypeKind) -> own Bool reads('y), traps {
  let count: own u64 = deref(types).count;
  match ilt<u64>(type_id, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed: own SemanticTypeKind = index<SemanticTypeKind>(deref(types).kinds, type_id);
  return ieq<SemanticTypeKind>(observed, expected);
}

fn llvm_scalar_tokens_valid ['t] (tokens: &'t TokenTape) -> own Bool reads('t) {
  let clean_tag: own LexStatus = LexClean();
  let clean: own Bool = ieq<LexStatus>(deref(tokens).status, clean_tag);
  match clean {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let count: own u64 = deref(tokens).count;
  let kinds_length: own u64 = len<TokenKind>(deref(tokens).kinds);
  let starts_length: own u64 = len<u64>(deref(tokens).starts);
  let ends_length: own u64 = len<u64>(deref(tokens).ends);
  let kinds_ok: own Bool = ige<u64>(kinds_length, count);
  let starts_ok: own Bool = ige<u64>(starts_length, count);
  let ends_ok: own Bool = ige<u64>(ends_length, count);
  let offsets_ok: own Bool = band<Bool>(starts_ok, ends_ok);
  return band<Bool>(kinds_ok, offsets_ok);
}

fn llvm_scalar_name_token_valid ['s, 't] (source: &'s buffer<u8>, tokens: &'t TokenTape, token: own u64) -> own Bool reads('s 't), traps {
  let ordinal_valid: own Bool = token_ordinal_valid(source: source, tokens: tokens, token: token);
  match ordinal_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed_kind: own TokenKind = index<TokenKind>(deref(tokens).kinds, token);
  let word_tag: own TokenKind = TokWord();
  let is_word: own Bool = ieq<TokenKind>(observed_kind, word_tag);
  match is_word {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let start: own u64 = index<u64>(deref(tokens).starts, token);
  let end: own u64 = index<u64>(deref(tokens).ends, token);
  match ilt<u64>(start, end) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let first: own u8 = index<u8>(deref(source), start);
  let first_valid: own Bool = lexer_is_lower(c: first);
  match first_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let cursor: own u64 = iadd.trap<u64>(start, 1_u64);
  loop @llvm_scalar_name_tail {
    match ige<u64>(cursor, end) {
      True() => {
        return True();
      }
      False() => {
      }
    }
    let byte: own u8 = index<u8>(deref(source), cursor);
    let valid: own Bool = lexer_is_ident_tail(c: byte);
    match valid {
      True() => {
        set cursor = iadd.trap<u64>(cursor, 1_u64);
      }
      False() => {
        return False();
      }
    }
  }
}

fn llvm_scalar_node_type_is ['f, 'y] (facts: &'f NodeFacts, types: &'y TypeTape, node: own u64, expected: own SemanticTypeKind) -> own Bool reads('f 'y), traps {
  let fact_count: own u64 = deref(facts).count;
  match ilt<u64>(node, fact_count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let type_id: own u64 = index<u64>(deref(facts).type_ids, node);
  return llvm_scalar_type_is<'y>(types: types, type_id: type_id, expected: expected);
}

