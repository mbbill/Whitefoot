fn llvm_scalar_operation_is_compare ['f] (facts: &'f NodeFacts, node: own u64) -> own Bool reads('f), traps {
  let count: own u64 = deref(facts).count;
  match ilt<u64>(node, count) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let observed: own SemanticOperation = index<SemanticOperation>(deref(facts).operations, node);
  let ige_tag: own SemanticOperation = SemanticOperationIge();
  let ile_tag: own SemanticOperation = SemanticOperationIle();
  let is_ige: own Bool = ieq<SemanticOperation>(observed, ige_tag);
  let is_ile: own Bool = ieq<SemanticOperation>(observed, ile_tag);
  return bor<Bool>(is_ige, is_ile);
}

