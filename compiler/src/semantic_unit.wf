enum SemanticCapabilityKind {
  SemanticCapabilityFailed();
  SemanticCapabilityFixedWidth();
  SemanticCapabilityScanner();
  SemanticCapabilityLinear();
  SemanticCapabilityUnsupported();
  SemanticCapabilityAcyclic();
}

struct SemanticCapabilityReport {
  status: SemanticBodyStatus;
  function: u64;
  related: u64;
  rule: SemanticRuleId;
  fix: SemanticFixCode;
  primary_node: u64;
  related_node: u64;
  span_start: u64;
  span_end: u64;
  path: buffer<u64>;
  path_count: u64;
}

struct SemanticCapabilityResult {
  status: SemanticBodyStatus;
  function: u64;
  related: u64;
  rule: SemanticRuleId;
  fix: SemanticFixCode;
  primary_node: u64;
  related_node: u64;
}

enum SemanticUnitStatus {
  SemanticUnitClean();
  SemanticUnitInvalidTokenTape();
  SemanticUnitInvalidAstTape();
  SemanticUnitInvalidValidation();
  SemanticUnitInvalidSymbolTape();
  SemanticUnitInvalidWork();
  SemanticUnitCapacity();
  SemanticUnitInfrastructureFailure();
}

struct SemanticUnitReport {
  status: SemanticUnitStatus;
  total: u64;
  clean: u64;
  unsupported: u64;
  rejected: u64;
  first_unsupported: u64;
  first_rejected: u64;
  diagnostic_rule: SemanticRuleId;
  diagnostic_fix: SemanticFixCode;
  diagnostic_primary_node: u64;
  diagnostic_related_node: u64;
  diagnostic_span_start: u64;
  diagnostic_span_end: u64;
  diagnostic_path: buffer<u64>;
  diagnostic_path_count: u64;
}

enum SemanticDiagnosticStatus {
  SemanticDiagnosticReady();
  SemanticDiagnosticNone();
  SemanticDiagnosticCapacity();
  SemanticDiagnosticInvalidAst();
}

struct SemanticDiagnosticPathResult {
  status: SemanticDiagnosticStatus;
  count: u64;
}

struct SemanticDiagnosticParentResult {
  status: SemanticDiagnosticStatus;
  parent: u64;
  ordinal: u64;
}

fn semantic_diagnostic_invalid_parent () -> own SemanticDiagnosticParentResult pure {
  let status: own SemanticDiagnosticStatus = SemanticDiagnosticInvalidAst();
  return SemanticDiagnosticParentResult(status: status, parent: ast_none, ordinal: ast_none);
}

fn semantic_diagnostic_ready_parent (parent: own u64, ordinal: own u64) -> own SemanticDiagnosticParentResult pure {
  let status: own SemanticDiagnosticStatus = SemanticDiagnosticReady();
  return SemanticDiagnosticParentResult(status: status, parent: parent, ordinal: ordinal);
}

fn semantic_diagnostic_invalid_path () -> own SemanticDiagnosticPathResult pure {
  let status: own SemanticDiagnosticStatus = SemanticDiagnosticInvalidAst();
  return SemanticDiagnosticPathResult(status: status, count: 0_u64);
}

fn semantic_diagnostic_capacity_path () -> own SemanticDiagnosticPathResult pure {
  let status: own SemanticDiagnosticStatus = SemanticDiagnosticCapacity();
  return SemanticDiagnosticPathResult(status: status, count: 0_u64);
}

fn semantic_diagnostic_ready_path (count: own u64) -> own SemanticDiagnosticPathResult pure {
  let status: own SemanticDiagnosticStatus = SemanticDiagnosticReady();
  return SemanticDiagnosticPathResult(status: status, count: count);
}

fn semantic_diagnostic_find_parent ['a] (ast: &'a AstTape, current: own u64) -> own SemanticDiagnosticParentResult reads('a), traps {
  let count: own u64 = deref(ast).count;
  let parent: own u64 = ast_none;
  let child_ordinal: own u64 = ast_none;
  let candidate: own u64 = 0_u64;
  loop @semantic_diagnostic_parent_candidates {
    match ige<u64>(candidate, count) {
      True() => {
        break @semantic_diagnostic_parent_candidates;
      }
      False() => {
      }
    }
    let first: own u64 = index<u64>(deref(ast).first_children, candidate);
    let last: own u64 = index<u64>(deref(ast).last_children, candidate);
    let first_none: own Bool = ieq<u64>(first, ast_none);
    let last_none: own Bool = ieq<u64>(last, ast_none);
    match ieq<Bool>(first_none, last_none) {
      True() => {
      }
      False() => {
        return semantic_diagnostic_invalid_parent();
      }
    }
    match first_none {
      True() => {
      }
      False() => {
        let first_valid: own Bool = ilt<u64>(first, count);
        let last_valid: own Bool = ilt<u64>(last, count);
        match band<Bool>(first_valid, last_valid) {
          True() => {
          }
          False() => {
            return semantic_diagnostic_invalid_parent();
          }
        }
        let child: own u64 = first;
        let ordinal: own u64 = 0_u64;
        let child_steps: own u64 = 0_u64;
        let observed_last: own u64 = ast_none;
        loop @semantic_diagnostic_parent_children {
          match ilt<u64>(child, count) {
            True() => {
            }
            False() => {
              return semantic_diagnostic_invalid_parent();
            }
          }
          match ieq<u64>(child, current) {
            True() => {
              match ieq<u64>(parent, ast_none) {
                True() => {
                  set parent = candidate;
                  set child_ordinal = ordinal;
                }
                False() => {
                  return semantic_diagnostic_invalid_parent();
                }
              }
            }
            False() => {
            }
          }
          set observed_last = child;
          let following: own u64 = index<u64>(deref(ast).next_siblings, child);
          set child_steps = iadd.trap<u64>(child_steps, 1_u64);
          match ieq<u64>(following, ast_none) {
            True() => {
              break @semantic_diagnostic_parent_children;
            }
            False() => {
            }
          }
          match ilt<u64>(child_steps, count) {
            True() => {
            }
            False() => {
              return semantic_diagnostic_invalid_parent();
            }
          }
          set child = following;
          set ordinal = iadd.trap<u64>(ordinal, 1_u64);
        }
        match ieq<u64>(observed_last, last) {
          True() => {
          }
          False() => {
            return semantic_diagnostic_invalid_parent();
          }
        }
      }
    }
    set candidate = iadd.trap<u64>(candidate, 1_u64);
  }
  match ieq<u64>(parent, ast_none) {
    True() => {
      return semantic_diagnostic_invalid_parent();
    }
    False() => {
      return semantic_diagnostic_ready_parent(parent: parent, ordinal: child_ordinal);
    }
  }
}

fn semantic_diagnostic_write_path ['a, 'v, 'p] (source_length: own u64, token_count: own u64, ast: &'a AstTape, validation: &uniq 'v AstValidationReport, target: own u64, path: &uniq 'p buffer<u64>) -> own SemanticDiagnosticPathResult reads('a 'v 'p), writes('v 'p), traps {
  region 'semantic_diagnostic_refresh_validation {
    ast_validate(source_length: source_length, token_count: token_count, ast: ast, report: &uniq 'semantic_diagnostic_refresh_validation deref(validation));
  }
  match deref(validation).status {
    AstValidationClean() => {
    }
    AstValidationScratchCapacity() => {
      return semantic_diagnostic_capacity_path();
    }
    AstValidationColumnCapacity() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationCountExceedsTokens() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationEmpty() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationRootReference() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationHeadReference() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationDuplicateHead() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationSpan() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationChildPair() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationChildReference() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationSiblingReference() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationLastChild() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationDuplicateReach() => {
      return semantic_diagnostic_invalid_path();
    }
    AstValidationUnreachable() => {
      return semantic_diagnostic_invalid_path();
    }
  }

  let count: own u64 = deref(ast).count;
  match ieq<u64>(count, 0_u64) {
    True() => {
      return semantic_diagnostic_invalid_path();
    }
    False() => {
    }
  }
  let first_length: own u64 = len<u64>(deref(ast).first_children);
  let last_length: own u64 = len<u64>(deref(ast).last_children);
  let next_length: own u64 = len<u64>(deref(ast).next_siblings);
  let start_length: own u64 = len<u64>(deref(ast).starts);
  let end_length: own u64 = len<u64>(deref(ast).ends);
  let first_capacity: own Bool = ige<u64>(first_length, count);
  let last_capacity: own Bool = ige<u64>(last_length, count);
  let next_capacity: own Bool = ige<u64>(next_length, count);
  let start_capacity: own Bool = ige<u64>(start_length, count);
  let end_capacity: own Bool = ige<u64>(end_length, count);
  let child_columns: own Bool = band<Bool>(first_capacity, last_capacity);
  let span_columns: own Bool = band<Bool>(start_capacity, end_capacity);
  let tree_columns: own Bool = band<Bool>(child_columns, next_capacity);
  match band<Bool>(tree_columns, span_columns) {
    True() => {
    }
    False() => {
      return semantic_diagnostic_invalid_path();
    }
  }

  let root: own u64 = deref(ast).root;
  let target_valid: own Bool = ilt<u64>(target, count);
  let root_valid: own Bool = ilt<u64>(root, count);
  match band<Bool>(target_valid, root_valid) {
    True() => {
    }
    False() => {
      return semantic_diagnostic_invalid_path();
    }
  }
  let root_next: own u64 = index<u64>(deref(ast).next_siblings, root);
  match ieq<u64>(root_next, ast_none) {
    True() => {
    }
    False() => {
      return semantic_diagnostic_invalid_path();
    }
  }

  let current: own u64 = target;
  let depth: own u64 = 0_u64;
  loop @semantic_diagnostic_ancestors {
    match ieq<u64>(current, root) {
      True() => {
        break @semantic_diagnostic_ancestors;
      }
      False() => {
      }
    }
    let parent_result: own SemanticDiagnosticParentResult = semantic_diagnostic_find_parent(ast: ast, current: current);
    match parent_result.status {
      SemanticDiagnosticReady() => {
      }
      SemanticDiagnosticNone() => {
        return semantic_diagnostic_invalid_path();
      }
      SemanticDiagnosticCapacity() => {
        return semantic_diagnostic_invalid_path();
      }
      SemanticDiagnosticInvalidAst() => {
        return semantic_diagnostic_invalid_path();
      }
    }
    set depth = iadd.trap<u64>(depth, 1_u64);
    match ilt<u64>(depth, count) {
      True() => {
      }
      False() => {
        return semantic_diagnostic_invalid_path();
      }
    }
    set current = parent_result.parent;
  }

  let path_capacity: own u64 = len<u64>(deref(path));
  match ige<u64>(path_capacity, count) {
    True() => {
    }
    False() => {
      return semantic_diagnostic_capacity_path();
    }
  }

  set current = target;
  let remaining: own u64 = depth;
  loop @semantic_diagnostic_write_ancestors {
    match ieq<u64>(current, root) {
      True() => {
        break @semantic_diagnostic_write_ancestors;
      }
      False() => {
      }
    }
    let write_parent_result: own SemanticDiagnosticParentResult = semantic_diagnostic_find_parent(ast: ast, current: current);
    set remaining = isub.wrap<u64>(remaining, 1_u64);
    set index<u64>(deref(path), remaining) = write_parent_result.ordinal;
    set current = write_parent_result.parent;
  }
  return semantic_diagnostic_ready_path(count: depth);
}

fn semantic_unit_classify_validated ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, validation: &'c AstValidationReport, symbols: &'c SymbolTape, function: own u64, types: &uniq 'w TypeTape, facts: &uniq 'w NodeFacts, scratch: &uniq 'w SemanticBodyScratch, report: &uniq 'w SemanticCapabilityResult) -> own SemanticCapabilityKind reads('c 'w), writes('w), traps {
  set deref(report).status = SemanticBodyInvalidTokenTape();
  set deref(report).function = function;
  set deref(report).related = semantic_facts_none;
  set deref(report).rule = SemanticRuleNone();
  set deref(report).fix = SemanticFixNone();
  set deref(report).primary_node = function;
  set deref(report).related_node = ast_none;

  let tokens_valid: own Bool = symbol_token_tape_shape_valid(tokens: tokens);
  match tokens_valid {
    True() => {
    }
    False() => {
      set deref(report).related = deref(tokens).count;
      return SemanticCapabilityFailed();
    }
  }
  let ast_valid: own Bool = semantic_globals_ast_tape_valid(ast: ast);
  match ast_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidAstTape();
      set deref(report).related = deref(ast).count;
      return SemanticCapabilityFailed();
    }
  }
  let ast_validation_clean_atom_0412: own AstValidationStatus = AstValidationClean();
  let validation_clean: own Bool = ieq<AstValidationStatus>(deref(validation).status, ast_validation_clean_atom_0412);
  match validation_clean {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidValidation();
      set deref(report).function = deref(validation).node;
      set deref(report).related = deref(validation).related;
      set deref(report).primary_node = deref(validation).node;
      return SemanticCapabilityFailed();
    }
  }
  let symbols_valid: own Bool = symbol_lookup_entries_valid(source: source, tokens: tokens, symbols: symbols);
  match symbols_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidSymbolTape();
      set deref(report).related = deref(symbols).count;
      return SemanticCapabilityFailed();
    }
  }

  let types_valid: own Bool = False();
  region 'semantic_unit_dispatch_type_shape {
    set types_valid = semantic_type_tape_shape_valid(types: &'semantic_unit_dispatch_type_shape deref(types));
  }
  match types_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidTypeTape();
      set deref(report).related = deref(types).count;
      return SemanticCapabilityFailed();
    }
  }
  let facts_valid: own Bool = False();
  region 'semantic_unit_dispatch_fact_shape {
    set facts_valid = semantic_node_facts_shape_valid(facts: &'semantic_unit_dispatch_fact_shape deref(facts));
  }
  match facts_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidNodeFacts();
      set deref(report).related = deref(facts).count;
      return SemanticCapabilityFailed();
    }
  }
  let scratch_valid: own Bool = False();
  region 'semantic_unit_dispatch_scratch_shape {
    set scratch_valid = semantic_body_scratch_shape_valid(scratch: &'semantic_unit_dispatch_scratch_shape deref(scratch));
  }
  match scratch_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidScratch();
      set deref(report).related = deref(scratch).count;
      return SemanticCapabilityFailed();
    }
  }
  let function_valid: own Bool = semantic_buffer_top_level_function_valid(ast: ast, function: function);
  let ast_function_atom_0413: own AstKind = AstFunction();
  let function_kind: own Bool = semantic_body_kind_is(ast: ast, node: function, want: ast_function_atom_0413);
  match band<Bool>(function_valid, function_kind) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyInvalidFunction();
      set deref(report).related = deref(ast).count;
      return SemanticCapabilityFailed();
    }
  }

  region 'semantic_unit_dispatch_reset_types {
    semantic_type_tape_reset(types: &uniq 'semantic_unit_dispatch_reset_types deref(types));
  }
  region 'semantic_unit_dispatch_reset_facts {
    semantic_node_facts_reset(facts: &uniq 'semantic_unit_dispatch_reset_facts deref(facts));
  }
  set deref(scratch).count = 0_u64;

  let semantic_body_invalid_function_atom_0414: own SemanticBodyStatus = SemanticBodyInvalidFunction();
  let body_rule_none: own SemanticRuleId = SemanticRuleNone();
  let body_fix_none: own SemanticFixCode = SemanticFixNone();
  let body: own SemanticBodyReport = SemanticBodyReport(status: semantic_body_invalid_function_atom_0414, node: function, related: semantic_facts_none, rule: body_rule_none, fix: body_fix_none, related_node: ast_none);
  let width: own u64 = semantic_buffer_fixed_width_profile(source: source, tokens: tokens, ast: ast, function: function);
  match ieq<u64>(width, semantic_facts_none) {
    True() => {
    }
    False() => {
      let fixed_signature: own Bool = semantic_buffer_fixed_width_signature_valid(source: source, tokens: tokens, ast: ast, function: function);
      let fixed_body: own Bool = False();
      match fixed_signature {
        True() => {
          set fixed_body = semantic_buffer_fixed_width_body_valid(source: source, tokens: tokens, ast: ast, function: function);
        }
        False() => {
        }
      }
      match band<Bool>(fixed_signature, fixed_body) {
        True() => {
        }
        False() => {
          set deref(report).status = SemanticBodyUnsupported();
          set deref(report).related = function;
          set deref(report).primary_node = function;
          return SemanticCapabilityUnsupported();
        }
      }
      region 'semantic_unit_dispatch_fixed {
        semantic_buffer_fixed_width_run(source: source, tokens: tokens, ast: ast, function: function, validation: validation, symbols: symbols, types: &uniq 'semantic_unit_dispatch_fixed deref(types), facts: &uniq 'semantic_unit_dispatch_fixed deref(facts), scratch: &uniq 'semantic_unit_dispatch_fixed deref(scratch), report: &uniq 'semantic_unit_dispatch_fixed body);
      }
      set deref(report).status = body.status;
      set deref(report).function = function;
      set deref(report).related = body.related;
      set deref(report).rule = body.rule;
      set deref(report).fix = body.fix;
      set deref(report).primary_node = body.node;
      set deref(report).related_node = body.related_node;
      let semantic_body_clean_atom_0415: own SemanticBodyStatus = SemanticBodyClean();
      match ieq<SemanticBodyStatus>(body.status, semantic_body_clean_atom_0415) {
        True() => {
          return SemanticCapabilityFixedWidth();
        }
        False() => {
          let semantic_body_unsupported_atom_0416: own SemanticBodyStatus = SemanticBodyUnsupported();
          match ieq<SemanticBodyStatus>(body.status, semantic_body_unsupported_atom_0416) {
            True() => {
              return SemanticCapabilityUnsupported();
            }
            False() => {
              return SemanticCapabilityFailed();
            }
          }
        }
      }
    }
  }

  let scanner_signature: own Bool = semantic_scanner_signature_valid(source: source, tokens: tokens, ast: ast, function: function);
  let scanner_body: own Bool = False();
  match scanner_signature {
    True() => {
      set scanner_body = semantic_scanner_body_valid(source: source, tokens: tokens, ast: ast, function: function, symbols: symbols);
    }
    False() => {
    }
  }
  match band<Bool>(scanner_signature, scanner_body) {
    True() => {
      region 'semantic_unit_dispatch_scanner {
        semantic_scanner_run(source: source, tokens: tokens, ast: ast, function: function, validation: validation, symbols: symbols, types: &uniq 'semantic_unit_dispatch_scanner deref(types), facts: &uniq 'semantic_unit_dispatch_scanner deref(facts), scratch: &uniq 'semantic_unit_dispatch_scanner deref(scratch), report: &uniq 'semantic_unit_dispatch_scanner body);
      }
      set deref(report).status = body.status;
      set deref(report).function = function;
      set deref(report).related = body.related;
      set deref(report).rule = body.rule;
      set deref(report).fix = body.fix;
      set deref(report).primary_node = body.node;
      set deref(report).related_node = body.related_node;
      let semantic_body_clean_atom_0417: own SemanticBodyStatus = SemanticBodyClean();
      match ieq<SemanticBodyStatus>(body.status, semantic_body_clean_atom_0417) {
        True() => {
          return SemanticCapabilityScanner();
        }
        False() => {
          let semantic_body_unsupported_atom_0418: own SemanticBodyStatus = SemanticBodyUnsupported();
          match ieq<SemanticBodyStatus>(body.status, semantic_body_unsupported_atom_0418) {
            True() => {
              return SemanticCapabilityUnsupported();
            }
            False() => {
              return SemanticCapabilityFailed();
            }
          }
        }
      }
    }
    False() => {
    }
  }

  let reader_signature: own Bool = semantic_reader_signature_valid(source: source, tokens: tokens, ast: ast, function: function);
  match reader_signature {
    True() => {
      region 'semantic_unit_dispatch_reader {
        semantic_reader_run(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, scratch: &uniq 'semantic_unit_dispatch_reader deref(scratch), report: &uniq 'semantic_unit_dispatch_reader body);
      }
      set deref(report).status = body.status;
      set deref(report).function = function;
      set deref(report).related = body.related;
      set deref(report).rule = body.rule;
      set deref(report).fix = body.fix;
      set deref(report).primary_node = body.node;
      set deref(report).related_node = body.related_node;
      let semantic_body_clean_atom_reader: own SemanticBodyStatus = SemanticBodyClean();
      match ieq<SemanticBodyStatus>(body.status, semantic_body_clean_atom_reader) {
        True() => {
          return SemanticCapabilityAcyclic();
        }
        False() => {
          let semantic_body_unsupported_atom_reader: own SemanticBodyStatus = SemanticBodyUnsupported();
          match ieq<SemanticBodyStatus>(body.status, semantic_body_unsupported_atom_reader) {
            True() => {
