    let next: own u64 = index<u64>(deref(ast).next_siblings, preflight);
    match at_last {
      True() => {
        match ieq<u64>(next, ast_none) {
          True() => {
            break @semantic_unit_preflight_children;
          }
          False() => {
            set deref(report).status = SemanticUnitInvalidAstTape();
            return unit;
          }
        }
      }
      False() => {
        match ilt<u64>(next, deref(ast).count) {
          True() => {
            set preflight = next;
          }
          False() => {
            set deref(report).status = SemanticUnitInvalidAstTape();
            return unit;
          }
        }
      }
    }
    set preflight_steps = iadd.trap<u64>(preflight_steps, 1_u64);
    match ilt<u64>(preflight_steps, deref(ast).count) {
      True() => {
      }
      False() => {
        set deref(report).status = SemanticUnitInvalidAstTape();
        return unit;
      }
    }
  }

  let total: own u64 = 0_u64;
  let clean: own u64 = 0_u64;
  let unsupported: own u64 = 0_u64;
  let rejected: own u64 = 0_u64;
  let first_unsupported: own u64 = semantic_facts_none;
  let first_rejected: own u64 = semantic_facts_none;
  let first_diagnostic_status: own SemanticBodyStatus = SemanticBodyInvalidFunction();
  let first_diagnostic_rule: own SemanticRuleId = SemanticRuleNone();
  let first_diagnostic_fix: own SemanticFixCode = SemanticFixNone();
  let first_diagnostic_primary: own u64 = ast_none;
  let first_diagnostic_related: own u64 = ast_none;
  let cursor: own u64 = first;
  loop @semantic_unit_functions {
    let kind: own AstKind = index<AstKind>(deref(ast).kinds, cursor);
    let ast_function_atom_0431: own AstKind = AstFunction();
    match ieq<AstKind>(kind, ast_function_atom_0431) {
      True() => {
        set total = iadd.trap<u64>(total, 1_u64);
        let semantic_body_invalid_function_atom_0432: own SemanticBodyStatus = SemanticBodyInvalidFunction();
        let capability_rule_none: own SemanticRuleId = SemanticRuleNone();
        let capability_fix_none: own SemanticFixCode = SemanticFixNone();
        let capability_report: own SemanticCapabilityResult = SemanticCapabilityResult(status: semantic_body_invalid_function_atom_0432, function: cursor, related: semantic_facts_none, rule: capability_rule_none, fix: capability_fix_none, primary_node: cursor, related_node: ast_none);
        let capability: own SemanticCapabilityKind = SemanticCapabilityFailed();
        region 'semantic_unit_function_dispatch {
          set capability = semantic_unit_classify_validated(source: source, tokens: tokens, ast: ast, validation: &'semantic_unit_function_dispatch deref(validation), symbols: symbols, function: cursor, types: &uniq 'semantic_unit_function_dispatch deref(types), facts: &uniq 'semantic_unit_function_dispatch deref(facts), scratch: &uniq 'semantic_unit_function_dispatch deref(scratch), report: &uniq 'semantic_unit_function_dispatch capability_report);
        }
        let source_rejection: own Bool = False();
        match capability_report.status {
          SemanticBodyClean() => {
            set clean = iadd.trap<u64>(clean, 1_u64);
          }
          SemanticBodyUnsupported() => {
            match ieq<u64>(first_unsupported, semantic_facts_none) {
              True() => {
                set first_unsupported = cursor;
              }
              False() => {
              }
            }
            set unsupported = iadd.trap<u64>(unsupported, 1_u64);
          }
          SemanticBodyMalformed() => {
            set source_rejection = True();
          }
          SemanticBodyUnknownName() => {
            set source_rejection = True();
          }
          SemanticBodyTypeMismatch() => {
            set source_rejection = True();
          }
          SemanticBodyInvalidLiteral() => {
            set source_rejection = True();
          }
          SemanticBodyEffectMismatch() => {
            set source_rejection = True();
          }
          SemanticBodyInvalidTokenTape() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyInvalidAstTape() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyInvalidValidation() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyInvalidFunction() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyInvalidTypeTape() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyInvalidNodeFacts() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyInvalidScratch() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
          SemanticBodyCapacity() => {
            set deref(report).status = SemanticUnitCapacity();
            return unit;
          }
          SemanticBodyInvalidSymbolTape() => {
            set deref(report).status = SemanticUnitInfrastructureFailure();
            return unit;
          }
        }
        match source_rejection {
          True() => {
            let no_rule: own SemanticRuleId = SemanticRuleNone();
            match ieq<SemanticRuleId>(capability_report.rule, no_rule) {
              True() => {
                set deref(report).status = SemanticUnitInfrastructureFailure();
                return unit;
              }
              False() => {
              }
            }
            match ieq<u64>(first_rejected, semantic_facts_none) {
              True() => {
                set first_rejected = cursor;
                set first_diagnostic_status = capability_report.status;
                set first_diagnostic_rule = capability_report.rule;
                set first_diagnostic_fix = capability_report.fix;
                set first_diagnostic_primary = capability_report.primary_node;
                set first_diagnostic_related = capability_report.related_node;
              }
              False() => {
              }
            }
            set rejected = iadd.trap<u64>(rejected, 1_u64);
          }
          False() => {
          }
        }
      }
      False() => {
      }
    }
    match ieq<u64>(cursor, last) {
      True() => {
        break @semantic_unit_functions;
      }
      False() => {
        set cursor = index<u64>(deref(ast).next_siblings, cursor);
      }
    }
  }

  match ieq<u64>(first_rejected, semantic_facts_none) {
    True() => {
    }
    False() => {
      let first_result: own SemanticCapabilityResult = SemanticCapabilityResult(status: first_diagnostic_status, function: first_rejected, related: semantic_facts_none, rule: first_diagnostic_rule, fix: first_diagnostic_fix, primary_node: first_diagnostic_primary, related_node: first_diagnostic_related);
      let diagnostic_status: own SemanticDiagnosticStatus = SemanticDiagnosticInvalidAst();
      region 'semantic_unit_publish_first_rejection {
        set diagnostic_status = semantic_diagnostic_publish_unit(source_length: source_length, token_count: deref(tokens).count, ast: ast, validation: &uniq 'semantic_unit_publish_first_rejection deref(validation), result: &'semantic_unit_publish_first_rejection first_result, report: &uniq 'semantic_unit_publish_first_rejection deref(report));
      }
      match diagnostic_status {
        SemanticDiagnosticReady() => {
        }
        SemanticDiagnosticNone() => {
          set deref(report).status = SemanticUnitInfrastructureFailure();
          return unit;
        }
        SemanticDiagnosticCapacity() => {
          set deref(report).status = SemanticUnitCapacity();
          return unit;
        }
        SemanticDiagnosticInvalidAst() => {
          set deref(report).status = SemanticUnitInfrastructureFailure();
          return unit;
        }
      }
    }
  }
  set deref(report).status = SemanticUnitClean();
  set deref(report).total = total;
  set deref(report).clean = clean;
  set deref(report).unsupported = unsupported;
  set deref(report).rejected = rejected;
  set deref(report).first_unsupported = first_unsupported;
  set deref(report).first_rejected = first_rejected;
  return unit;
}
