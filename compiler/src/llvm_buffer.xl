    match ilt<u64>(statement_ordinal, add_count) {
      True() => {
        set let_type_id = semantic_buffer_type_u64;
      }
      False() => {
        match ilt<u64>(statement_ordinal, byte_limit) {
          True() => {
            set let_type_id = semantic_buffer_type_u8;
          }
          False() => {
          }
        }
      }
    }
    let let_declaration_rows: own Bool = llvm_buffer_let_facts_valid(ast: ast, facts: facts, declaration: let_declaration, type_id: let_type_id, ordinal: statement_ordinal);
    match let_declaration_rows {
      True() => {
      }
      False() => {
        return False();
      }
    }
    match ieq<u64>(statement_ordinal, last_let) {
      True() => {
        break @llvm_buffer_let_rows;
      }
      False() => {
        set statement_ordinal = iadd.trap<u64>(statement_ordinal, 1_u64);
      }
    }
  }

  let addend: own u64 = 1_u64;
  loop @llvm_buffer_add_fact_rows {
    let add_declaration_ordinal: own u64 = isub.trap<u64>(addend, 1_u64);
    let add_declaration: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: add_declaration_ordinal);
    let add_call: own u64 = llvm_linear_child_at(ast: ast, node: add_declaration, ordinal: 3_u64);
    let add_rows: own Bool = llvm_buffer_iadd_facts_valid(ast: ast, facts: facts, call: add_call, ordinal: add_declaration_ordinal, left_declaration: start_parameter, literal_value: addend);
    match add_rows {
      True() => {
      }
      False() => {
        return False();
      }
    }
    match ieq<u64>(addend, add_count) {
      True() => {
        break @llvm_buffer_add_fact_rows;
      }
      False() => {
        set addend = iadd.trap<u64>(addend, 1_u64);
      }
    }
  }

  let byte: own u64 = 0_u64;
  loop @llvm_buffer_index_fact_rows {
    let index_ordinal: own u64 = iadd.trap<u64>(add_count, byte);
    let index_declaration: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: index_ordinal);
    let index_call: own u64 = llvm_linear_child_at(ast: ast, node: index_declaration, ordinal: 3_u64);
    let index_subscript_declaration: own u64 = start_parameter;
    match ieq<u64>(byte, 0_u64) {
      True() => {
      }
      False() => {
        let index_add_ordinal: own u64 = isub.trap<u64>(byte, 1_u64);
        set index_subscript_declaration = llvm_linear_child_at(ast: ast, node: block, ordinal: index_add_ordinal);
      }
    }
    let index_rows: own Bool = llvm_buffer_index_facts_valid(ast: ast, facts: facts, node: index_call, ordinal: index_ordinal, source_declaration: source_parameter, subscript_declaration: index_subscript_declaration);
    match index_rows {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let next_byte: own u64 = iadd.trap<u64>(byte, 1_u64);
    match ieq<u64>(next_byte, width) {
      True() => {
        break @llvm_buffer_index_fact_rows;
      }
      False() => {
        set byte = next_byte;
      }
    }
  }

  let eq_base: own u64 = byte_limit;
  let comparison: own u64 = 0_u64;
  loop @llvm_buffer_eq_fact_rows {
    let eq_ordinal: own u64 = iadd.trap<u64>(eq_base, comparison);
    let eq_declaration: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: eq_ordinal);
    let eq_call: own u64 = llvm_linear_child_at(ast: ast, node: eq_declaration, ordinal: 3_u64);
    let eq_byte_ordinal: own u64 = iadd.trap<u64>(add_count, comparison);
    let eq_byte_declaration: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: eq_byte_ordinal);
    let eq_parameter_position: own u64 = iadd.trap<u64>(comparison, 4_u64);
    let eq_parameter: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: eq_parameter_position);
    let semantic_operation_ieq_atom_0655: own SemanticOperation = SemanticOperationIeq();
    let eq_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: eq_call, ordinal: eq_ordinal, operand_type: semantic_buffer_type_u8, operation: semantic_operation_ieq_atom_0655, left_declaration: eq_byte_declaration, right_declaration: eq_parameter);
    match eq_rows {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let next_comparison: own u64 = iadd.trap<u64>(comparison, 1_u64);
    match ieq<u64>(next_comparison, width) {
      True() => {
        break @llvm_buffer_eq_fact_rows;
      }
      False() => {
        set comparison = next_comparison;
      }
    }
  }

  let three_width: own u64 = imul.trap<u64>(width, 3_u64);
  let band_base: own u64 = isub.trap<u64>(three_width, 1_u64);
  let intermediate_count: own u64 = isub.trap<u64>(width, 2_u64);
  let band_index: own u64 = 0_u64;
  loop @llvm_buffer_band_fact_rows {
    let band_ordinal: own u64 = iadd.trap<u64>(band_base, band_index);
    let band_declaration: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: band_ordinal);
    let band_call: own u64 = llvm_linear_child_at(ast: ast, node: band_declaration, ordinal: 3_u64);
    let band_left_declaration: own u64 = llvm_buffer_band_left_declaration(ast: ast, block: block, width: width, band_index: band_index);
    let band_right_declaration: own u64 = llvm_buffer_band_right_declaration(ast: ast, block: block, width: width, band_index: band_index);
    let semantic_operation_band_atom_0656: own SemanticOperation = SemanticOperationBand();
    let band_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: band_call, ordinal: band_ordinal, operand_type: semantic_buffer_type_bool, operation: semantic_operation_band_atom_0656, left_declaration: band_left_declaration, right_declaration: band_right_declaration);
    match band_rows {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let next_band: own u64 = iadd.trap<u64>(band_index, 1_u64);
    match ieq<u64>(next_band, intermediate_count) {
      True() => {
        break @llvm_buffer_band_fact_rows;
      }
      False() => {
        set band_index = next_band;
      }
    }
  }
  let final_return: own u64 = llvm_linear_child_at(ast: ast, node: block, ordinal: let_count);
  let final_call: own u64 = llvm_linear_child_at(ast: ast, node: final_return, ordinal: 0_u64);
  let final_left_declaration: own u64 = llvm_buffer_final_band_left_declaration(ast: ast, block: block, width: width);
  let final_right_declaration: own u64 = llvm_buffer_final_band_right_declaration(ast: ast, block: block, width: width);
  let semantic_operation_band_atom_0657: own SemanticOperation = SemanticOperationBand();
  let final_rows: own Bool = llvm_buffer_binary_facts_valid(ast: ast, facts: facts, call: final_call, ordinal: let_count, operand_type: semantic_buffer_type_bool, operation: semantic_operation_band_atom_0657, left_declaration: final_left_declaration, right_declaration: final_right_declaration);
  let semantic_operation_none_atom_0658: own SemanticOperation = SemanticOperationNone();
  let semantic_mode_own_atom_0659: own SemanticValueMode = SemanticModeOwn();
  let prelude_constructor_unknown_atom_0660: own PreludeConstructorCode = PreludeConstructorUnknown();
  let final_return_row: own Bool = llvm_buffer_fact_row_valid(facts: facts, node: final_return, type_id: semantic_buffer_type_bool, resolution: semantic_facts_none, ordinal: let_count, operation: semantic_operation_none_atom_0658, constant: semantic_facts_none, target: semantic_facts_none, mode: semantic_mode_own_atom_0659, prelude: prelude_constructor_unknown_atom_0660);
  match band<Bool>(final_rows, final_return_row) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let expected_nondefault_product: own u64 = imul.trap<u64>(width, 36_u64);
  let expected_nondefault: own u64 = isub.trap<u64>(expected_nondefault_product, 10_u64);
  let observed_nondefault: own u64 = llvm_buffer_nondefault_fact_count(facts: facts);
  return ieq<u64>(observed_nondefault, expected_nondefault);
}

fn llvm_buffer_fixed_width_facts_valid ['s, 't, 'a, 'y, 'f] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts) -> own Bool reads('s 't 'a 'y 'f), traps {
  let width: own u64 = semantic_buffer_fixed_width_profile(source: source, tokens: tokens, ast: ast, function: function);
  return llvm_buffer_fixed_width_facts_valid_at(source: source, tokens: tokens, ast: ast, function: function, width: width, types: types, facts: facts);
}

fn llvm_buffer_fixed_width_append_ready ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, width: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &'o ByteTape) -> own Bool reads('s 't 'a 'y 'f 'o), traps {
  let appendable: own Bool = False();
  let source_size: own u64 = len<u8>(deref(source));
  let ast_nodes: own u64 = deref(ast).count;
  region 'llvm_buffer_ready_state {
    set appendable = llvm_linear_output_appendable(out: &'llvm_buffer_ready_state deref(out), source_size: source_size, ast_nodes: ast_nodes);
  }
  match appendable {
    True() => {
    }
    False() => {
      return False();
    }
  }
  return llvm_buffer_fixed_width_facts_valid_at(source: source, tokens: tokens, ast: ast, function: function, width: width, types: types, facts: facts);
}

fn llvm_buffer_emit_validated_fixed_width_function ['s, 't, 'a, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, width: own u64, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'f 'o), writes('o), traps {
  region 'llvm_buffer_validated_header {
    llvm_buffer_emit_header(source: source, tokens: tokens, ast: ast, function: function, width: width, out: &uniq 'llvm_buffer_validated_header deref(out));
  }
  region 'llvm_buffer_validated_body {
    llvm_buffer_emit_matcher_body(ast: ast, function: function, width: width, facts: facts, out: &uniq 'llvm_buffer_validated_body deref(out));
  }
  return unit;
}

fn llvm_buffer_append_fixed_width_at ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, width: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  let byte_invalid_state_atom_0661: own ByteStatus = ByteInvalidState();
  match ieq<ByteStatus>(deref(out).status, byte_invalid_state_atom_0661) {
    True() => {
      return unit;
    }
    False() => {
    }
  }
  let ready: own Bool = False();
  region 'llvm_buffer_append_ready {
    set ready = llvm_buffer_fixed_width_append_ready(source: source, tokens: tokens, ast: ast, function: function, width: width, types: types, facts: facts, out: &'llvm_buffer_append_ready deref(out));
  }
  match ready {
    True() => {
    }
    False() => {
      region 'llvm_buffer_append_bad_input {
        llvm_buffer_fail(out: &uniq 'llvm_buffer_append_bad_input deref(out));
      }
      return unit;
    }
  }
  region 'llvm_buffer_append_function {
    llvm_buffer_emit_validated_fixed_width_function(source: source, tokens: tokens, ast: ast, function: function, width: width, facts: facts, out: &uniq 'llvm_buffer_append_function deref(out));
  }
  return unit;
}

fn llvm_buffer_emit_fixed_width_at ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, width: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  region 'llvm_buffer_emit_reset {
    byte_tape_reset(out: &uniq 'llvm_buffer_emit_reset deref(out));
  }
  let ready: own Bool = False();
  region 'llvm_buffer_emit_ready {
    set ready = llvm_buffer_fixed_width_append_ready(source: source, tokens: tokens, ast: ast, function: function, width: width, types: types, facts: facts, out: &'llvm_buffer_emit_ready deref(out));
  }
  match ready {
    True() => {
    }
