  region 'llvm_buffer_emit_function {
    llvm_buffer_emit_validated_fixed_width_function(source: source, tokens: tokens, ast: ast, function: function, width: width, facts: facts, out: &uniq 'llvm_buffer_emit_function deref(out));
  }
  return unit;
}

