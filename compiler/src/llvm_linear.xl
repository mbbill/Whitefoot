  }
  region 'llvm_linear_user_right_paren {
    llvm_text_emit_right_paren(out: &uniq 'llvm_linear_user_right_paren deref(out));
  }
  region 'llvm_linear_user_newline {
    llvm_text_emit_newline(out: &uniq 'llvm_linear_user_newline deref(out));
  }
  return unit;
}

