    let next: own u64 = index<u64>(deref(ast).next_siblings, statement);
    match ilt<u64>(next, deref(ast).count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let ast_match_atom_0596: own AstKind = AstMatch();
    match llvm_linear_node_is(ast: ast, node: next, want: ast_match_atom_0596) {
      True() => {
        let continuation: own u64 = index<u64>(deref(ast).next_siblings, next);
        match llvm_linear_match_node_valid(ast: ast, types: types, facts: facts, function: function, node: next, expected_let: statement, continuation: continuation) {
          True() => {
            set statement = continuation;
            set value_ordinal = iadd.trap<u64>(value_ordinal, 1_u64);
            set match_count = iadd.trap<u64>(match_count, 1_u64);
            set steps = iadd.trap<u64>(steps, 2_u64);
          }
          False() => {
            return False();
          }
        }
      }
      False() => {
        match ige<u64>(match_count, 1_u64) {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let return_valid: own Bool = llvm_linear_match_return_valid(ast: ast, types: types, facts: facts, function: function, statement: next, final_let: statement, value_ordinal: value_ordinal);
        let return_last: own Bool = ieq<u64>(next, index<u64>(deref(ast).last_children, block));
        let return_end: own Bool = ieq<u64>(index<u64>(deref(ast).next_siblings, next), ast_none);
        let return0: own Bool = band<Bool>(return_valid, return_last);
        return band<Bool>(return0, return_end);
