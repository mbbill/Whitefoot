  }
  region 'llvm_linear_place_footer_newline {
    llvm_text_emit_newline(out: &uniq 'llvm_linear_place_footer_newline deref(out));
  }
  region 'llvm_linear_place_footer_brace {
    llvm_text_emit_right_brace(out: &uniq 'llvm_linear_place_footer_brace deref(out));
  }
  region 'llvm_linear_place_footer_function_newline {
    llvm_text_emit_newline(out: &uniq 'llvm_linear_place_footer_function_newline deref(out));
  }
  return unit;
}

fn llvm_linear_emit_match_body ['s, 't, 'a, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'f 'o), writes('o), traps {
  let block: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 5_u64);
  let statement: own u64 = index<u64>(deref(ast).first_children, block);
  let match_index: own u64 = 0_u64;
  loop @llvm_linear_emit_match_statements {
    let initializer: own u64 = llvm_linear_child_at(ast: ast, node: statement, ordinal: 3_u64);
    region 'llvm_linear_match_emit_let {
      llvm_linear_emit_initializer(source: source, tokens: tokens, ast: ast, facts: facts, value: initializer, out: &uniq 'llvm_linear_match_emit_let deref(out));
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, statement);
    let ast_match_atom_0604: own AstKind = AstMatch();
    match llvm_linear_node_is(ast: ast, node: next, want: ast_match_atom_0604) {
      True() => {
        let false_block: own u64 = iadd.trap<u64>(match_index, 1_u64);
        region 'llvm_linear_match_emit_branch {
          llvm_linear_emit_match_branch(ast: ast, facts: facts, node: next, false_block: false_block, out: &uniq 'llvm_linear_match_emit_branch deref(out));
        }
        match ieq<u64>(match_index, 0_u64) {
          True() => {
            region 'llvm_linear_match_emit_success_label {
              llvm_linear_emit_block_label(out: &uniq 'llvm_linear_match_emit_success_label deref(out), id: 0_u64);
            }
            region 'llvm_linear_match_emit_success_return {
              llvm_linear_emit_true_return(out: &uniq 'llvm_linear_match_emit_success_return deref(out));
            }
          }
          False() => {
          }
        }
        region 'llvm_linear_match_emit_false_label {
          llvm_linear_emit_block_label(out: &uniq 'llvm_linear_match_emit_false_label deref(out), id: false_block);
        }
        set statement = index<u64>(deref(ast).next_siblings, next);
        set match_index = false_block;
      }
      False() => {
        let place: own u64 = llvm_linear_child_at(ast: ast, node: next, ordinal: 0_u64);
        region 'llvm_linear_match_emit_footer {
          llvm_linear_emit_place_footer(facts: facts, place: place, out: &uniq 'llvm_linear_match_emit_footer deref(out));
        }
        return unit;
      }
    }
  }
}

fn llvm_linear_append_function ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  let invalid_tag: own ByteStatus = ByteInvalidState();
  match ieq<ByteStatus>(deref(out).status, invalid_tag) {
    True() => {
      return unit;
    }
    False() => {
    }
  }
  let appendable: own Bool = False();
  let source_size: own u64 = len<u8>(deref(source));
  let ast_nodes: own u64 = deref(ast).count;
  region 'llvm_linear_append_state {
    set appendable = llvm_linear_output_appendable(out: &'llvm_linear_append_state deref(out), source_size: source_size, ast_nodes: ast_nodes);
  }
  match appendable {
    True() => {
    }
    False() => {
      region 'llvm_linear_append_bad_state {
        llvm_linear_fail(out: &uniq 'llvm_linear_append_bad_state deref(out));
      }
      return unit;
    }
  }
  let linear_valid: own Bool = llvm_linear_table_function_valid(source: source, tokens: tokens, ast: ast, function: function, types: types, facts: facts);
  let match_valid: own Bool = False();
  match linear_valid {
    True() => {
    }
    False() => {
      set match_valid = llvm_linear_match_function_valid(source: source, tokens: tokens, ast: ast, function: function, types: types, facts: facts);
    }
  }
  match bor<Bool>(linear_valid, match_valid) {
    True() => {
    }
    False() => {
      region 'llvm_linear_append_bad_function {
        llvm_linear_fail(out: &uniq 'llvm_linear_append_bad_function deref(out));
      }
      return unit;
    }
  }
  region 'llvm_linear_append_header {
    llvm_linear_emit_header(source: source, tokens: tokens, ast: ast, function: function, facts: facts, out: &uniq 'llvm_linear_append_header deref(out));
  }
  match match_valid {
    True() => {
      region 'llvm_linear_append_match_body {
        llvm_linear_emit_match_body(source: source, tokens: tokens, ast: ast, function: function, facts: facts, out: &uniq 'llvm_linear_append_match_body deref(out));
      }
      return unit;
    }
    False() => {
    }
  }
  let block: own u64 = llvm_linear_child_at(ast: ast, node: function, ordinal: 5_u64);
  let statement: own u64 = index<u64>(deref(ast).first_children, block);
  loop @llvm_linear_emit_statements {
    let ast_let_atom_0605: own AstKind = AstLet();
    match llvm_linear_node_is(ast: ast, node: statement, want: ast_let_atom_0605) {
      True() => {
        let value: own u64 = llvm_linear_child_at(ast: ast, node: statement, ordinal: 3_u64);
        region 'llvm_linear_append_let {
          llvm_linear_emit_initializer(source: source, tokens: tokens, ast: ast, facts: facts, value: value, out: &uniq 'llvm_linear_append_let deref(out));
        }
        set statement = index<u64>(deref(ast).next_siblings, statement);
      }
      False() => {
        let value: own u64 = llvm_linear_child_at(ast: ast, node: statement, ordinal: 0_u64);
        region 'llvm_linear_append_return_value {
          llvm_linear_emit_call(ast: ast, facts: facts, call: value, out: &uniq 'llvm_linear_append_return_value deref(out));
        }
        region 'llvm_linear_append_footer {
          llvm_linear_emit_footer(facts: facts, call: value, out: &uniq 'llvm_linear_append_footer deref(out));
        }
        return unit;
      }
    }
  }
}

fn llvm_linear_emit_function ['s, 't, 'a, 'y, 'f, 'o] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, function: own u64, types: &'y TypeTape, facts: &'f NodeFacts, out: &uniq 'o ByteTape) -> own unit reads('s 't 'a 'y 'f 'o), writes('o), traps {
  region 'llvm_linear_emit_reset {
    byte_tape_reset(out: &uniq 'llvm_linear_emit_reset deref(out));
  }
  region 'llvm_linear_emit_append {
    llvm_linear_append_function(source: source, tokens: tokens, ast: ast, function: function, types: types, facts: facts, out: &uniq 'llvm_linear_emit_append deref(out));
  }
  return unit;
}
