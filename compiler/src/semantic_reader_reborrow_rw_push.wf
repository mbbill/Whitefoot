fn semantic_reader_reborrow_rw_arm_set ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, arm: own u64, expected_true: own Bool) -> own u64 reads('c), traps {
  let ast_match_arm_atom: own AstKind = AstMatchArm();
  let kind: own Bool = semantic_body_kind_is(ast: ast, node: arm, want: ast_match_arm_atom);
  let shape: own Bool = semantic_body_exact_children(ast: ast, node: arm, want: 1_u64);
  let start: own Bool = semantic_reader_writer_head_starts_node(source: source, tokens: tokens, ast: ast, node: arm);
  let head: own u64 = index<u64>(deref(ast).heads, arm);
  let code: own PreludeConstructorCode = semantic_prelude_constructor_code(source: source, tokens: tokens, token: head);
  let expected: own PreludeConstructorCode = PreludeConstructorFalse();
  match expected_true {
    True() => {
      set expected = PreludeConstructorTrue();
    }
    False() => {
    }
  }
  let tag_valid: own Bool = eeq<PreludeConstructorCode>(code, expected);
  let first: own Bool = band<Bool>(kind, shape);
  let second: own Bool = band<Bool>(start, tag_valid);
  match band<Bool>(first, second) {
    True() => {
    }
    False() => {
      return ast_none;
    }
  }
  let block: own u64 = semantic_body_child_at(ast: ast, node: arm, ordinal: 0_u64);
  let ast_block_atom: own AstKind = AstBlock();
  let block_kind: own Bool = semantic_body_kind_is(ast: ast, node: block, want: ast_block_atom);
  let block_shape: own Bool = semantic_body_exact_children(ast: ast, node: block, want: 1_u64);
  let block_token: own Bool = semantic_buffer_single_symbol_node(source: source, tokens: tokens, ast: ast, node: block, want: 123_u8);
  let block_first: own Bool = band<Bool>(block_kind, block_shape);
  match band<Bool>(block_first, block_token) {
    True() => {
    }
    False() => {
      return ast_none;
    }
  }
  let set_node: own u64 = semantic_body_child_at(ast: ast, node: block, ordinal: 0_u64);
  let set_valid: own Bool = semantic_reader_writer_control_set_header_valid(source: source, tokens: tokens, ast: ast, node: set_node);
  match set_valid {
    True() => {
      return set_node;
    }
    False() => {
      return ast_none;
    }
  }
}

fn semantic_reader_reborrow_rw_push_body_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64) -> own Bool reads('c), traps {
  let output_parameter: own u64 = semantic_body_child_at(ast: ast, node: function, ordinal: 2_u64);
