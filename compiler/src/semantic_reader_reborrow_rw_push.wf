fn semantic_reader_reborrow_rw_ilt_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64, left_head: own u64, right_head: own u64) -> own Bool reads('c), traps {
