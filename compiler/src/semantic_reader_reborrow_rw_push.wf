fn semantic_reader_reborrow_rw_place_matches ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64, expected_head: own u64) -> own Bool reads('c), traps {
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let kind: own Bool = semantic_body_kind_is(ast: ast, node: node, want: ast_place_use_atom);
  let token: own Bool = semantic_reader_writer_leaf_token_exact(source: source, tokens: tokens, ast: ast, node: node);
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let same: own Bool = token_text_equal(source: source, tokens: tokens, left: head, right: expected_head);
  let first: own Bool = band<Bool>(kind, token);
  return band<Bool>(first, same);
}

fn semantic_reader_reborrow_rw_names_distinct ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, first: own u64, second: own u64, third: own u64, fourth: own u64, fifth: own u64) -> own Bool reads('c), traps {
  let first_second: own Bool = token_text_equal(source: source, tokens: tokens, left: first, right: second);
  let first_third: own Bool = token_text_equal(source: source, tokens: tokens, left: first, right: third);
  let first_fourth: own Bool = token_text_equal(source: source, tokens: tokens, left: first, right: fourth);
  let first_fifth: own Bool = token_text_equal(source: source, tokens: tokens, left: first, right: fifth);
  let second_third: own Bool = token_text_equal(source: source, tokens: tokens, left: second, right: third);
  let second_fourth: own Bool = token_text_equal(source: source, tokens: tokens, left: second, right: fourth);
  let second_fifth: own Bool = token_text_equal(source: source, tokens: tokens, left: second, right: fifth);
  let third_fourth: own Bool = token_text_equal(source: source, tokens: tokens, left: third, right: fourth);
  let third_fifth: own Bool = token_text_equal(source: source, tokens: tokens, left: third, right: fifth);
  let fourth_fifth: own Bool = token_text_equal(source: source, tokens: tokens, left: fourth, right: fifth);
  let duplicate_a: own Bool = bor<Bool>(first_second, first_third);
  let duplicate_b: own Bool = bor<Bool>(first_fourth, first_fifth);
  let duplicate_c: own Bool = bor<Bool>(second_third, second_fourth);
  let duplicate_d: own Bool = bor<Bool>(second_fifth, third_fourth);
  let duplicate_e: own Bool = bor<Bool>(third_fifth, fourth_fifth);
  let duplicate_ab: own Bool = bor<Bool>(duplicate_a, duplicate_b);
  let duplicate_cd: own Bool = bor<Bool>(duplicate_c, duplicate_d);
  let duplicate_abcd: own Bool = bor<Bool>(duplicate_ab, duplicate_cd);
  let duplicate: own Bool = bor<Bool>(duplicate_abcd, duplicate_e);
  return bnot<Bool>(duplicate);
}

fn semantic_reader_reborrow_rw_field_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, writes_region_head: own u64, struct_decl: own u64, node: own u64, expected_type: own u64) -> own Bool reads('c), traps {
