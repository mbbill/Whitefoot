  let target_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: target, want: ast_field_place_atom);
  let target_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: target, want: 1_u64);
  let target_token: own Bool = semantic_reader_writer_head_ends_node<'c>(source: source, tokens: tokens, ast: ast, node: target);
  let target_first: own Bool = band<Bool>(target_kind, target_shape);
  match band<Bool>(target_first, target_token) {
    True() => {
    }
    False() => {
