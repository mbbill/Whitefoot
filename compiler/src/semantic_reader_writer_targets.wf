fn semantic_reader_writer_head_ends_node ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let token_valid: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: node);
  match token_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let token_end: own u64 = index<u64>(deref(tokens).ends, head);
  let node_end: own u64 = index<u64>(deref(ast).ends, node);
  return ieq<u64>(token_end, node_end);
}

fn semantic_reader_writer_uniq_place_valid ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, scratch: &'w SemanticBodyScratch, place: own u64) -> own Bool reads('c 'w), traps {
  let slot: own u64 = semantic_reader_place_slot<'c, 'w>(source: source, tokens: tokens, ast: ast, scratch: scratch, node: place);
  match ieq<u64>(slot, semantic_facts_none) {
    True() => {
      return False();
    }
    False() => {
    }
  }
  let mode: own SemanticValueMode = index<SemanticValueMode>(deref(scratch).modes, slot);
  let uniq_mode: own SemanticValueMode = SemanticModeUniq();
  match eeq<SemanticValueMode>(mode, uniq_mode) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let declaration: own u64 = index<u64>(deref(scratch).declarations, slot);
  let ast_parameter_atom: own AstKind = AstParameter();
  let parameter_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: declaration, want: ast_parameter_atom);
  let parameter_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: declaration, want: 2_u64);
  match band<Bool>(parameter_kind, parameter_shape) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let mode_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: declaration, ordinal: 0_u64);
  let ast_uniq_mode_atom: own AstKind = AstUniqMode();
  let mode_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: mode_node, want: ast_uniq_mode_atom);
  let mode_valid: own Bool = semantic_function_mode_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: mode_node);
  return band<Bool>(mode_kind, mode_valid);
}

fn semantic_reader_writer_index_target_type ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, scratch: &'w SemanticBodyScratch, target: own u64, report: &uniq 'w SemanticBodyReport) -> own u64 reads('c 'w), writes('w), traps {
  let element_type: own u64 = semantic_facts_none;
  let allow_writer_subscript: own Bool = True();
  region 'semantic_reader_writer_index_element {
    set element_type = semantic_reader_analyze_index<'c, 'semantic_reader_writer_index_element>(source: source, tokens: tokens, ast: ast, symbols: symbols, scratch: &'semantic_reader_writer_index_element deref(scratch), node: target, allow_writer_subscript: allow_writer_subscript, report: &uniq 'semantic_reader_writer_index_element deref(report));
  }
  match ieq<u64>(element_type, semantic_facts_none) {
    True() => {
      return semantic_facts_none;
    }
    False() => {
    }
  }
  let base: own u64 = semantic_body_child_at<'c>(ast: ast, node: target, ordinal: 1_u64);
  let ast_field_place_atom: own AstKind = AstFieldPlace();
  let base_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: base, want: ast_field_place_atom);
  let base_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: base, want: 1_u64);
  let base_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: base);
  let base_first: own Bool = band<Bool>(base_kind, base_shape);
  match band<Bool>(base_first, base_token) {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = target;
      set deref(report).related = base;
      return semantic_facts_none;
    }
  }
  let deref_node: own u64 = semantic_body_child_at<'c>(ast: ast, node: base, ordinal: 0_u64);
  let ast_deref_place_atom: own AstKind = AstDerefPlace();
  let deref_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: deref_node, want: ast_deref_place_atom);
  let deref_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: deref_node, want: 1_u64);
  let deref_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: deref_node);
  let deref_first: own Bool = band<Bool>(deref_kind, deref_shape);
  let deref_valid: own Bool = band<Bool>(deref_first, deref_token);
  match deref_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = target;
      set deref(report).related = deref_node;
      return semantic_facts_none;
    }
  }
  let deref_head: own u64 = index<u64>(deref(ast).heads, deref_node);
  let deref_word: own Bool = parser_word5<'c, 'c>(source: source, tokens: tokens, token: deref_head, a: 100_u8, b: 101_u8, c: 114_u8, d: 101_u8, e: 102_u8);
  match deref_word {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = target;
      set deref(report).related = deref_head;
      return semantic_facts_none;
    }
  }
  let place: own u64 = semantic_body_child_at<'c>(ast: ast, node: deref_node, ordinal: 0_u64);
  let uniq_root: own Bool = semantic_reader_writer_uniq_place_valid<'c, 'w>(source: source, tokens: tokens, ast: ast, scratch: scratch, place: place);
  match uniq_root {
    True() => {
      return element_type;
    }
    False() => {
      set deref(report).status = SemanticBodyUnsupported();
      set deref(report).node = target;
      set deref(report).related = place;
      return semantic_facts_none;
    }
  }
}

fn semantic_reader_writer_field_target_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, function: own u64, writes_region_head: own u64, target: own u64) -> own Bool reads('c), traps {
