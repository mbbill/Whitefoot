enum SemanticTypeMembersStatus {
  SemanticTypeMembersClean();
  SemanticTypeMembersInvalidTokenTape();
  SemanticTypeMembersInvalidAstTape();
  SemanticTypeMembersExpectedProgram();
  SemanticTypeMembersMalformedDeclaration();
  SemanticTypeMembersInvalidNameToken();
  SemanticTypeMembersDuplicate();
  SemanticTypeMembersCapacity();
  SemanticTypeMembersInvalidSymbolTape();
}

struct SemanticTypeMembersReport {
  status: SemanticTypeMembersStatus;
  declaration: u64;
  related: u64;
  variant_count: u64;
  field_count: u64;
}

fn semantic_type_members_node_valid ['a] (ast: &'a AstTape, node: own u64) -> own Bool reads('a) {
  return ilt<u64>(node, deref(ast).count);
}

fn semantic_type_members_kind_is ['a] (ast: &'a AstTape, node: own u64, want: own AstKind) -> own Bool reads('a), traps {
  let member_node_valid: own Bool = semantic_type_members_node_valid(ast: ast, node: node);
  match member_node_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let member_observed_kind: own AstKind = index<AstKind>(deref(ast).kinds, node);
  return ieq<AstKind>(member_observed_kind, want);
}

fn semantic_type_members_leaf_valid ['a] (ast: &'a AstTape, node: own u64) -> own Bool reads('a), traps {
  let member_leaf_node_valid: own Bool = semantic_type_members_node_valid(ast: ast, node: node);
  match member_leaf_node_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let member_leaf_first: own u64 = index<u64>(deref(ast).first_children, node);
  let member_leaf_last: own u64 = index<u64>(deref(ast).last_children, node);
  let member_leaf_first_none: own Bool = ieq<u64>(member_leaf_first, ast_none);
  let member_leaf_last_none: own Bool = ieq<u64>(member_leaf_last, ast_none);
  return band<Bool>(member_leaf_first_none, member_leaf_last_none);
}

fn semantic_type_members_head_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, node: own u64, want_kind: own u64) -> own Bool reads('s 't 'a), traps {
  let member_head_node_valid: own Bool = semantic_type_members_node_valid(ast: ast, node: node);
  match member_head_node_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let member_head_token: own u64 = index<u64>(deref(ast).heads, node);
  return symbol_name_token_valid(source: source, tokens: tokens, token: member_head_token, want_kind: want_kind);
}

fn semantic_type_members_prior_variant ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, root: own u64, current: own u64, name_token: own u64) -> own u64 reads('s 't 'a), traps {
  let variant_top: own u64 = index<u64>(deref(ast).first_children, root);
  let variant_top_steps: own u64 = 0_u64;
  let variant_scan_limit: own u64 = deref(ast).count;
  loop @member_prior_variant_tops {
    match ieq<u64>(variant_top, ast_none) {
      True() => {
        return ast_none;
      }
      False() => {
      }
    }
    match ilt<u64>(variant_top_steps, variant_scan_limit) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
    let variant_top_kind: own AstKind = index<AstKind>(deref(ast).kinds, variant_top);
    let variant_enum_tag: own AstKind = AstEnumDecl();
    let variant_is_enum: own Bool = ieq<AstKind>(variant_top_kind, variant_enum_tag);
    match variant_is_enum {
      True() => {
        let variant_name_node: own u64 = index<u64>(deref(ast).first_children, variant_top);
        let variant_cursor: own u64 = index<u64>(deref(ast).next_siblings, variant_name_node);
        let variant_member_steps: own u64 = 0_u64;
        loop @member_prior_variants {
          match ieq<u64>(variant_cursor, ast_none) {
            True() => {
              break @member_prior_variants;
            }
            False() => {
            }
          }
          match ieq<u64>(variant_cursor, current) {
            True() => {
              return ast_none;
            }
            False() => {
            }
          }
          match ilt<u64>(variant_member_steps, variant_scan_limit) {
            True() => {
            }
            False() => {
              return ast_none;
            }
          }
          let prior_variant_token: own u64 = index<u64>(deref(ast).heads, variant_cursor);
          let prior_variant_same: own Bool = token_text_equal(source: source, tokens: tokens, left: prior_variant_token, right: name_token);
          match prior_variant_same {
            True() => {
              return variant_cursor;
            }
            False() => {
            }
          }
          set variant_cursor = index<u64>(deref(ast).next_siblings, variant_cursor);
          set variant_member_steps = iadd.trap<u64>(variant_member_steps, 1_u64);
        }
      }
      False() => {
      }
    }
    set variant_top = index<u64>(deref(ast).next_siblings, variant_top);
    set variant_top_steps = iadd.trap<u64>(variant_top_steps, 1_u64);
  }
}

fn semantic_type_members_prior_field ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, first: own u64, current: own u64, name_token: own u64) -> own u64 reads('s 't 'a), traps {
  let prior_field: own u64 = first;
  let prior_field_steps: own u64 = 0_u64;
  let prior_field_limit: own u64 = deref(ast).count;
  loop @member_prior_fields {
    match ieq<u64>(prior_field, current) {
      True() => {
        return ast_none;
      }
      False() => {
      }
    }
    match ilt<u64>(prior_field_steps, prior_field_limit) {
      True() => {
      }
      False() => {
        return ast_none;
      }
    }
    let prior_field_token: own u64 = index<u64>(deref(ast).heads, prior_field);
    let prior_field_same: own Bool = token_text_equal(source: source, tokens: tokens, left: prior_field_token, right: name_token);
    match prior_field_same {
      True() => {
        return prior_field;
      }
      False() => {
      }
    }
    set prior_field = index<u64>(deref(ast).next_siblings, prior_field);
    set prior_field_steps = iadd.trap<u64>(prior_field_steps, 1_u64);
  }
}

fn semantic_type_members_field_shape_valid ['s, 't, 'a] (source: &'s buffer<u8>, tokens: &'t TokenTape, ast: &'a AstTape, field: own u64) -> own Bool reads('s 't 'a), traps {
  let ast_field_atom_0476: own AstKind = AstField();
  let field_kind_valid: own Bool = semantic_type_members_kind_is(ast: ast, node: field, want: ast_field_atom_0476);
  match field_kind_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let field_type: own u64 = index<u64>(deref(ast).first_children, field);
  let field_last: own u64 = index<u64>(deref(ast).last_children, field);
  let field_one_type: own Bool = ieq<u64>(field_type, field_last);
  match field_one_type {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let ast_field_type_atom_0477: own AstKind = AstFieldType();
  let field_type_kind_valid: own Bool = semantic_type_members_kind_is(ast: ast, node: field_type, want: ast_field_type_atom_0477);
  match field_type_kind_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let field_type_head: own u64 = index<u64>(deref(ast).heads, field_type);
  let field_type_head_valid: own Bool = token_ordinal_valid(source: source, tokens: tokens, token: field_type_head);
  match field_type_head_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let field_type_word: own Bool = parser_kind_at_is(tokens: tokens, token: field_type_head, want: 1_u64);
  let field_type_named: own Bool = parser_kind_at_is(tokens: tokens, token: field_type_head, want: 3_u64);
  let field_type_token_valid: own Bool = bor<Bool>(field_type_word, field_type_named);
  match field_type_token_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let after_field_type: own u64 = index<u64>(deref(ast).next_siblings, field_type);
  return ieq<u64>(after_field_type, ast_none);
}

fn semantic_index_type_members ['c, 'w] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &uniq 'w SymbolTape, report: &uniq 'w SemanticTypeMembersReport) -> own unit reads('c 'w), writes('w), traps {
