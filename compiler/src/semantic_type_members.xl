                False() => {
                  set deref(report).status = SemanticTypeMembersMalformedDeclaration();
                  set deref(report).declaration = members_top;
                  set deref(report).related = struct_field;
                  return unit;
                }
              }
              let struct_field_ref_valid: own Bool = semantic_type_members_node_valid(ast: ast, node: struct_field);
              match struct_field_ref_valid {
                True() => {
                }
                False() => {
                  set deref(report).status = SemanticTypeMembersMalformedDeclaration();
                  set deref(report).declaration = members_top;
                  set deref(report).related = struct_field;
                  return unit;
                }
              }
              let struct_field_name_token: own u64 = index<u64>(deref(ast).heads, struct_field);
              let struct_field_name_valid: own Bool = semantic_type_members_head_valid(source: source, tokens: tokens, ast: ast, node: struct_field, want_kind: 1_u64);
              match struct_field_name_valid {
                True() => {
                }
                False() => {
                  set deref(report).status = SemanticTypeMembersInvalidNameToken();
                  set deref(report).declaration = struct_field;
                  set deref(report).related = struct_field_name_token;
                  return unit;
                }
              }
              let struct_field_shape_valid: own Bool = semantic_type_members_field_shape_valid(source: source, tokens: tokens, ast: ast, field: struct_field);
              match struct_field_shape_valid {
                True() => {
                }
                False() => {
                  set deref(report).status = SemanticTypeMembersMalformedDeclaration();
                  set deref(report).declaration = struct_field;
                  set deref(report).related = struct_field;
                  return unit;
                }
              }
              match ieq<u64>(struct_field, struct_first_field) {
                True() => {
                }
                False() => {
                  let struct_prior_field: own u64 = semantic_type_members_prior_field(source: source, tokens: tokens, ast: ast, first: struct_first_field, current: struct_field, name_token: struct_field_name_token);
                  match ieq<u64>(struct_prior_field, ast_none) {
                    True() => {
                    }
                    False() => {
                      set deref(report).status = SemanticTypeMembersDuplicate();
                      set deref(report).declaration = struct_field;
                      set deref(report).related = struct_prior_field;
                      return unit;
                    }
                  }
                }
              }
              let struct_existing_slot: own u64 = symbol_none;
              region 'type_member_find_field {
                set struct_existing_slot = symbol_find_slot(source: source, tokens: tokens, symbols: &uniq 'type_member_find_field deref(symbols), space_code: 0_u64, scope: members_top, name_token: struct_field_name_token);
              }
              match ieq<u64>(struct_existing_slot, symbol_none) {
                True() => {
                }
                False() => {
                  let struct_existing_declaration: own u64 = index<u64>(deref(symbols).declarations, struct_existing_slot);
                  set deref(report).status = SemanticTypeMembersDuplicate();
                  set deref(report).declaration = struct_field;
                  set deref(report).related = struct_existing_declaration;
                  return unit;
                }
              }
              set members_field_total = iadd.trap<u64>(members_field_total, 1_u64);
              set deref(report).field_count = members_field_total;
              set struct_previous_member = struct_field;
              set struct_field = index<u64>(deref(ast).next_siblings, struct_field);
              set struct_member_steps = iadd.trap<u64>(struct_member_steps, 1_u64);
            }
            let struct_last_matches: own Bool = ieq<u64>(struct_previous_member, struct_last_member);
            match struct_last_matches {
              True() => {
              }
              False() => {
                set deref(report).status = SemanticTypeMembersMalformedDeclaration();
                set deref(report).declaration = members_top;
                set deref(report).related = struct_last_member;
                return unit;
              }
            }
          }
          False() => {
          }
        }
      }
    }

    set members_previous_top = members_top;
    let members_next_top: own u64 = index<u64>(deref(ast).next_siblings, members_top);
    match ieq<u64>(members_next_top, ast_none) {
      True() => {
        break @validate_type_member_tops;
      }
      False() => {
        set members_top = members_next_top;
      }
    }
    set members_top_steps = iadd.trap<u64>(members_top_steps, 1_u64);
  }

  let members_last_matches: own Bool = ieq<u64>(members_previous_top, members_last_top);
  match members_last_matches {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticTypeMembersInvalidAstTape();
      set deref(report).declaration = members_root;
      set deref(report).related = members_last_top;
      return unit;
    }
  }

  let members_needed: own u64 = iadd.trap<u64>(members_variant_total, members_field_total);
  let members_capacity_valid: own Bool = False();
  region 'type_members_capacity_check {
    set members_capacity_valid = semantic_globals_capacity_valid(symbols: &uniq 'type_members_capacity_check deref(symbols), needed: members_needed);
  }
  match members_capacity_valid {
    True() => {
    }
    False() => {
      set deref(report).status = SemanticTypeMembersCapacity();
      set deref(report).declaration = ast_none;
      set deref(report).related = members_needed;
      return unit;
    }
  }

  let members_base: own u64 = deref(symbols).count;
  let members_committed: own u64 = 0_u64;
  let commit_top: own u64 = members_first_top;
  let commit_top_steps: own u64 = 0_u64;
  loop @commit_type_member_tops {
    let commit_top_kind: own AstKind = index<AstKind>(deref(ast).kinds, commit_top);
    let commit_enum_tag: own AstKind = AstEnumDecl();
    let commit_struct_tag: own AstKind = AstStructDecl();
    let commit_is_enum: own Bool = ieq<AstKind>(commit_top_kind, commit_enum_tag);
    let commit_is_struct: own Bool = ieq<AstKind>(commit_top_kind, commit_struct_tag);
    match commit_is_enum {
      True() => {
        let commit_enum_name: own u64 = index<u64>(deref(ast).first_children, commit_top);
        let commit_variant: own u64 = index<u64>(deref(ast).next_siblings, commit_enum_name);
        loop @commit_enum_variants {
          match ieq<u64>(commit_variant, ast_none) {
            True() => {
              break @commit_enum_variants;
            }
            False() => {
            }
          }
          let commit_variant_slot: own u64 = iadd.trap<u64>(members_base, members_committed);
          let commit_variant_token: own u64 = index<u64>(deref(ast).heads, commit_variant);
          set index<SymbolNamespace>(deref(symbols).namespaces, commit_variant_slot) = SymbolConstructor();
          set index<u64>(deref(symbols).scopes, commit_variant_slot) = symbol_none;
          set index<u64>(deref(symbols).name_tokens, commit_variant_slot) = commit_variant_token;
          set index<u64>(deref(symbols).declarations, commit_variant_slot) = commit_variant;
          set members_committed = iadd.trap<u64>(members_committed, 1_u64);
          set commit_variant = index<u64>(deref(ast).next_siblings, commit_variant);
        }
      }
      False() => {
        match commit_is_struct {
          True() => {
            let commit_struct_name: own u64 = index<u64>(deref(ast).first_children, commit_top);
            let commit_field: own u64 = index<u64>(deref(ast).next_siblings, commit_struct_name);
            loop @commit_struct_fields {
              match ieq<u64>(commit_field, ast_none) {
                True() => {
                  break @commit_struct_fields;
                }
                False() => {
                }
              }
              let commit_field_slot: own u64 = iadd.trap<u64>(members_base, members_committed);
              let commit_field_token: own u64 = index<u64>(deref(ast).heads, commit_field);
              set index<SymbolNamespace>(deref(symbols).namespaces, commit_field_slot) = SymbolValue();
              set index<u64>(deref(symbols).scopes, commit_field_slot) = commit_top;
              set index<u64>(deref(symbols).name_tokens, commit_field_slot) = commit_field_token;
              set index<u64>(deref(symbols).declarations, commit_field_slot) = commit_field;
              set members_committed = iadd.trap<u64>(members_committed, 1_u64);
              set commit_field = index<u64>(deref(ast).next_siblings, commit_field);
            }
          }
          False() => {
          }
        }
      }
    }
    let commit_next_top: own u64 = index<u64>(deref(ast).next_siblings, commit_top);
    set commit_top_steps = iadd.trap<u64>(commit_top_steps, 1_u64);
    match ieq<u64>(commit_next_top, ast_none) {
      True() => {
        break @commit_type_member_tops;
      }
      False() => {
        set commit_top = commit_next_top;
      }
    }
  }

  let members_final_count: own u64 = iadd.trap<u64>(members_base, members_committed);
  set deref(symbols).count = members_final_count;
  set deref(symbols).status = SymbolClean();
  set deref(symbols).related = symbol_none;
  set deref(report).status = SemanticTypeMembersClean();
  set deref(report).declaration = ast_none;
  set deref(report).related = symbol_none;
  set deref(report).variant_count = members_variant_total;
  set deref(report).field_count = members_field_total;
  return unit;
}
