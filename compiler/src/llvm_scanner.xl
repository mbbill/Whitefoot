  }
  region 'llvm_scanner_header_space2 {
    llvm_text_emit_space(out: &uniq 'llvm_scanner_header_space2 deref(out));
  }
  region 'llvm_scanner_header_p0 {
    llvm_text_emit_place(out: &uniq 'llvm_scanner_header_p0 deref(out), id: 0_u64);
  }
  let parameter: own u64 = 1_u64;
  loop @llvm_scanner_header_u64_parameters {
    region 'llvm_scanner_header_comma {
      llvm_buffer_emit_comma_space(out: &uniq 'llvm_scanner_header_comma deref(out));
