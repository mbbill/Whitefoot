    match ieq<u64>(child, function_last) {
      True() => {
        let function_terminal: own u64 = index<u64>(deref(ast).next_siblings, child);
        let function_terminated: own Bool = ieq<u64>(function_terminal, ast_none);
        let has_uniq: own Bool = igt<u64>(uniq_count, 0_u64);
        return band<Bool>(function_terminated, has_uniq);
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, child);
    match ilt<u64>(next, ast_count) {
      True() => {
        set child = next;
      }
      False() => {
        return False();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }
}

fn semantic_reader_writer_body_valid ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, symbols: &'c SymbolTape, function: own u64, writes_node: own u64, block: own u64, allow_user_call: own Bool, allow_index_target: own Bool) -> own Bool reads('c), traps {
  let ast_count: own u64 = deref(ast).count;
  let function_valid: own Bool = ilt<u64>(function, ast_count);
  let writes_valid: own Bool = ilt<u64>(writes_node, ast_count);
  let block_valid: own Bool = ilt<u64>(block, ast_count);
  let first_valid: own Bool = band<Bool>(function_valid, writes_valid);
  match band<Bool>(first_valid, block_valid) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let writes_first: own u64 = index<u64>(deref(ast).first_children, writes_node);
  let writes_last: own u64 = index<u64>(deref(ast).last_children, writes_node);
  let writes_one: own Bool = ieq<u64>(writes_first, writes_last);
  let writes_present: own Bool = ine<u64>(writes_first, ast_none);
  match band<Bool>(writes_one, writes_present) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let writes_region_valid: own Bool = semantic_function_region_leaf_valid<'c, 'c, 'c>(source: source, tokens: tokens, ast: ast, node: writes_first);
  match writes_region_valid {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let writes_region_head: own u64 = index<u64>(deref(ast).heads, writes_first);
  let statement: own u64 = index<u64>(deref(ast).first_children, block);
  let last_statement: own u64 = index<u64>(deref(ast).last_children, block);
  let statement_present: own Bool = ine<u64>(statement, ast_none);
  let last_present: own Bool = ine<u64>(last_statement, ast_none);
  match band<Bool>(statement_present, last_present) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let set_count: own u64 = 0_u64;
  let return_count: own u64 = 0_u64;
  let steps: own u64 = 0_u64;
  let ast_set_atom: own AstKind = AstSet();
  let ast_return_atom: own AstKind = AstReturn();
  let ast_place_use_atom: own AstKind = AstPlaceUse();
  let ast_numeric_literal_atom: own AstKind = AstNumericLiteral();
  let ast_constructor_atom: own AstKind = AstConstructor();
  let ast_user_call_atom: own AstKind = AstUserCall();
  let ast_unit_literal_atom: own AstKind = AstUnitLiteral();
  loop @semantic_reader_writer_body_scan {
    match ilt<u64>(statement, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    let statement_kind: own AstKind = index<AstKind>(deref(ast).kinds, statement);
    let is_set: own Bool = eeq<AstKind>(statement_kind, ast_set_atom);
    let is_return: own Bool = eeq<AstKind>(statement_kind, ast_return_atom);
    match is_set {
      True() => {
        let set_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: statement, want: 2_u64);
        let set_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: statement);
        match band<Bool>(set_shape, set_token) {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let set_head: own u64 = index<u64>(deref(ast).heads, statement);
        let set_word: own Bool = parser_word3<'c, 'c>(source: source, tokens: tokens, token: set_head, a: 115_u8, b: 101_u8, c: 116_u8);
        match set_word {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let target: own u64 = semantic_body_child_at<'c>(ast: ast, node: statement, ordinal: 0_u64);
        let field_target: own Bool = semantic_reader_writer_field_target_valid<'c>(source: source, tokens: tokens, ast: ast, function: function, writes_region_head: writes_region_head, target: target);
        let index_target: own Bool = False();
        match allow_index_target {
          True() => {
            set index_target = semantic_reader_writer_index_target_valid<'c>(source: source, tokens: tokens, ast: ast, symbols: symbols, function: function, writes_region_head: writes_region_head, target: target);
          }
          False() => {
          }
        }
        match bor<Bool>(field_target, index_target) {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let value: own u64 = semantic_body_child_at<'c>(ast: ast, node: statement, ordinal: 1_u64);
        let value_place: own Bool = semantic_body_kind_is<'c>(ast: ast, node: value, want: ast_place_use_atom);
        let value_numeric: own Bool = semantic_body_kind_is<'c>(ast: ast, node: value, want: ast_numeric_literal_atom);
        let value_constructor: own Bool = semantic_body_kind_is<'c>(ast: ast, node: value, want: ast_constructor_atom);
        let value_user_call: own Bool = semantic_body_kind_is<'c>(ast: ast, node: value, want: ast_user_call_atom);
        let value_literal: own Bool = bor<Bool>(value_numeric, value_constructor);
        let value_leaf_kind: own Bool = bor<Bool>(value_place, value_literal);
        let value_leaf: own Bool = semantic_body_exact_children<'c>(ast: ast, node: value, want: 0_u64);
        let value_leaf_ok: own Bool = band<Bool>(value_leaf_kind, value_leaf);
        let value_call_ok: own Bool = band<Bool>(value_user_call, allow_user_call);
        let value_shape_ok: own Bool = bor<Bool>(value_leaf_ok, value_call_ok);
        let value_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: value);
        match band<Bool>(value_shape_ok, value_token) {
          True() => {
            set set_count = iadd.trap<u64>(set_count, 1_u64);
          }
          False() => {
            return False();
          }
        }
      }
      False() => {
      }
    }
    match is_return {
      True() => {
        match ieq<u64>(statement, last_statement) {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let return_shape: own Bool = semantic_body_exact_children<'c>(ast: ast, node: statement, want: 1_u64);
        let return_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: statement);
        match band<Bool>(return_shape, return_token) {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let value: own u64 = semantic_body_child_at<'c>(ast: ast, node: statement, ordinal: 0_u64);
        let value_kind: own Bool = semantic_body_kind_is<'c>(ast: ast, node: value, want: ast_unit_literal_atom);
        let value_leaf: own Bool = semantic_body_exact_children<'c>(ast: ast, node: value, want: 0_u64);
        let value_token: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: value);
        let value_a: own Bool = band<Bool>(value_kind, value_leaf);
        match band<Bool>(value_a, value_token) {
          True() => {
          }
          False() => {
            return False();
          }
        }
        let value_head: own u64 = index<u64>(deref(ast).heads, value);
        let value_word: own Bool = parser_word4<'c, 'c>(source: source, tokens: tokens, token: value_head, a: 117_u8, b: 110_u8, c: 105_u8, d: 116_u8);
        match value_word {
          True() => {
            set return_count = iadd.trap<u64>(return_count, 1_u64);
          }
          False() => {
            return False();
          }
        }
      }
      False() => {
      }
    }
    match bor<Bool>(is_set, is_return) {
      True() => {
      }
      False() => {
        return False();
      }
    }
    match ieq<u64>(statement, last_statement) {
      True() => {
        let terminal: own u64 = index<u64>(deref(ast).next_siblings, statement);
        let terminated: own Bool = ieq<u64>(terminal, ast_none);
        let has_set: own Bool = igt<u64>(set_count, 0_u64);
        let one_return: own Bool = ieq<u64>(return_count, 1_u64);
        let counts_ok: own Bool = band<Bool>(has_set, one_return);
        return band<Bool>(terminated, counts_ok);
      }
      False() => {
      }
    }
    let next: own u64 = index<u64>(deref(ast).next_siblings, statement);
    match ilt<u64>(next, ast_count) {
      True() => {
        set statement = next;
      }
      False() => {
        return False();
      }
    }
    set steps = iadd.trap<u64>(steps, 1_u64);
    match ilt<u64>(steps, ast_count) {
      True() => {
      }
      False() => {
        return False();
      }
    }
  }
}
