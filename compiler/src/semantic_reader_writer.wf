fn semantic_reader_writer_leaf_token_exact ['c] (source: &'c buffer<u8>, tokens: &'c TokenTape, ast: &'c AstTape, node: own u64) -> own Bool reads('c), traps {
  let leaf: own Bool = semantic_body_exact_children<'c>(ast: ast, node: node, want: 0_u64);
  let token_valid: own Bool = semantic_body_node_token_valid<'c>(source: source, tokens: tokens, ast: ast, node: node);
  match band<Bool>(leaf, token_valid) {
    True() => {
    }
    False() => {
      return False();
    }
  }
  let head: own u64 = index<u64>(deref(ast).heads, node);
  let token_start: own u64 = index<u64>(deref(tokens).starts, head);
  let token_end: own u64 = index<u64>(deref(tokens).ends, head);
  let node_start: own u64 = index<u64>(deref(ast).starts, node);
  let node_end: own u64 = index<u64>(deref(ast).ends, node);
  let start_exact: own Bool = ieq<u64>(token_start, node_start);
  let end_exact: own Bool = ieq<u64>(token_end, node_end);
  return band<Bool>(start_exact, end_exact);
}

