{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlang.local/codegen-corpus/schema.json",
  "title": "xlang codegen corpus family",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "family", "tags", "hypothesis", "measurement", "cases"],
  "properties": {
    "schema": {"const": 1},
    "family": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[/-][a-z0-9]+)*$"
    },
    "tags": {"$ref": "#/$defs/tags"},
    "hypothesis": {"type": "string", "minLength": 1},
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["function", "metric"],
      "properties": {
        "function": {"type": "string", "minLength": 1},
        "metric": {"type": "string", "minLength": 3},
        "opt": {"enum": ["O0", "O1", "O2", "O3", "Os", "Oz"]},
        "facts_on": {"type": "string"},
        "facts_off": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "hypothesis", "tags", "maturity", "expected"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "source": {"type": "string", "pattern": "^[^/]+\\.xl$"},
        "hypothesis": {"type": "string", "minLength": 1},
        "tags": {"$ref": "#/$defs/tags"},
        "maturity": {"enum": ["explore", "audit", "gate"]},
        "expected": {
          "type": "object",
          "required": ["proof_classification", "bounds_sites"],
          "properties": {
            "proof_classification": {"enum": ["proved", "elided", "retained", "checked", "mixed"]},
            "bounds_sites": {"type": "integer", "minimum": 1},
            "proved_sites": {"type": "integer", "minimum": 1},
            "retained_sites": {"type": "integer", "minimum": 1},
            "checked_automation_ready": {"type": "boolean"},
            "checked_automation_disposition_counts": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "automatically-accounted",
                "intrinsic-dynamic",
                "hard-finding",
                "unaccounted"
              ],
              "properties": {
                "automatically-accounted": {"type": "integer", "minimum": 0},
                "intrinsic-dynamic": {"type": "integer", "minimum": 0},
                "hard-finding": {"type": "integer", "minimum": 0},
                "unaccounted": {"type": "integer", "minimum": 0}
              }
            },
            "obligation_status": {
              "enum": ["derived", "failed-premise", "not-applicable", "unknown"]
            },
            "obligation_exactness": {
              "type": ["string", "null"],
              "enum": ["exact", "sufficient", "unknown", null]
            },
            "requirement_relation": {
              "type": ["string", "null"],
              "enum": ["equivalent", "missing", "mismatch", "unknown", "not-applicable", null]
            },
            "obligation_status_counts": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "enum": ["derived", "failed-premise", "not-applicable", "unknown"]
              },
              "additionalProperties": {"type": "integer", "minimum": 1}
            },
            "obligation_exactness_counts": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "enum": ["exact", "sufficient", "unknown", "<null>"]
              },
              "additionalProperties": {"type": "integer", "minimum": 1}
            },
            "requirement_relation_counts": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "enum": ["equivalent", "missing", "mismatch", "unknown", "not-applicable", "<null>"]
              },
              "additionalProperties": {"type": "integer", "minimum": 1}
            },
            "first_failed_premise_reason_counts": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {"type": "string", "minLength": 1},
              "additionalProperties": {"type": "integer", "minimum": 1}
            },
            "first_missing_fact": {
              "type": ["object", "null"]
            },
            "first_failed_premise": {
              "oneOf": [
                {"type": "null"},
                {"type": "string", "minLength": 1},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["reason"],
                  "properties": {
                    "reason": {"type": "string", "minLength": 1},
                    "expected": {"type": "string"},
                    "observed": {"type": "string"},
                    "path": {"type": "string"}
                  }
                }
              ]
            },
            "first_failed_premise_reason": {
              "type": ["string", "null"]
            }
          },
          "dependentRequired": {
            "checked_automation_ready": ["checked_automation_disposition_counts"],
            "checked_automation_disposition_counts": ["checked_automation_ready"]
          },
          "additionalProperties": true
        }
      }
    }
  }
}
