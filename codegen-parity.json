        {
          "label": "base64 has no missing capacity fact",
          "left": "facts.proof.first_missing_fact_count",
          "op": "eq",
          "value": 0
        },
        {
          "label": "base64 has no failed PROOF-2 premise",
          "left": "facts.proof.first_failed_premise_count",
          "op": "eq",
          "value": 0
        },
        {
          "label": "facts-off retains every base64 bounds site",
          "left": "nofacts.proof.retained",
          "op": "eq",
          "value": 27
        },
        {
          "label": "facts-off enumerates the same 27 sites",
