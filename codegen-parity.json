          "facts": false,
          "opt": "O3"
        }
      ],
      "checks": [
        {
          "label": "base64 encode has 27 lowered bounds sites",
          "left": "facts.proof.eligible",
          "op": "eq",
          "value": 27
        },
        {
          "label": "local and checked-capacity proofs discharge all 27 sites",
          "left": "facts.proof.proved",
