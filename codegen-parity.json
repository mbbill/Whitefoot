          "op": "eq",
          "value": {}
        },
        {
          "label": "proved sites are exactly source, alphabet, and output accesses",
          "left": "facts.proof.proved_targets",
          "op": "eq",
          "value": {"b64": 9, "out": 12, "src": 6}
        },
        {
          "label": "nine alphabet sites use masked-index proof",
          "left": "facts.proof.masked_index",
          "op": "eq",
          "value": 9
        },
        {
          "label": "three full-loop source sites use remainder guard",
          "left": "facts.proof.remainder_guard",
          "op": "eq",
          "value": 3
        },
        {
          "label": "three tail source sites use remainder proof",
          "left": "facts.proof.remainder_tail",
          "op": "eq",
          "value": 3
        },
        {
          "label": "twelve output sites use the checked capacity lockstep proof",
          "left": "facts.proof.output_capacity_lockstep",
          "op": "eq",
          "value": 12
        },
        {
          "label": "base64 obligation diagnostics are facts-independent",
