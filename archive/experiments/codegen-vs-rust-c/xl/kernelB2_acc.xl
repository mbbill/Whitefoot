fn accumulate ['r] (acc: &uniq 'r u64, addend: &'r u64, n: own u64) -> own unit reads('r), writes('r) {
  let i: own u64 = 0_u64;
  loop @l {
    match ige<u64>(i, n) {
      True() => {
        break @l;
      }
      False() => {
      }
    }
    let r1: own u64 = irotl<u64>(deref(acc), 1_u32);
    set deref(acc) = ixor<u64>(r1, deref(addend));
    set i = iadd.wrap<u64>(i, 1_u64);
  }
  return unit;
}
