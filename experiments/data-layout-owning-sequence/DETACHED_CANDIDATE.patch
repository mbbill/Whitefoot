+    def _flat_field_error(self, ty, stack):
+        if not isinstance(ty, dict):
+            return "malformed field type"
+        k = ty.get("kind")
+        if k == "prim":
+            name = ty.get("name")
+            if name in PRIMS - {"f32", "f64"}:
+                return None
+            if name in ("f32", "f64"):
