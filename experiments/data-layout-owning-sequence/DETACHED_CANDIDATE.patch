+            why = self._flat_field_error(fld.get("ty"), child_stack)
+            if why is not None:
+                result = (False, f"field {name}.{fld.get('name')}: {why}")
+                self._flat_record_cache[name] = result
+                return result
+        result = (True, None)
+        self._flat_record_cache[name] = result
+        return result
