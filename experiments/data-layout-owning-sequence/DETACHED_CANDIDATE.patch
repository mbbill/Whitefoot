+                return None if ok else why
+            variants = self.enums.get(name)
+            if variants is None:
+                return f"unknown named type {name}"
+            if variants and all(not v["fields"] for v in variants):
+                return None
+            return f"payload or empty enum {name} is not a first-slice Flat field"
+        if k == "unit":
+            return "unit/zero-sized fields are outside the first slice"
+        if k == "array":
+            return "array fields are deferred in the first slice"
+        if k == "slice" or k == "ref":
+            return f"{k} carries borrowed provenance"
+        if k in ("box", "buffer", "arena", "cell", "sequence"):
+            return f"{k} carries ownership, provenance, or a drop obligation"
+        if k == "any":
+            return "erased/any fields cannot prove a fixed ownership-free layout"
+        return f"unsupported field type kind {k!r}"
+
+    def _flat_record_shape(self, name, stack=()):
+        cached = self._flat_record_cache.get(name)
+        if cached is not None:
+            return cached
+        if name in stack:
+            cycle = " -> ".join((*stack, name))
+            return False, f"by-value record cycle {cycle} has no finite layout"
+        fields = self.structs.get(name)
+        if fields is None:
+            return False, f"unknown record {name}"
+        if name in self.enums:
+            result = (False,
+                      f"record name {name} collides with an enum and is ambiguous")
+            self._flat_record_cache[name] = result
+            return result
+        if not fields:
+            result = (False,
+                      f"record {name} is zero-sized; zero-stride elements are deferred")
+            self._flat_record_cache[name] = result
+            return result
+        child_stack = (*stack, name)
