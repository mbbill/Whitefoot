+# E0.1a candidate: Token/Ast-shaped records pin natural 24/56-byte layouts.
+flat_records = """enum RowKind {
+  RowZero();
+  RowOne();
+  RowOther();
+}
+
+struct TokenRow {
+  kind: RowKind;
+  start: u64;
+  end: u64;
+}
+
+struct AstRow {
+  kind: RowKind;
+  parent: u64;
+  first: u64;
+  last: u64;
+  next: u64;
+  start: u64;
+  end: u64;
+}
+
+struct Tapes {
+  tokens: buffer<TokenRow>;
+  ast: buffer<AstRow>;
+}
+
+fn read_end ['row] (row: & 'row TokenRow) -> own u64 reads('row) {
+  return deref(row).end;
+}
+
+fn field_kernel ['tapes] (tapes: &uniq 'tapes Tapes) -> own unit reads('tapes), writes('tapes), traps {
+  let token_start: own u64 = index<TokenRow>(deref(tapes).tokens, 0_u64).start;
+  set index<TokenRow>(deref(tapes).tokens, 0_u64).end = token_start;
+  let ast_parent: own u64 = index<AstRow>(deref(tapes).ast, 0_u64).parent;
+  set index<AstRow>(deref(tapes).ast, 0_u64).end = ast_parent;
+  return unit;
+}
+
+fn main () -> own unit allocates(heap), traps {
+  let tokens: own buffer<TokenRow> = buffer_new<TokenRow>(2_u64, TokenRow(kind: RowZero(), start: 1_u64, end: 2_u64));
+  let ast: own buffer<AstRow> = buffer_new<AstRow>(1_u64, AstRow(kind: RowZero(), parent: 7_u64, first: 0_u64, last: 0_u64, next: 0_u64, start: 8_u64, end: 9_u64));
+  set index<TokenRow>(tokens, 1_u64) = TokenRow(kind: RowOne(), start: 10_u64, end: 11_u64);
+  region 'row_borrow {
+    let row: & 'row_borrow TokenRow = & 'row_borrow index<TokenRow>(tokens, 1_u64);
+    let borrowed_end: own u64 = read_end(row: row);
+    check ieq<u64>(borrowed_end, 11_u64) else trap "row borrow changed stride";
+  }
+  let tapes: own Tapes = Tapes(tokens: move tokens, ast: move ast);
+  region 'tapes_borrow {
+    field_kernel(tapes: &uniq 'tapes_borrow tapes);
+  }
+  let token_end: own u64 = index<TokenRow>(tapes.tokens, 0_u64).end;
+  let ast_end: own u64 = index<AstRow>(tapes.ast, 0_u64).end;
