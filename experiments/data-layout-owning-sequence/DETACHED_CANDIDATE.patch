+def _ty_exact_eq(a, b) -> bool:
+    """Representation-sensitive equality for explicitly typed places.
+
+    `_ty_eq` deliberately permits `any`/erased compatibility.  `index<T>` is
+    a lowering input, so its T must identify the exact element stride instead.
+    """
+    if not isinstance(a, dict) or not isinstance(b, dict):
+        return False
+    if a.get("kind") != b.get("kind"):
+        return False
+    k = a.get("kind")
+    if k == "prim":
+        return a.get("name") == b.get("name")
+    if k == "named":
+        if a.get("name") != b.get("name"):
+            return False
+        aa, ba = a.get("args"), b.get("args")
+        if aa is None or ba is None:
+            return aa is None and ba is None
+        return (len(aa) == len(ba)
+                and all(_ty_exact_eq(x, y) for x, y in zip(aa, ba)))
+    if k in ("unit", "any"):
+        return True
+    if k in ("box", "buffer"):
+        return _ty_exact_eq(a.get("elem"), b.get("elem"))
+    if k == "array":
+        return (a.get("n") == b.get("n")
+                and _ty_exact_eq(a.get("elem"), b.get("elem")))
+    if k in ("slice", "arena"):
+        return (a.get("region") == b.get("region")
+                and _ty_exact_eq(a.get("elem"), b.get("elem")))
+    return False
+
