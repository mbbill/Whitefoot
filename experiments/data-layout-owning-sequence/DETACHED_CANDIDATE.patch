+def _flat_record_layout(name, structs, enums, memo=None, stack=()):
+    """Conservative E0.1a eligibility plus the candidate 64-bit layout model.
+
+    The result is used only for zero-size/alignment rejection.  Allocation uses
+    an LLVM GEP-derived stride, leaving the selected target layout authoritative.
+    """
+    memo = {} if memo is None else memo
+    if name in memo:
+        return memo[name]
+    if name in stack:
+        cycle = " -> ".join((*stack, name))
+        raise SystemExit(
+            f"democ: buffer<{stack[0]}> is outside the E0.1a flat-record "
+            f"candidate (recursive by-value struct cycle: {cycle})"
+        )
+    fields = structs.get(name)
+    if fields is None:
+        raise SystemExit(f"democ: {name} is not a struct in the E0.1a candidate")
+    if not fields:
+        raise SystemExit(
+            f"democ: buffer<{name}> is outside the E0.1a flat-record candidate "
+            "(zero-sized records are rejected)"
+        )
+    if name in enums:
+        raise SystemExit(
+            f"democ: buffer<{name}> is outside the E0.1a flat-record candidate "
+            "(the name collides with an enum)"
+        )
+
+    def leaf_layout(tyname):
+        if tyname in INT_LLTY:
+            width = _tybytes(tyname)
+            return width, width
+        if tyname == "Bool" or tyname in _TAGONLY2:
+            return 1, 1
+        variants = enums.get(tyname)
+        if variants and all(not fields for _variant, fields in variants):
+            return 4, 4
+        variants = PRELUDE_ENUMS.get(tyname)
+        if variants and all(not variant["fields"] for variant in variants):
+            return (1, 1) if tyname == "Bool" else (4, 4)
+        if tyname in structs:
+            return _flat_record_layout(
+                tyname, structs, enums, memo=memo, stack=(*stack, name)
+            )
+        root = stack[0] if stack else name
+        raise SystemExit(
+            f"democ: buffer<{root}> is outside the E0.1a flat-record candidate "
+            f"(field type {tyname} is not a stage-0 integer, tag-only enum, "
+            "or non-empty flat record)"
+        )
+
+    offset, maximum_alignment = 0, 1
+    for field in fields:
+        size, alignment = leaf_layout(field["ty"])
+        offset = (offset + alignment - 1) // alignment * alignment
+        offset += size
+        maximum_alignment = max(maximum_alignment, alignment)
+    size = (offset + maximum_alignment - 1) // maximum_alignment * maximum_alignment
+    if maximum_alignment > 8:
+        raise SystemExit(
+            f"democ: buffer<{name}> requires alignment {maximum_alignment}, above "
+            "the E0.1a candidate allocator guarantee of 8"
+        )
+    memo[name] = (size, maximum_alignment)
+    return memo[name]
+
